        "rev_2": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "Ordered a Sangeet outfit and it was delivered faster than expected. The colors were vibrant and the embroidery was exquisite. Everyone was asking where I got it from!",
