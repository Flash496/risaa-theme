            "reviewer_meta": "Sangeet look · Delhi",
            "show_verified": true
          }
        },
        "rev_3": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "My entire trousseau was handled by Rima and her team. They understood my vision better than I did. Truly accessible luxury — worth every rupee.",
            "reviewer_name": "Meera K.",
            "reviewer_meta": "Trousseau client · Mumbai",
            "show_verified": true
          }
        },
        "rev_4": {
          "type": "review",
          "settings": {
            "rating": 5,
            "review_text": "The customization process was so smooth. They were patient with all my requests. The reception lehenga turned out to be a masterpiece!",
            "reviewer_name": "Simran D.",
            "reviewer_meta": "Reception outfit · Chandigarh",
            "show_verified": true
          }
        }
      },
      "block_order": ["rev_1", "rev_2", "rev_3", "rev_4"],
