{%- style -%}
  .section-{{ section.id }}-padding {
    --risaa-active-glow: 154, 28, 32;
    position: relative;
    overflow: visible;
    isolation: isolate;
  }

  .section-{{ section.id }}-padding::before,
  .section-{{ section.id }}-padding::after {
    content: "";
    position: absolute;
    pointer-events: none;
    z-index: -1;
  }

  .section-{{ section.id }}-padding::before {
    inset: -140px 0 -110px;
    background:
      radial-gradient(circle at 50% 45%, rgba(var(--risaa-active-glow), 0.28), rgba(var(--risaa-active-glow), 0.1) 30%, transparent 64%),
      radial-gradient(circle at 18% 55%, rgba(var(--risaa-active-glow), 0.15), transparent 44%),
      radial-gradient(circle at 82% 55%, rgba(var(--risaa-active-glow), 0.15), transparent 44%);
    filter: blur(20px);
    opacity: 1;
    transition: background 0.7s ease, opacity 0.7s ease;
  }

  .section-{{ section.id }}-padding::after {
    inset: 8% 14% -18%;
    background:
      radial-gradient(ellipse at 50% 62%, rgba(var(--risaa-active-glow), 0.2), rgba(var(--risaa-active-glow), 0.08) 38%, transparent 68%);
    filter: blur(44px);
    opacity: 0.85;
    transform: translateY(32px);
    transition: background 0.7s ease, opacity 0.7s ease;
  }

  .section-{{ section.id }}-padding .section-header {
    margin-bottom: 10px !important;
    padding-top: 20px !important;
    padding-bottom: 0 !important;
  }

  .section-{{ section.id }}-padding .section-header h2 {
    color: rgb(var(--risaa-active-glow)) !important;
    transition: color 0.7s ease;
    margin-bottom: 0 !important;
    padding-bottom: 0 !important;
  }

  .section-{{ section.id }}-padding .section-header h2::after {
    display: none !important;
    content: none !important;
  }

  .risaa-3d-carousel-wrapper {
    position: relative;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px 30px;
    overflow-x: clip;
    overflow-y: visible;
  }

  .risaa-3d-carousel-container {
    position: relative;
    width: 100%;
    height: 540px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .risaa-3d-carousel-track {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .risaa-3d-carousel-item {
    position: absolute;
    width: 455px;
    height: auto;
    background: transparent;
    text-decoration: none;
    color: inherit;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.33, 1), opacity 0.6s cubic-bezier(0.25, 1, 0.33, 1);
    text-align: center;
    cursor: pointer;
  }

  .risaa-collage {
    position: relative;
    height: 455px;
    margin-bottom: 20px;
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.33, 1), box-shadow 0.5s ease;
    border-radius: 8px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.18), 0 4px 12px rgba(0, 0, 0, 0.1);
  }

  .risaa-collage__main {
    width: 81%;
    height: 85%;
    position: absolute;
    top: 1%;
    left: -1%;
    object-fit: cover;
    z-index: 1;
    border-radius: 6px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.33, 1);
  }

  .risaa-collage__third {
    width: 44%;
    height: 55%;
    position: absolute;
    top: 38%;
    left: 4%;
    object-fit: cover;
    z-index: 3;
    border: 4px solid white;
    border-radius: 6px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    transform: rotate(-5deg);
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.33, 1);
  }

  .risaa-collage__fourth {
    width: 44%;
    height: 52%;
    position: absolute;
    top: 2%;
    right: 2%;
    object-fit: cover;
    z-index: 4;
    border: 4px solid white;
    border-radius: 6px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    transform: rotate(4deg);
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.33, 1);
  }

  .risaa-collage__sub {
    width: 59%;
    height: 50%;
    position: absolute;
    top: calc(40% + 5px);
    left: 53%;
    object-fit: cover;
    z-index: 2;
    border: 4px solid white;
    border-radius: 6px;
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.22), 0 4px 10px rgba(0, 0, 0, 0.12);
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.33, 1);
  }

  /* Interaction effects on active card hover */
  .risaa-3d-carousel-item.is-active:hover .risaa-collage {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 18px 35px rgba(0, 0, 0, 0.25);
  }

  .risaa-3d-carousel-item.is-active:hover .risaa-collage__main {
    transform: translate(-4px, -4px) scale(1.02);
  }

  .risaa-3d-carousel-item.is-active:hover .risaa-collage__third {
    transform: translate(-4px, 4px) scale(1.04) rotate(-7deg);
  }

  .risaa-3d-carousel-item.is-active:hover .risaa-collage__fourth {
    transform: translate(4px, -4px) scale(1.04) rotate(6deg);
  }

  .risaa-3d-carousel-item.is-active:hover .risaa-collage__sub {
    transform: translate(6px, 8px) scale(1.06);
  }

  .risaa-3d-carousel-item h3 {
    font-size: 1.8rem;
    letter-spacing: 0.18em;
    margin: 12px 0 4px;
    text-transform: uppercase;
    color: var(--brand-dark-text, #111);
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .risaa-3d-carousel-item.is-active h3 {
    color: #6E1423;
  }

  .risaa-3d-carousel-item span {
    font-size: 1.15rem;
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
  }

  /* Navigation Buttons */
  .risaa-3d-carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #ffffff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 25;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 6px 16px rgba(0,0,0,0.08);
  }

  .risaa-3d-carousel-btn svg {
    width: 18px;
    height: 18px;
    stroke: #6e1423;
    stroke-width: 2.5;
    fill: none;
  }

  .risaa-3d-carousel-btn:hover {
    background: #D4AF37;
    color: #ffffff;
    border-color: #D4AF37;
    box-shadow: 0 8px 24px rgba(216, 167, 100, 0.32);
    transform: translateY(-50%) scale(1.08);
  }

  .risaa-3d-carousel-btn--prev {
    left: 40px;
  }

  .risaa-3d-carousel-btn--next {
    right: 40px;
  }

  /* Navigation Dots */
  .risaa-3d-carousel-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 10px;
  }

  .risaa-3d-carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.15);
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .risaa-3d-carousel-dot.is-active {
    background: #6E1423;
    width: 26px;
    border-radius: 5px;
  }

  @media screen and (max-width: 989px) {
    .risaa-3d-carousel-btn--prev {
      left: 15px;
    }
    .risaa-3d-carousel-btn--next {
      right: 15px;
    }
    .risaa-3d-carousel-item {
      width: 390px;
      height: auto;
    }
    .risaa-collage {
      height: 390px;
    }
  }

  @media screen and (max-width: 749px) {
    .risaa-3d-carousel-container {
      height: 420px;
    }
    .risaa-3d-carousel-btn {
      width: 40px;
      height: 40px;
    }
    .risaa-3d-carousel-btn svg {
      width: 16px;
      height: 16px;
    }
    .risaa-3d-carousel-item {
      width: 312px;
      height: auto;
    }
    .risaa-collage {
      height: 312px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding reveal-on-scroll">
  <div class="section-header">
    <h2>{{ section.settings.title }}</h2>
    <p>{{ section.settings.subtitle }}</p>
  </div>

  <div class="risaa-3d-carousel-wrapper">
    <button class="risaa-3d-carousel-btn risaa-3d-carousel-btn--prev" aria-label="Previous slide">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="20" y1="12" x2="4" y2="12"/>
        <polyline points="10 6 4 12 10 18"/>
      </svg>
    </button>

    <div class="risaa-3d-carousel-container">
      <div class="risaa-3d-carousel-track">
        {% for block in section.blocks %}
          {%- assign _col_main_imgs = 'https://ik.imagekit.io/flashspdstr/risaa/Ruby%20primary.jpg,https://ik.imagekit.io/flashspdstr/risaa/kesar%20primary.png,https://ik.imagekit.io/flashspdstr/risaa/mocha%20primary.jpg,https://ik.imagekit.io/flashspdstr/risaa/indigo%20main.jpg,https://ik.imagekit.io/flashspdstr/risaa/matcha%20main.jpg'
            | split: ','
          -%}
          {%- assign _col_sub_imgs = 'https://ik.imagekit.io/flashspdstr/risaa/Ruby%20secondary.jpg,https://ik.imagekit.io/flashspdstr/risaa/kesar%20secondary.png,https://ik.imagekit.io/flashspdstr/risaa/mocha%20secondary.jpg,https://ik.imagekit.io/flashspdstr/risaa/indigo%20secondary.jpg,https://ik.imagekit.io/flashspdstr/risaa/matcha%20secondary.jpg'
            | split: ','
          -%}
          {%- assign _col_third_imgs = 'https://ik.imagekit.io/flashspdstr/risaa/ruby%20third.jpg,https://ik.imagekit.io/flashspdstr/risaa/saffron%20third.jpg,https://ik.imagekit.io/flashspdstr/risaa/mocha%20third.jpg,https://ik.imagekit.io/flashspdstr/risaa/indigo%20third.jpg,https://ik.imagekit.io/flashspdstr/risaa/matcha%20third.jpg'
            | split: ','
          -%}
          {%- assign _col_fourth_imgs = 'https://ik.imagekit.io/flashspdstr/risaa/ruby%204th.jpg,https://ik.imagekit.io/flashspdstr/risaa/saffron%204th.jpg,https://ik.imagekit.io/flashspdstr/risaa/mocha%204th.jpg,https://ik.imagekit.io/flashspdstr/risaa/indigo%204th.jpg,https://ik.imagekit.io/flashspdstr/risaa/matcha%204th.jpg'
            | split: ','
          -%}
          {%- assign _col_main = _col_main_imgs[forloop.index0] | default: _col_main_imgs[0] -%}
          {%- assign _col_sub = _col_sub_imgs[forloop.index0] | default: _col_sub_imgs[0] -%}
          {%- assign _col_third = _col_third_imgs[forloop.index0] | default: _col_third_imgs[0] -%}
          {%- assign _col_fourth = _col_fourth_imgs[forloop.index0] | default: _col_fourth_imgs[0] -%}

          <a href="{{ block.settings.link }}" class="risaa-3d-carousel-item" {{ block.shopify_attributes }}>
            <div class="risaa-collage">
              {% if block.settings.main_image != blank %}
                {{
                  block.settings.main_image
                  | image_url: width: 600
                  | image_tag: class: 'risaa-collage__main', loading: 'lazy'
                }}
              {% else %}
                <img
                  src="{{ _col_main }}"
                  alt="{{ block.settings.color_name }}"
                  class="risaa-collage__main"
                  loading="lazy"
                >
              {% endif %}

              {% if block.settings.third_image != blank %}
                {{
                  block.settings.third_image
                  | image_url: width: 500
                  | image_tag: class: 'risaa-collage__third', loading: 'lazy'
                }}
              {% else %}
                <img
                  src="{{ _col_third }}"
                  alt="{{ block.settings.color_name }}"
                  class="risaa-collage__third"
                  loading="lazy"
                >
              {% endif %}

              <img
                src="{{ _col_fourth }}"
                alt="{{ block.settings.color_name }}"
                class="risaa-collage__fourth"
                loading="lazy"
              >

              {% if block.settings.sub_image != blank %}
                {{
                  block.settings.sub_image
                  | image_url: width: 400
                  | image_tag: class: 'risaa-collage__sub', loading: 'lazy'
                }}
              {% else %}
                <img
                  src="{{ _col_sub }}"
                  alt="{{ block.settings.color_name }}"
                  class="risaa-collage__sub"
                  loading="lazy"
                >
              {% endif %}
            </div>
            <h3>{{ block.settings.color_name }}</h3>
          </a>
        {% endfor %}
      </div>
    </div>

    <button class="risaa-3d-carousel-btn risaa-3d-carousel-btn--next" aria-label="Next slide">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="4" y1="12" x2="20" y2="12"/>
        <polyline points="14 6 20 12 14 18"/>
      </svg>
    </button>

    <div class="risaa-3d-carousel-dots"></div>
  </div>
</div>

<script>
  (function () {
    document.addEventListener('DOMContentLoaded', () => {
      const wrapper = document.querySelector('.section-{{ section.id }}-padding');
      if (!wrapper) return;

      const track = wrapper.querySelector('.risaa-3d-carousel-track');
      const items = wrapper.querySelectorAll('.risaa-3d-carousel-item');
      const dotsContainer = wrapper.querySelector('.risaa-3d-carousel-dots');
      const btnPrev = wrapper.querySelector('.risaa-3d-carousel-btn--prev');
      const btnNext = wrapper.querySelector('.risaa-3d-carousel-btn--next');

      if (!items.length) return;

      let currentIndex = 0; // Start with Ruby (first item)
      const glowColors = {
        ruby: '154, 28, 32',
        kesar: '225, 140, 35',
        saffron: '225, 140, 35',
        mocha: '126, 80, 55',
        indigo: '53, 68, 132',
        matcha: '105, 139, 79',
        emerald: '4, 121, 87',
        gold: '216, 167, 100',
        ivory: '245, 240, 230',
        blush: '248, 183, 153',
      };

      function updateGlowColor() {
        const activeName = items[currentIndex]?.querySelector('h3')?.textContent.trim().toLowerCase();
        const glowColor = glowColors[activeName] || '154, 28, 32';
        wrapper.style.setProperty('--risaa-active-glow', glowColor);
      }

      // Generate dots
      items.forEach((_, index) => {
        const dot = document.createElement('div');
        dot.classList.add('risaa-3d-carousel-dot');
        if (index === currentIndex) dot.classList.add('is-active');
        dot.addEventListener('click', () => {
          currentIndex = index;
          updateCarousel();
        });
        dotsContainer.appendChild(dot);
      });

      const dots = dotsContainer.querySelectorAll('.risaa-3d-carousel-dot');

      function updateCarousel() {
        const isMobile = window.innerWidth <= 749;
        const isTablet = window.innerWidth <= 989 && window.innerWidth > 749;
        const cardWidth = isMobile ? 312 : isTablet ? 390 : 455;
        const gap = isMobile ? 24 : 40;
        const step = cardWidth + gap;

        items.forEach((item, index) => {
          let offset = index - currentIndex;

          // Wrap for circular loop
          const half = Math.floor(items.length / 2);
          if (offset > half) offset -= items.length;
          else if (offset < -half) offset += items.length;

          const absOffset = Math.abs(offset);
          const translateX = offset * step;
          const scale = offset === 0 ? 1 : 0.88;
          const opacity = absOffset > 1 ? 0 : offset === 0 ? 1 : 0.85;
          const zIndex = offset === 0 ? 10 : 5 - absOffset;

          item.style.transform = `translateX(${translateX}px) scale(${scale})`;
          item.style.opacity = opacity;
          item.style.zIndex = zIndex;
          item.style.pointerEvents = absOffset > 1 ? 'none' : 'auto';

          if (offset === 0) {
            item.classList.add('is-active');
          } else {
            item.classList.remove('is-active');
          }
        });

        dots.forEach((dot, index) => {
          dot.classList.toggle('is-active', index === currentIndex);
        });

        updateGlowColor();
      }

      // Control buttons action
      btnPrev.addEventListener('click', () => {
        currentIndex = (currentIndex - 1 + items.length) % items.length;
        updateCarousel();
      });

      btnNext.addEventListener('click', () => {
        currentIndex = (currentIndex + 1) % items.length;
        updateCarousel();
      });

      // Click item to bring it to center
      items.forEach((item, index) => {
        item.addEventListener('click', (e) => {
          if (index !== currentIndex) {
            e.preventDefault(); // Don't navigate to collection link on initial click
            currentIndex = index;
            updateCarousel();
          }
        });
      });

      // Swipe gestures for touch screens
      let startX = 0;
      let dragActive = false;

      track.addEventListener(
        'touchstart',
        (e) => {
          startX = e.touches[0].clientX;
          dragActive = true;
        },
        { passive: true }
      );

      track.addEventListener(
        'touchmove',
        (e) => {
          if (!dragActive) return;
          const diffX = e.touches[0].clientX - startX;
          if (Math.abs(diffX) > 60) {
            if (diffX > 0) {
              currentIndex = (currentIndex - 1 + items.length) % items.length;
            } else {
              currentIndex = (currentIndex + 1) % items.length;
            }
            updateCarousel();
            dragActive = false;
          }
        },
        { passive: true }
      );

      track.addEventListener('touchend', () => {
        dragActive = false;
      });

      window.addEventListener('resize', updateCarousel);
      updateCarousel();
    });
  })();
</script>

{% schema %}
{
  "name": "Shop by Colour",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Shop by Colour"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Curated palettes for every mood"
    }
  ],
  "blocks": [
    {
      "type": "color_block",
      "name": "Color Category",
      "settings": [
        {
          "type": "text",
          "id": "color_name",
          "label": "Color Name",
          "default": "RUBY"
        },
        {
          "type": "text",
          "id": "count_text",
          "label": "Count Text",
          "default": "Explore 24+ styles"
        },
        {
          "type": "image_picker",
          "id": "main_image",
          "label": "Main Product Image"
        },
        {
          "type": "image_picker",
          "id": "third_image",
          "label": "Detail/Zoom Image"
        },
        {
          "type": "image_picker",
          "id": "sub_image",
          "label": "Mood/Abstract Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Colour",
      "blocks": [
        { "type": "color_block", "settings": { "color_name": "RUBY" } },
        { "type": "color_block", "settings": { "color_name": "SAFFRON" } },
        { "type": "color_block", "settings": { "color_name": "MOCHA" } },
        { "type": "color_block", "settings": { "color_name": "INDIGO" } },
        { "type": "color_block", "settings": { "color_name": "MATCHA" } }
      ]
    }
  ]
}
{% endschema %}
