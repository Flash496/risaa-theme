{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* ── RiSaa Footer — Seeaash-inspired layout ── */
  .risaa-footer {
    background: #9a1c20;
    color: rgba(255, 255, 255, 0.9);
    font-family: var(--font-body-family);
    font-size: 1.3rem;
    line-height: 1.7;
  }

  /* Rounded bottom edge effect above footer */
  .risaa-footer::before {
    content: '';
    display: block;
    height: 40px;
    background: var(--color-background, #ffffff);
    border-radius: 0 0 32px 32px;
    margin-bottom: -1px;
  }

  /* Widen footer beyond default page-width margins */
  .risaa-footer .page-width {
    max-width: 1600px;
    padding-left: 32px;
    padding-right: 32px;
  }

  @media screen and (min-width: 750px) {
    .risaa-footer .page-width {
      padding-left: 48px;
      padding-right: 48px;
    }
  }

  .risaa-footer__top {
    display: grid;
    grid-template-columns: 420px 0.45fr 0.45fr 0.65fr 0.8fr 1.2fr;
    gap: 32px;
    padding: 60px 0 48px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
  }

  .risaa-footer__logo-wrap {
    position: relative;
    display: inline-block;
    margin-bottom: 32px;
  }

  .risaa-footer__logo {
    display: block;
    text-decoration: none;
    line-height: 0;
    font-size: 0;
  }

  .risaa-footer__logo img {
    max-width: 160px;
    height: auto;
    filter: none;
    opacity: 1;
    display: block;
  }

  .risaa-footer__logo-text {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 400;
  }

  .risaa-footer__brand-desc {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.75;
    margin: 0 0 24px;
    font-weight: 300;
  }

  .risaa-footer__social {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-top: 4px;
  }

  .risaa-footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid rgba(255, 255, 255, 0.45);
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: border-color 0.25s ease, color 0.25s ease, background 0.25s ease;
  }

  .risaa-footer__social a:hover {
    border-color: white;
    color: white;
    background: rgba(255, 255, 255, 0.15);
  }

  .risaa-footer__social svg {
    width: 15px;
    height: 15px;
    fill: currentColor;
  }

  .risaa-footer__social--inline {
    margin-top: 18px;
  }

  .risaa-footer__nav-heading {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: white !important;
    margin: 0 0 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
  }

  /* Override any inline styles on headings */
  .risaa-footer__nav-heading,
  .risaa-footer__nav-heading *,
  .risaa-footer__newsletter-label {
    color: white !important;
  }

  .risaa-footer__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .risaa-footer__nav-list a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    font-size: 1.25rem;
    font-weight: 300;
    letter-spacing: 0.02em;
    transition: color 0.2s ease;
  }

  .risaa-footer__nav-list a:hover {
    color: white;
  }

  .risaa-footer__newsletter-strip {
    padding: 28px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
    display: flex;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .risaa-footer__newsletter-label {
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.95);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .risaa-footer__newsletter-form {
    display: flex;
    gap: 0;
    flex: 1;
    max-width: 420px;
  }

  .risaa-footer__newsletter-form input[type='email'] {
    flex: 1;
    background: rgba(255, 255, 255, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-right: none;
    color: white;
    font-size: 1.25rem;
    padding: 10px 16px;
    outline: none;
    font-family: var(--font-body-family);
    border-radius: 3px 0 0 3px;
    transition: border-color 0.2s ease;
  }

  .risaa-footer__newsletter-form input[type='email']::placeholder {
    color: rgba(255, 255, 255, 0.55);
  }

  .risaa-footer__newsletter-form input[type='email']:focus {
    border-color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.25);
  }

  .risaa-footer__newsletter-form button {
    background: rgba(255, 255, 255, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.4);
    color: white;
    padding: 10px 18px;
    font-size: 1.2rem;
    cursor: pointer;
    font-family: var(--font-body-family);
    letter-spacing: 0.08em;
    border-radius: 0 3px 3px 0;
    transition: background 0.2s ease;
    white-space: nowrap;
  }

  .risaa-footer__newsletter-form button:hover {
    background: rgba(255, 255, 255, 0.38);
  }

  .risaa-footer__bottom {
    padding: 20px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .risaa-footer__copyright {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 300;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .risaa-footer__copyright a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
  }

  .risaa-footer__copyright a:hover {
    color: white;
  }

  /* Force all footer links to be white */
  .risaa-footer a {
    color: rgba(255, 255, 255, 0.85) !important;
  }

  .risaa-footer a:hover {
    color: white !important;
  }

  /* Override Shopify powered_by_link default styling */
  .risaa-footer__copyright a,
  .risaa-footer__copyright a:visited,
  .risaa-footer__copyright a:link {
    color: rgba(255, 255, 255, 0.7) !important;
  }

  .risaa-footer__copyright a:hover {
    color: white !important;
  }

  .risaa-footer__payment .list-payment {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .risaa-footer__payment .list-payment__item svg,
  .risaa-footer__payment .list-payment__item img {
    height: 22px;
    width: auto;
    border-radius: 3px;
    opacity: 0.75;
  }

  .risaa-footer__text-block {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1.75;
  }

  .risaa-footer__text-block a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
  }

  .risaa-footer__text-block a:hover {
    color: white;
  }

  .risaa-footer__text-block p {
    margin: 0 0 6px;
  }

  /* Map container for store location */
  .risaa-footer__map-wrapper {
    display: flex;
    flex-direction: column;
  }

  .risaa-footer__map-container {
    width: 100%;
    height: 320px;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .risaa-footer__map-container iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  .risaa-footer__directions-btn,
  .risaa-footer__text-block a[href*='maps.app.goo.gl'],
  .risaa-footer__text-block a[href*='maps.google'] {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 14px;
    padding: 9px 20px;
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 2px;
    color: white !important;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.15rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none !important;
    background: transparent;
    position: relative;
    overflow: hidden;
    transition: border-color 0.35s ease;
  }

  .risaa-footer__text-block a[href*='maps.app.goo.gl']::before,
  .risaa-footer__text-block a[href*='maps.google']::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.12);
    transform: translateX(-101%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .risaa-footer__directions-btn:hover,
  .risaa-footer__text-block a[href*='maps.app.goo.gl']:hover,
  .risaa-footer__text-block a[href*='maps.google']:hover {
    border-color: white;
    color: white !important;
  }

  .risaa-footer__text-block a[href*='maps.app.goo.gl']:hover::before,
  .risaa-footer__text-block a[href*='maps.google']:hover::before {
    transform: translateX(0);
  }

  @media screen and (max-width: 989px) {
    .risaa-footer__top {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 36px;
    }
    .risaa-footer__brand {
      grid-column: span 3;
    }
    .risaa-footer__map-wrapper {
      grid-column: span 3;
    }
  }

  @media screen and (max-width: 749px) {
    .risaa-footer__top {
      grid-template-columns: 1fr;
      padding: 40px 0 32px;
      gap: 28px;
    }
    .risaa-footer__brand {
      grid-column: span 1;
    }
    .risaa-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
    .risaa-footer__newsletter-strip {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }
    .risaa-footer__newsletter-form {
      width: 100%;
      max-width: 100%;
    }
  }
{%- endstyle -%}

{%- liquid
  assign has_social_instagram = false
  assign has_social_facebook = false
  assign has_social_youtube = false
  assign has_social_pinterest = false
  assign has_social_tiktok = false
  if settings.social_instagram_link != blank
    assign has_social_instagram = true
  endif
  if settings.social_facebook_link != blank
    assign has_social_facebook = true
  endif
  if settings.social_youtube_link != blank
    assign has_social_youtube = true
  endif
  if settings.social_pinterest_link != blank
    assign has_social_pinterest = true
  endif
  if settings.social_tiktok_link != blank
    assign has_social_tiktok = true
  endif
-%}

<footer class="risaa-footer">
  <div class="page-width">
    <div class="risaa-footer__top">
      <!-- Brand column -->
      <div class="risaa-footer__brand">
        <div class="risaa-footer__logo-wrap">
          <a href="{{ routes.root_url }}" class="risaa-footer__logo">
            {%- if settings.brand_image != blank -%}
              {{ settings.brand_image | image_url: width: 300 | image_tag: loading: 'lazy', alt: shop.name }}
            {%- else -%}
              <img
                src="{{ 'risaa-logo-brand name with background removed.png' | asset_url }}"
                alt="{{ shop.name }}"
                width="160"
                height="auto"
                loading="lazy"
              >
            {%- endif -%}
          </a>
        </div>

        {%- if section.settings.brand_description != blank -%}
          <p class="risaa-footer__brand-desc">{{ section.settings.brand_description }}</p>
        {%- elsif settings.brand_description != blank -%}
          <p class="risaa-footer__brand-desc">{{ settings.brand_description }}</p>
        {%- else -%}
          <p class="risaa-footer__brand-desc">
            Accessible Luxury · Slow Fashion · Prêt · Fusion.<br>
            Handcrafted for the woman of today.<br>
            <br>
            Born in Ludhiana, RiSaa is a design studio by Rima — where every piece is thoughtfully crafted to celebrate
            individuality. From bridal couture to everyday pret, we believe luxury should feel personal, not out of
            reach.
          </p>
        {%- endif -%}
      </div>

      <!-- Nav columns from blocks -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="risaa-footer__nav-col" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h3 class="risaa-footer__nav-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="risaa-footer__nav-list">
                {%- for link in block.settings.menu.links -%}
                  <li>
                    <a href="{{ link.url }}">{{ link.title | escape }}</a>
                  </li>
                {%- endfor -%}
                {%- if block.settings.heading == 'Shop' or block.settings.heading == 'Quick Links' -%}
                  <li><a href="/collections/summer-favourites">Summer Favourites</a></li>
                  <li><a href="/collections/founders-pick">Founder's Pick</a></li>
                {%- endif -%}
              </ul>
            {%- endif -%}
          </div>
        {%- elsif block.type == 'text' -%}
          <div class="risaa-footer__nav-col" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h3 class="risaa-footer__nav-heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            <div class="risaa-footer__text-block">
              {{ block.settings.subtext }}
            </div>
            {%- if block.settings.heading == 'Contact Us' or block.settings.heading == 'Visit Our Store' -%}
              <div class="risaa-footer__social risaa-footer__social--inline">
                {%- if settings.social_instagram_link != blank -%}
                  <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
                    <svg viewBox="0 0 24 24">
