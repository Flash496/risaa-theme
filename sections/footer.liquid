{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* ── RiSaa Footer — Seeaash-inspired layout ── */
  .risaa-footer {
    background: #4d0e18;
    color: rgba(255, 255, 255, 0.9);
    font-family: var(--font-body-family);
    font-size: 1.3rem;
    line-height: 1.7;
  }

  /* Widen footer beyond default page-width margins */
  .risaa-footer .page-width {
    max-width: 1600px;
    padding-left: 32px;
    padding-right: 32px;
  }

  @media screen and (min-width: 750px) {
    .risaa-footer .page-width {
      padding-left: 48px;
      padding-right: 48px;
    }
  }

  .risaa-footer__top {
    padding: 60px 0 0;
  }

  /* Map row — full width at top */
  .risaa-footer__map-row {
    margin-bottom: 40px;
    padding-bottom: 0;
    width: calc(100% + 64px);
    margin-left: -32px;
    margin-right: -32px;
  }

  @media screen and (min-width: 750px) {
    .risaa-footer__map-row {
      width: calc(100% + 96px);
      margin-left: -48px;
      margin-right: -48px;
    }
  }

  /* Columns row — brand + nav columns */
  .risaa-footer__cols-row {
    display: grid;
    padding-bottom: 0;
    grid-template-columns: 420px 0.55fr 0.55fr 0.75fr;
    gap: 32px;
    padding-bottom: 0;
  }

  .risaa-footer__brand {
    /* just a normal grid cell — no spanning */
  }

  .risaa-footer__logo-wrap {
    padding-bottom: 20px;
  }

  .risaa-footer__logo {
    display: block;
    text-decoration: none;
    line-height: 0;
    font-size: 0;
  }

  .risaa-footer__logo img {
    max-width: 192px;
    height: auto;
    filter: none;
    opacity: 1;
    display: block;
  }

  .risaa-footer__logo-text {
    font-family: var(--font-heading-family);
    font-size: 2rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 400;
  }

  .risaa-footer__brand-desc {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.75;
    margin: 0 0 24px;
    font-weight: 300;
  }

  .risaa-footer__social {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-top: 4px;
  }

  .risaa-footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    text-decoration: none;
    transition: transform 0.25s ease, filter 0.25s ease, box-shadow 0.25s ease;
  }

  /* Colorful social buttons with brand colors */
  .risaa-footer__social a.social-btn--whatsapp {
    background-color: #25d366;
    border: 1px solid #25d366;
  }
  .risaa-footer__social a.social-btn--instagram {
    background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
    border: 1px solid transparent;
  }
  .risaa-footer__social a.social-btn--facebook {
    background-color: #1877f2;
    border: 1px solid #1877f2;
  }
  .risaa-footer__social a.social-btn--youtube {
    background-color: #ff0000;
    border: 1px solid #ff0000;
  }
  .risaa-footer__social a.social-btn--tiktok {
    background-color: #000000;
    border: 1px solid #000000;
  }

  .risaa-footer__social a:hover {
    transform: translateY(-2px) scale(1.1);
    filter: brightness(1.15);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
  }

  .risaa-footer__social svg {
    width: 17px;
    height: 17px;
    fill: #ffffff !important;
  }

  .risaa-footer__social--inline {
    margin-top: 18px;
  }

  .risaa-footer__nav-heading {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: white !important;
    margin: 0 0 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
  }

  /* Override any inline styles on headings */
  .risaa-footer__nav-heading,
  .risaa-footer__nav-heading *,
  .risaa-footer__newsletter-label {
    color: white !important;
  }

  .risaa-footer__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .risaa-footer__nav-list a {
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    font-size: 1.25rem;
    font-weight: 300;
    letter-spacing: 0.02em;
    transition: color 0.2s ease;
  }

  .risaa-footer__nav-list a:hover {
    color: white;
  }

  .risaa-footer__contact-links {
    margin-top: 14px;
  }

  .risaa-footer__newsletter-strip {
    padding: 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.25);
    display: flex;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .risaa-footer__newsletter-label {
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.95);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .risaa-footer__newsletter-form {
    display: flex;
    gap: 0;
    flex: 1;
    max-width: 420px;
  }

  .risaa-footer__newsletter-form input[type='email'] {
    flex: 1;
    background: rgba(255, 255, 255, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-right: none;
    color: white;
    font-size: 1.25rem;
    padding: 10px 16px;
    outline: none;
    font-family: var(--font-body-family);
    border-radius: 3px 0 0 3px;
    transition: border-color 0.2s ease;
  }

  .risaa-footer__newsletter-form input[type='email']::placeholder {
    color: rgba(255, 255, 255, 0.55);
  }

  .risaa-footer__newsletter-form input[type='email']:focus {
    border-color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.25);
  }

  .risaa-footer__newsletter-form button {
    background: rgba(255, 255, 255, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.4);
    color: white;
    padding: 10px 18px;
    font-size: 1.2rem;
    cursor: pointer;
    font-family: var(--font-body-family);
    letter-spacing: 0.08em;
    border-radius: 0 3px 3px 0;
    transition: background 0.2s ease;
    white-space: nowrap;
  }

  .risaa-footer__newsletter-form button:hover {
    background: rgba(255, 255, 255, 0.38);
  }

  .risaa-footer__bottom {
    padding: 20px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .risaa-footer__copyright {
    font-size: 1.15rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 300;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .risaa-footer__copyright a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
  }

  .risaa-footer__copyright a:hover {
    color: white;
  }

  /* Force all footer links to be white */
  .risaa-footer a {
    color: rgba(255, 255, 255, 0.85) !important;
  }

  .risaa-footer a:hover {
    color: white !important;
  }

  /* Override Shopify powered_by_link default styling */
  .risaa-footer__copyright a,
  .risaa-footer__copyright a:visited,
  .risaa-footer__copyright a:link {
    color: rgba(255, 255, 255, 0.7) !important;
  }

  .risaa-footer__copyright a:hover {
    color: white !important;
  }

  .risaa-footer__payment .list-payment {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .risaa-footer__payment .list-payment__item svg,
  .risaa-footer__payment .list-payment__item img {
    height: 22px;
    width: auto;
    border-radius: 3px;
    opacity: 0.75;
  }

  .risaa-footer__text-block {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1.25rem;
    font-weight: 300;
    line-height: 1.75;
  }

  .risaa-footer__text-block a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
  }

  .risaa-footer__text-block a:hover {
    color: white;
  }

  .risaa-footer__text-block p {
    margin: 0 0 6px;
  }

  /* Get Directions button */
  .risaa-footer__get-directions-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    background: #1a73e8;
    color: #fff !important;
    font-family: Arial, sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    text-decoration: none !important;
    border-radius: 999px;
    border: none;
    box-shadow: 0 2px 6px rgba(26, 115, 232, 0.28);
    transition: background 0.25s ease, box-shadow 0.2s ease;
    white-space: nowrap;
  }

  .risaa-footer__get-directions-btn:hover {
    background: #1558b0 !important;
    color: #fff !important;
    box-shadow: 0 3px 9px rgba(26, 115, 232, 0.35);
  }

  /* Map-as-background for Visit Our Store — full width row */
  .risaa-footer__nav-col--map-bg {
    position: relative;
    overflow: hidden;
    border-radius: 4px 4px 30px 30px;
    min-height: 220px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  /* Map iframe fills the entire row as background */
  .risaa-footer__nav-col--map-bg .risaa-footer__map-bg-iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    display: block;
    z-index: 0;
  }

  /* Dark gradient — stronger on left where text sits */
  .risaa-footer__nav-col--map-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(80, 10, 12, 0.92) 0%,
      rgba(80, 10, 12, 0.7) 35%,
      rgba(80, 10, 12, 0.2) 65%,
      rgba(80, 10, 12, 0.05) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  /* Text content — left-aligned, sits above the overlay */
  .risaa-footer__nav-col--map-bg .risaa-footer__map-bg-content {
    position: relative;
    z-index: 2;
    max-width: 360px;
    margin: 24px 0 24px 28px;
    padding: 18px 18px 14px;
    background: #fff;
    color: #202124;
    border-radius: 8px;
    box-shadow: 0 2px 6px rgba(60, 64, 67, 0.3), 0 1px 2px rgba(60, 64, 67, 0.15);
  }

  .risaa-footer__nav-col--map-bg .risaa-footer__nav-heading {
    margin: 0 0 10px;
    padding: 5px 0 0;
    border-bottom: 0;
    color: #202124 !important;
    font-family: Arial, sans-serif;
    font-size: 1.6rem;
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.3;
    text-transform: none;
  }

  .risaa-footer__map-rating {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
    color: #70757a;
    font-family: Arial, sans-serif;
    font-size: 1.2rem;
    line-height: 1;
  }

  .risaa-footer__map-rating-score {
    color: #202124;
    font-weight: 500;
  }

  .risaa-footer__map-stars {
    color: #fbbc04;
    letter-spacing: -0.08em;
  }

  .risaa-footer__map-place-type {
    color: #70757a;
  }

  .risaa-footer__nav-col--map-bg .risaa-footer__text-block,
  .risaa-footer__nav-col--map-bg .risaa-footer__text-block p {
    color: #3c4043;
    font-family: Arial, sans-serif;
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.45;
  }

  .risaa-footer__nav-col--map-bg .risaa-footer__text-block p {
    margin: 0 0 8px;
  }

  .risaa-footer__nav-col--map-bg .risaa-footer__text-block a {
    color: #1a73e8 !important;
  }

  .risaa-footer__map-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px solid #e8eaed;
  }

  .risaa-footer__map-action {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #1a73e8 !important;
    font-family: Arial, sans-serif;
    font-size: 1.2rem;
    font-weight: 500;
    text-decoration: none !important;
  }

  .risaa-footer__text-block a[href*='maps.app.goo.gl']::before,
  .risaa-footer__text-block a[href*='maps.google']::before {
    display: none;
  }

  .risaa-footer__text-block a[href*='maps.app.goo.gl']:hover,
  .risaa-footer__text-block a[href*='maps.google']:hover {
    color: white !important;
  }

  @media screen and (max-width: 989px) {
    .risaa-footer__cols-row {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 36px;
    }
    .risaa-footer__brand {
      grid-column: span 3;
    }
    .risaa-footer__nav-col--map-bg {
      min-height: 180px;
    }
  }

  @media screen and (max-width: 749px) {
    .risaa-footer__top {
      padding: 30px 0 0;
    }
    .risaa-footer__cols-row {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      padding-bottom: 24px;
    }
    .risaa-footer__brand {
      order: 1;
      grid-column: span 2;
      margin-bottom: 12px;
    }
    .risaa-footer__brand-desc {
      margin-bottom: 12px;
    }
    /* Shop column (2nd child) */
    .risaa-footer__cols-row > div:nth-child(2) {
      order: 2;
      grid-column: span 1;
    }
    /* About column (4th child) */
    .risaa-footer__cols-row > div:nth-child(4) {
      order: 3;
      grid-column: span 1;
    }
    /* Policies column (3rd child) */
    .risaa-footer__cols-row > div:nth-child(3) {
      order: 4;
      grid-column: span 2;
      margin-top: 10px;
    }
    /* Split Policies links into 2 columns */
    .risaa-footer__cols-row > div:nth-child(3) .risaa-footer__nav-list {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px 16px;
    }
    .risaa-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
    .risaa-footer__newsletter-strip {
      flex-direction: column;
      align-items: flex-start;
      gap: 14px;
    }
    .risaa-footer__newsletter-form {
      width: 100%;
    }
  }
{%- endstyle -%}

{%- liquid
  assign has_social_instagram = false
  assign has_social_facebook = false
  assign has_social_youtube = false
  assign has_social_pinterest = false
  assign has_social_tiktok = false
  if settings.social_instagram_link != blank
    assign has_social_instagram = true
  endif
  if settings.social_facebook_link != blank
    assign has_social_facebook = true
  endif
  if settings.social_youtube_link != blank
    assign has_social_youtube = true
  endif
  if settings.social_pinterest_link != blank
    assign has_social_pinterest = true
  endif
  if settings.social_tiktok_link != blank
    assign has_social_tiktok = true
  endif
-%}

<footer class="risaa-footer">
  <div class="page-width">
    <div class="risaa-footer__top">
      <!-- COLUMNS ROW: Brand + Shop + Help + Contact Us -->
      <div class="risaa-footer__cols-row">
        <!-- Brand column -->
        <div class="risaa-footer__brand">
          <div class="risaa-footer__logo-wrap">
            <a href="{{ routes.root_url }}" class="risaa-footer__logo">
              {%- if false -%}
                {{ settings.brand_image | image_url: width: 300 | image_tag: loading: 'lazy', alt: shop.name }}
              {%- else -%}
                <img
                  src="https://ik.imagekit.io/flashspdstr/risaa/risaa%20Logo%20new%20white%20and%20red-Photoroom.png?updatedAt=1780806177877"
                  alt="{{ shop.name }}"
                  width="192"
                  height="auto"
                  loading="lazy"
                >
              {%- endif -%}
            </a>
          </div>
          {%- if section.settings.brand_description != blank -%}
            <p class="risaa-footer__brand-desc">{{ section.settings.brand_description }}</p>
          {%- elsif settings.brand_description != blank -%}
            <p class="risaa-footer__brand-desc">{{ settings.brand_description }}</p>
          {%- else -%}
            <p class="risaa-footer__brand-desc">
              Accessible Luxury · Slow Fashion · Prêt · Fusion.<br>
              Handcrafted for the woman of today.<br>
              <br>
              Born in Ludhiana, RiSaa is a design studio by Rima — where every piece is thoughtfully crafted to
              celebrate individuality. From bridal couture to everyday pret, we believe luxury should feel personal, not
              out of reach.
            </p>
          {%- endif -%}
        </div>

        <!-- Nav columns (excluding Visit Our Store) -->
        {%- for block in section.blocks -%}
          {%- if block.type == 'link_list' -%}
            <div class="risaa-footer__nav-col" {{ block.shopify_attributes }}>
              {%- assign heading_down = block.settings.heading | downcase | strip -%}
              {%- if block.settings.heading != blank -%}
                <h3 class="risaa-footer__nav-heading">
                  {%- if heading_down == 'help' or heading_down == 'policies' -%}
                    Policies
                  {%- else -%}
                    {{ block.settings.heading }}
                  {%- endif -%}
                </h3>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="risaa-footer__nav-list">
                  {%- unless heading_down == 'help' or heading_down == 'policies' -%}
                    {%- for link in block.settings.menu.links -%}
                      {%- assign display_title = link.title | escape -%}
                      {%- assign link_title_lower = link.title | downcase | strip -%}
                      {%- if link_title_lower == 'catalogue' or link_title_lower == 'catalog' -%}
                        {%- assign display_title = 'Shop All' -%}
                      {%- endif -%}
                      {%- if link_title_lower contains 'contact' -%}
                        {%- if heading_down == 'shop' or heading_down == 'quick links' -%}
                          {%- continue -%}
                        {%- endif -%}
                      {%- endif -%}
                      <li>
                        <a href="{{ link.url }}">{{ display_title }}</a>
                      </li>
                    {%- endfor -%}
                  {%- endunless -%}
                  {%- if heading_down == 'shop' or heading_down == 'quick links' -%}
                    <li><a href="/collections/bestsellers">Bestsellers</a></li>
                  {%- endif -%}
                  {%- if heading_down == 'help' or heading_down == 'policies' -%}
                    <li><a href="/pages/about-us">FAQ</a></li>
                    <li>
                      <a href="{{ shop.url }}/policies/refund-policy">Returns, Exchange &amp; Cancellation Policy</a>
                    </li>
                    <li><a href="{{ shop.url }}/policies/shipping-policy">Shipping Policy</a></li>
                    <li><a href="{{ shop.url }}/policies/privacy-policy">Privacy Policy</a></li>
                    <li><a href="{{ shop.url }}/policies/terms-of-service">Terms of Service</a></li>
                    <li><a href="{{ shop.url }}/policies/refund-policy">Refund policy</a></li>
                  {%- endif -%}
                </ul>
              {%- endif -%}
            </div>
          {%- elsif block.type == 'text' -%}
            {%- assign heading_down = block.settings.heading | downcase | strip -%}
            {%- unless heading_down == 'visit our store' -%}
              <div class="risaa-footer__nav-col" {{ block.shopify_attributes }}>
                {%- assign is_about_col = false -%}
                {%- if heading_down == 'contact us' or heading_down == 'about' -%}
                  {%- assign is_about_col = true -%}
                {%- endif -%}
                {%- if block.settings.heading != blank -%}
                  <h3 class="risaa-footer__nav-heading">
                    {%- if is_about_col -%}
                      About
                    {%- else -%}
                      {{ block.settings.heading }}
                    {%- endif -%}
                  </h3>
                {%- endif -%}
                {%- unless is_about_col -%}
                  <div class="risaa-footer__text-block">{{ block.settings.subtext }}</div>
                {%- endunless -%}
                {%- if is_about_col -%}
                  <ul class="risaa-footer__nav-list risaa-footer__contact-links">
                    <li><a href="/pages/our-store">Our Store</a></li>
                    <li><a href="/pages/about">About Us</a></li>
                    <li><a href="/pages/contact">Contact Us</a></li>
                    <li><a href="/pages/book-an-appointment">Book an Appointment</a></li>
                  </ul>
                  <div class="risaa-footer__social risaa-footer__social--inline">
                    <a
                      href="https://wa.me/919501032126?text=Hello%20RiSaa!%20I'm%20reaching%20out%20from%20your%20website."
                      class="social-btn--whatsapp"
                      target="_blank"
                      rel="noopener"
                      aria-label="WhatsApp"
                    >
                      <svg viewBox="0 0 24 24">
