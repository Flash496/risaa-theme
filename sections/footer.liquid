<script>
  (function () {
    function setupFooterReveal() {
      const footer = document.querySelector('.risaa-footer');
      if (!footer) return;

      // Find the outermost wrapper for the footer
      const footerWrapper =
        footer.closest('.shopify-section-group-footer-group') || footer.closest('.shopify-section') || footer;

      const main = document.getElementById('MainContent');
      if (!main) return;

      // Make main sit above the footer
      main.style.position = 'relative';
      main.style.zIndex = '2';

      // Apply rounded bottom edge so it looks like it's peeling off
      main.style.borderBottomLeftRadius = '36px';
      main.style.borderBottomRightRadius = '36px';
      main.style.boxShadow = '0 15px 30px rgba(0,0,0,0.15)'; // Subtle drop shadow over the footer

      // Ensure main has a solid background to hide the footer during scroll
      const bodyBg = window.getComputedStyle(document.body).backgroundColor;
      main.style.backgroundColor = bodyBg === 'rgba(0, 0, 0, 0)' || bodyBg === 'transparent' ? '#ffffff' : bodyBg;

      function updateReveal() {
        const height = footerWrapper.offsetHeight;

        // Only apply reveal effect if the footer fits within the viewport with tolerance.
        if (height < window.innerHeight + 100) {
          footerWrapper.style.position = 'fixed';
          footerWrapper.style.bottom = '0';
          footerWrapper.style.left = '0';
          footerWrapper.style.width = '100%';
          footerWrapper.style.zIndex = '0';
          footerWrapper.style.transition = 'opacity 0.6s ease';

          // Make the scroll end 7% earlier so the peeling edge overlaps the footer
          main.style.marginBottom = height * 0.93 + 'px';
        } else {
          // Revert to normal flow
          footerWrapper.style.position = 'static';
          main.style.marginBottom = '0px';
        }
      }

      // Fade footer in as we scroll near the actual bottom reveal trigger point
      function updateOpacity() {
        const scrolled = window.scrollY;
        const height = footerWrapper.offsetHeight;
        const documentHeight = document.documentElement.scrollHeight;
        const windowHeight = window.innerHeight;
        
        // Calculate the scroll position where the footer reveal starts
        const revealStart = documentHeight - height - windowHeight;
        const threshold = Math.max(0, revealStart - 200);
        
        if (scrolled >= threshold) {
          footerWrapper.style.opacity = '1';
          footerWrapper.style.pointerEvents = 'auto';
        } else {
          footerWrapper.style.opacity = '0';
          footerWrapper.style.pointerEvents = 'none';
        }
      }

      // Start invisible
      footerWrapper.style.opacity = '0';
      footerWrapper.style.pointerEvents = 'none';

      window.addEventListener('scroll', updateOpacity, { passive: true });
      updateOpacity();

      const resizeObserver = new ResizeObserver(() => {
        updateReveal();
      });
      resizeObserver.observe(footerWrapper);
      window.addEventListener('resize', updateReveal);

      updateReveal();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupFooterReveal);
    } else {
      setupFooterReveal();
    }
  })();
</script>

