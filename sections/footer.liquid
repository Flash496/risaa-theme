                    </svg>
                  </a>
                {%- endif -%}
                {%- if settings.social_facebook_link != blank -%}
                  <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
                    <svg viewBox="0 0 24 24">
                      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                  </a>
                {%- endif -%}
                {%- if settings.social_youtube_link != blank -%}
                  <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" aria-label="YouTube">
                    <svg viewBox="0 0 24 24">
                      <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
                    </svg>
                  </a>
                {%- endif -%}
                {%- if settings.social_pinterest_link != blank -%}
                  <a href="{{ settings.social_pinterest_link }}" target="_blank" rel="noopener" aria-label="Pinterest">
                    <svg viewBox="0 0 24 24">
                      <path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
                    </svg>
                  </a>
                {%- endif -%}
                {%- if settings.social_tiktok_link != blank -%}
                  <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" aria-label="TikTok">
                    <svg viewBox="0 0 24 24">
                      <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                    </svg>
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      <!-- Map column (rightmost) -->
      <div class="risaa-footer__map-wrapper">
        <div class="risaa-footer__map-container">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3422.9876543210987!2d75.8321064!3d30.8904329!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x391a838f0056f067%3A0xb9f05c5a3ffd943b!2sRisaa%20-%20The%20Design%20Studio!5e0!3m2!1sen!2sin!4v1716480000000!5m2!1sen!2sin"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Risaa - The Design Studio, 117-B Jyoti Colony, Model Town Extension, Ludhiana"
            allowfullscreen
          ></iframe>
        </div>
      </div>
    </div>

    {%- if section.settings.newsletter_enable -%}
      <div class="risaa-footer__newsletter-strip">
        {%- if section.settings.newsletter_heading != blank -%}
          <span class="risaa-footer__newsletter-label">{{ section.settings.newsletter_heading }}</span>
        {%- endif -%}
        {%- form 'customer', id: 'ContactFooter', class: 'risaa-footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            type="email"
            name="contact[email]"
            value="{{ form.email }}"
            placeholder="{{ 'newsletter.label' | t }}"
            aria-label="{{ 'newsletter.label' | t }}"
            autocomplete="email"
            required
          >
          <button type="submit" name="commit">Subscribe</button>
          {%- if form.posted_successfully? -%}
            <p style="color:rgba(255,255,255,0.6);font-size:1.2rem;margin-left:12px;">{{ 'newsletter.success' | t }}</p>
          {%- endif -%}
        {%- endform -%}
      </div>
    {%- endif -%}

    <div class="risaa-footer__bottom">
      <p class="risaa-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }}, <a href="{{ routes.root_url }}">{{ shop.name }}</a> &bull;
        {{ powered_by_link }}
      </p>
      {%- if section.settings.payment_enable -%}
        <div class="risaa-footer__payment">
          <ul class="list-payment" role="list">
            {%- for type in shop.enabled_payment_types -%}
              <li class="list-payment__item">
                {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

<script>
  (function() {
    function setupFooterReveal() {
      const footer = document.querySelector('.risaa-footer');
      if (!footer) return;
      
      // Find the outermost wrapper for the footer
      const footerWrapper = footer.closest('.shopify-section-group-footer-group') || 
                            footer.closest('.shopify-section') || 
                            footer;
                            
      const main = document.getElementById('MainContent');
      if (!main) return;
      
      // Make main sit above the footer
      main.style.position = 'relative';
      main.style.zIndex = '2';
      
      // Ensure main has a solid background to hide the footer during scroll
      const bodyBg = window.getComputedStyle(document.body).backgroundColor;
      main.style.backgroundColor = (bodyBg === 'rgba(0, 0, 0, 0)' || bodyBg === 'transparent') ? '#ffffff' : bodyBg;
      
      function updateReveal() {
        // Temporarily unset fixed to measure natural height if needed, 
        // but offsetHeight usually works fine on fixed elements.
        const height = footerWrapper.offsetHeight;
        
        // Only apply reveal effect if the footer fits within the viewport.
        // If it's taller than the screen (e.g. on mobile), fixing it to bottom 
        // would permanently hide the top part of the footer.
        if (height < window.innerHeight) {
          footerWrapper.style.position = 'fixed';
          footerWrapper.style.bottom = '0';
          footerWrapper.style.left = '0';
          footerWrapper.style.width = '100%';
          footerWrapper.style.zIndex = '0';
          main.style.marginBottom = height + 'px';
        } else {
          // Revert to normal flow
          footerWrapper.style.position = 'static';
          main.style.marginBottom = '0px';
        }
      }
      
      const resizeObserver = new ResizeObserver(() => {
        updateReveal();
      });
      resizeObserver.observe(footerWrapper);
      window.addEventListener('resize', updateReveal);
      
      updateReveal();
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setupFooterReveal);
    } else {
      setupFooterReveal();
    }
  })();
</script>

