{%- style -%}
  .risaa-watch-and-shop {
    position: relative;
    width: calc(100% - 115px);

    margin: 0 auto;
    padding: 0 10px;
    background: #fff;
    border-radius: 30px;
    overflow: hidden;
  }

  .risaa-reels-decor {
    position: absolute;
    width: 250px;
    height: 250px;
    opacity: 0.12;
    pointer-events: none;
    z-index: 1;
    background-size: contain;
  }

  .risaa-reels-layout {
    display: flex;
    max-width: 820px;
    margin: 24px auto;
    align-items: center;
    justify-content: center;
    gap: 40px;
    position: relative;
    z-index: 2;
  }

  /* Reel Stack Side */
  .risaa-reels-stack-side {
    position: relative;
    flex: 0 0 240px;
  }

  .risaa-reels-stack {
    position: relative;
    width: 240px;
    height: 426px;
    perspective: 1000px;
  }

  .risaa-video-card {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 30px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.25);
    transition: all 0.7s cubic-bezier(0.19, 1, 0.22, 1);
    cursor: pointer;
  }

  .risaa-video-card.card-1 {
    transform: rotate(0) translateZ(0);
    z-index: 10;
    opacity: 1;
  }
  .risaa-video-card.card-2 {
    transform: rotate(4deg) translateZ(-30px) translateX(20px);
    z-index: 9;
    opacity: 0.8;
  }
  .risaa-video-card.card-3 {
    transform: rotate(-3deg) translateZ(-60px) translateX(-20px);
    z-index: 8;
    opacity: 0.6;
  }
  .risaa-video-card.card-hidden {
    transform: translateZ(-200px) translateY(100px);
    z-index: 1;
    opacity: 0;
    pointer-events: none;
  }

  .risaa-video-card.shuffling {
    animation: shuffle-animation 0.8s forwards cubic-bezier(0.19, 1, 0.22, 1);
  }

  @keyframes shuffle-animation {
    0% {
      transform: scale(1) translateX(0);
      z-index: 100;
    }
    40% {
      transform: scale(0.9) translateX(-200px) rotate(-15deg);
      opacity: 0.8;
    }
    100% {
      transform: scale(0.8) translateX(0) translateZ(-100px);
      z-index: 1;
      opacity: 0;
    }
  }

  .risaa-video-card video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Product Info Side */
  .risaa-reels-info-side {
    flex: 1;
    max-width: 300px;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Bloom Animation States */
  .risaa-reels-stack-side,
  .risaa-reels-info-side {
    opacity: 0;
    transform: scale(0.92);
    filter: blur(12px);
    transition: opacity 1.2s cubic-bezier(0.25, 1, 0.5, 1), transform 1.2s cubic-bezier(0.25, 1, 0.5, 1),
      filter 1.2s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .risaa-reels-layout.is-bloomed .risaa-reels-stack-side,
  .risaa-reels-layout.is-bloomed .risaa-reels-info-side {
    opacity: 1;
    transform: scale(1);
    filter: blur(0);
  }

  @keyframes metal-glimmer {
    0% {
      left: -150%;
    }
    50% {
      left: 150%;
    }
    100% {
      left: 150%;
    }
  }

  .risaa-video-card .active-product-card {
    display: none !important;
  }
  .risaa-video-card.card-1 .active-product-card {
    display: flex !important;
  }

  .active-product-card {
    position: relative;
    overflow: hidden;
    background: #fff;
    padding: 30px;
    border-radius: 0;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12), 0 12px 24px rgba(0, 0, 0, 0.08), 0 4px 8px rgba(0, 0, 0, 0.04);
    border: 1px solid #f5f5f5;
    transition: opacity 0.25s ease, transform 0.25s ease;
    text-decoration: none !important;
  }

  .active-product-image-wrap {
    margin-bottom: 20px;
    border-radius: 0;
    overflow: hidden;
    aspect-ratio: 4/5;
  }

  .active-product-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .active-product-details-wrap {
    display: flex;
    flex-direction: column;
  }

  .active-product-card::after {
    content: '';
    position: absolute;
    top: 0;
    left: -150%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.4),
      rgba(255, 255, 255, 0.6),
      rgba(255, 255, 255, 0.4),
      transparent
    );
    transform: skewX(-25deg);
    pointer-events: none;
  }

  .risaa-reels-layout.is-bloomed .active-product-card::after {
    animation: metal-glimmer 3.5s cubic-bezier(0.19, 1, 0.22, 1) infinite;
    animation-delay: 1.2s;
  }

  .active-product-card.look-exit {
    opacity: 0;
    transform: translateY(16px) scale(0.97);
  }

  .active-product-card.look-enter {
    animation: look-card-in 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes look-card-in {
    0% {
      opacity: 0;
      transform: translateY(24px) scale(0.96);
    }
    60% {
      opacity: 1;
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .active-product-tag {
    font-family: 'Montserrat', sans-serif;
    text-transform: uppercase;
    font-size: 9pt;
    letter-spacing: 2px;
    color: #f8b799;
    font-weight: 700;
    margin-bottom: 12px;
    display: block;
  }

  .active-product-title {
    font-family: 'Cinzel', serif;
    font-size: 1.8rem;
    color: #1a1a1a;
    margin: 0 0 10px 0;
    line-height: 1.2;
  }

  .active-product-price {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    color: #666;
    margin-bottom: 24px;
  }

  .active-product-link {
    display: inline-block;
    padding: 15px 40px;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-size: 9pt;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .active-product-link:hover {
    background: #f8b799;
    transform: translateY(-3px);
  }

  /* Arrows */
  .risaa-reels-nav {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 40px;
    pointer-events: none; /* Allow clicking through the container */
    z-index: 20;
  }

  .nav-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.165, 0.84, 0.44, 1), background-color 0.3s ease,
      border-color 0.3s ease, box-shadow 0.3s ease;
    color: #6e1423;
    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15), 0 2px 4px rgba(0, 0, 0, 0.08);
    transform: scale(0.9);
  }

  .nav-arrow svg {
    width: 18px;
    height: 18px;
    stroke: #6e1423;
    stroke-width: 2.5;
    fill: none;
    display: block;
  }

  .risaa-watch-and-shop:hover .nav-arrow {
    opacity: 0.7;
    pointer-events: auto;
    transform: scale(1);
  }

  .nav-arrow:hover {
    opacity: 1;
    background: rgba(255, 255, 255, 0.35);
    border-color: rgba(255, 255, 255, 0.5);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25), 0 4px 10px rgba(0, 0, 0, 0.12);
    transform: scale(1.05);
  }

  @media screen and (max-width: 990px) {
    .risaa-watch-and-shop {
      width: calc(100% - 30px) !important;
    }
    .risaa-reels-nav {
      position: relative;
      top: auto;
      transform: none;
      padding: 0;
      margin-top: 30px;
      justify-content: center;
    }
    .nav-arrow {
      opacity: 0.7;
      pointer-events: auto;
      transform: scale(1);
    }
  }

  @media screen and (min-width: 750px) {
    .risaa-reels-layout {
      max-width: 1350px !important;
      width: 100% !important;
      margin: 40px auto !important;
      position: relative !important;
      overflow: visible !important;
      height: 600px !important;
      display: flex !important;
      align-items: center !important;
      justify-content: flex-start !important;
    }

    .risaa-reels-stack-side {
      flex: 1 !important;
      width: 100% !important;
      height: 100% !important;
      overflow: visible !important;
      position: relative !important;
      display: flex !important;
      align-items: center !important;
    }

    .risaa-reels-stack {
      display: flex !important;
      gap: 20px !important;
      width: max-content !important;
      height: 554px !important;
      perspective: none !important;
      position: relative !important;
      transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1) !important;
      will-change: transform;
    }

    .risaa-video-card,
    .risaa-video-card.card-1,
    .risaa-video-card.card-2,
    .risaa-video-card.card-3,
    .risaa-video-card.card-hidden {
      position: relative !important;
      flex: 0 0 312px !important;
      width: 312px !important;
      height: 554px !important;
      top: auto !important;
      left: auto !important;
      transform: none !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      z-index: 1 !important;
      transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.6s ease !important;
      display: flex !important;
    }

    .risaa-video-card:hover {
      box-shadow: 0 20px 45px rgba(0, 0, 0, 0.28) !important;
    }

    /* Embedded Product Card position & styles for desktop */
    .risaa-video-card .active-product-card {
      position: absolute !important;
      bottom: -15px !important;
      right: -15px !important;
      width: 220px !important;
      z-index: 20 !important;
      transform: scale(1.3) !important;
      transform-origin: bottom right !important;
    }

    /* Arrows positioning relative to the layout container to overlap the edge reels */
    .risaa-reels-nav {
      position: absolute !important;
      top: 50% !important;
      left: -22px !important;
      right: -22px !important;
      width: calc(100% + 44px) !important;
      transform: translateY(-50%) !important;
      display: flex !important;
      justify-content: space-between !important;
      pointer-events: none !important;
      z-index: 30 !important;
      padding: 0 !important;
    }
  }

  @media screen and (max-width: 749px) {
    .risaa-reels-nav {
      display: none !important;
    }

    .risaa-watch-and-shop {
      border-radius: 16px !important;
    }

    /* Stack side fills the whole row; info-side overlays it */
    .risaa-reels-layout {
      flex-direction: row !important;
      gap: 0 !important;
      margin: 20px auto !important;
      position: relative !important;
      align-items: flex-start !important;
    }

    .risaa-reels-stack-side {
      flex: none !important;
      min-width: 0 !important;
      width: 85% !important;
      height: auto !important;
    }

    .risaa-reels-stack {
      width: 100% !important;
      height: auto !important;
      aspect-ratio: 9/16 !important;
    }

    .risaa-video-card {
      border-radius: 16px !important;
    }
    .risaa-video-card.card-2 {
      transform: rotate(3deg) translateZ(-20px) translateX(10px) !important;
    }
    .risaa-video-card.card-3 {
      transform: rotate(-2deg) translateZ(-40px) translateX(-10px) !important;
    }
    .risaa-video-card.shuffling {
      animation: shuffle-animation-mobile 0.8s forwards cubic-bezier(0.19, 1, 0.22, 1) !important;
    }
    .risaa-video-card.shuffling-prev {
      animation: shuffle-animation-prev-mobile 0.8s forwards cubic-bezier(0.19, 1, 0.22, 1) !important;
    }

    /* Shop the Look card: absolute overlay at bottom-right of the reel */
    .risaa-reels-info-side {
      position: absolute !important;
      bottom: 16px !important;
      right: 12px !important;
      width: 50% !important;
      max-width: 192px !important;
      flex: none !important;
      gap: 0 !important;
      z-index: 20 !important;
    }

    .active-product-card {
      padding: 10px !important;
      border-radius: 0 !important;
      background: rgba(255, 255, 255, 0.88) !important;
      backdrop-filter: blur(10px) !important;
      -webkit-backdrop-filter: blur(10px) !important;
      border: 1px solid rgba(255,255,255,0.6) !important;
      box-shadow: 0 8px 32px rgba(0,0,0,0.22) !important;
      display: flex !important;
      flex-direction: column !important;
      box-sizing: border-box !important;
      /* 3:4 aspect ratio */
      aspect-ratio: 3/4 !important;
      overflow: hidden !important;
    }

    .active-product-image-wrap {
      flex: 1 !important;
      margin-bottom: 6px !important;
      border-radius: 0 !important;
      overflow: hidden !important;
      min-height: 0 !important;
      aspect-ratio: unset !important;
    }

    .active-product-image-wrap img {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
    }

    .active-product-details-wrap {
      display: flex !important;
      flex-direction: column !important;
      flex-shrink: 0 !important;
    }

    .active-product-tag {
      font-size: 6pt !important;
      letter-spacing: 1px !important;
      margin-bottom: 2px !important;
    }
    .active-product-title {
      font-size: 0.72rem !important;
      margin: 0 0 3px 0 !important;
      line-height: 1.2 !important;
      display: -webkit-box !important;
      -webkit-line-clamp: 2 !important;
      -webkit-box-orient: vertical !important;
      overflow: hidden !important;
    }
    .active-product-price {
      font-size: 0.72rem !important;
      margin-bottom: 5px !important;
    }
    .active-product-link {
      padding: 7px 6px !important;
      font-size: 6.5pt !important;
      width: 100% !important;
      text-align: center !important;
      box-sizing: border-box !important;
      border-radius: 30px !important;
    }
  }

  @keyframes shuffle-animation-mobile {
    0% {
      transform: scale(1) translateX(0);
      z-index: 100;
    }
    40% {
      transform: scale(0.9) translateX(-120%) rotate(-10deg);
      opacity: 0.8;
    }
    100% {
      transform: scale(0.8) translateX(0) translateZ(-60px);
      z-index: 1;
      opacity: 0;
    }
  }

  @keyframes shuffle-animation-prev-mobile {
    0% {
      transform: scale(0.8) translateX(0) translateZ(-60px);
      z-index: 1;
      opacity: 0;
    }
    40% {
      transform: scale(0.9) translateX(-120%) rotate(-10deg);
      opacity: 0.8;
      z-index: 100;
    }
    100% {
      transform: scale(1) translateX(0) rotate(0) translateZ(0);
      z-index: 100;
      opacity: 1;
    }
  }

  /* Modal Styles */
  .risaa-video-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.95);
    z-index: 3000;
    backdrop-filter: blur(15px);
    align-items: center;
    justify-content: center;
  }

  .risaa-video-modal.active {
    display: flex;
  }

  .risaa-modal-content {
    display: flex;
    background: white;
    width: 95%;
    max-width: 1000px;
    height: 85vh;
    border-radius: 30px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.5);
    animation: modal-pop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  @keyframes modal-pop {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .risaa-modal-video {
    flex: 1.4;
    background: #000;
  }

  .risaa-modal-video video {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .risaa-modal-sidebar {
    flex: 1;
    padding: 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: #fff;
  }

  .risaa-close-modal {
    position: absolute;
    top: 30px;
    right: 30px;
    font-size: 40px;
    color: white;
    cursor: pointer;
    z-index: 3001;
    line-height: 1;
    transition: transform 0.3s ease;
  }

  .risaa-close-modal:hover {
    transform: rotate(90deg);
  }

  @media screen and (max-width: 749px) {
    .risaa-modal-content {
      flex-direction: column;
      height: 95vh;
    }
    .risaa-modal-video {
      flex: 1;
    }
    .risaa-modal-sidebar {
      padding: 30px;
    }
  }
{%- endstyle -%}

<div class="risaa-watch-and-shop section-{{ section.id }}-padding" data-anim="roll-up">
  <div class="section-header" style="text-align: center; margin-bottom: 10px; padding-top: 30px; padding-bottom: 15px;">
    <h2 class="h1">{{ section.settings.title }}</h2>
    <p>{{ section.settings.subtitle }}</p>
  </div>

  <div class="risaa-reels-layout">
    <!-- REEL STACK -->
    <div class="risaa-reels-stack-side">
      <div class="risaa-reels-stack" id="reelsStack-{{ section.id }}">
        {% for block in section.blocks %}
          <div
            class="risaa-video-card card-{{ forloop.index }} {% if forloop.index > 3 %}card-hidden{% endif %}"
            onclick="handleCardClick(this, '{{ block.id }}')"
            data-block-id="{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.video_url != blank %}
              <video muted loop playsinline class="reel-video">
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
            {% else %}
              <div style="width:100%; height:100%; background:linear-gradient(45deg, #f8b799, #ffd1bc); display:flex; align-items:center; justify-content:center; color:white;">
                <img
                  src="https://picsum.photos/400/700?random={{ forloop.index }}"
                  class="placeholder-svg"
                  alt="Product Placeholder"
                  style="width: 100%; height: 100%; object-fit: cover;"
                >
              </div>
            {% endif %}

            <!-- Embedded Product Info Overlay -->
            {%- assign product = block.settings.product -%}
            {%- if product != blank -%}
              <a href="{{ product.url }}" class="active-product-card" onclick="event.stopPropagation()">
                <div class="active-product-image-wrap">
                  <img src="{{ product.featured_image | image_url: width: 300 }}" alt="{{ product.title | escape }}">
                </div>
                <div class="active-product-details-wrap">
                  <span class="active-product-tag">The Look</span>
                  <h3 class="active-product-title">{{ product.title }}</h3>
                  <p class="active-product-price">{{ product.price | money }}</p>
                  <span class="active-product-link">Shop the Design</span>
                </div>
              </a>
            {%- else -%}
              <!-- Mockup Fallback when no product is selected to ensure it displays for testing -->
              <a href="#" class="active-product-card" onclick="event.stopPropagation()">
                <div class="active-product-image-wrap">
                  <img src="https://picsum.photos/300/400?random={{ forloop.index | plus: 100 }}" alt="Featured Design">
                </div>
                <div class="active-product-details-wrap">
                  <span class="active-product-tag">The Look</span>
                  <h3 class="active-product-title">Featured Design - Red Lehenga Set</h3>
                  <p class="active-product-price">Rs. 45,000</p>
                  <span class="active-product-link">Shop the Design</span>
                </div>
              </a>
            {%- endif -%}
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- Navigation Arrows positioned relative to layout container -->
    <div class="risaa-reels-nav">
      <div class="nav-arrow" onclick="shuffleStack('{{ section.id }}', 'prev')">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="20" y1="12" x2="4" y2="12"/>
          <polyline points="10 6 4 12 10 18"/>
        </svg>
      </div>
      <div class="nav-arrow" onclick="shuffleStack('{{ section.id }}', 'next')">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="4" y1="12" x2="20" y2="12"/>
          <polyline points="14 6 20 12 14 18"/>
        </svg>
      </div>
    </div>
  </div>
</div>

<script>
  function handleCardClick(card, blockId) {
    if (window.innerWidth < 750) {
      if (card.classList.contains('card-1')) {
        openRisaaModal(blockId);
      } else {
        shuffleStack('{{ section.id }}', 'next');
      }
    } else {
      openRisaaModal(blockId);
    }
  }

  function setActiveCarouselPage(sectionId, startIndex, animate = true) {
    const stack = document.getElementById(`reelsStack-${sectionId}`);
    if (!stack) return;
    const cards = Array.from(stack.querySelectorAll('.risaa-video-card'));
    if (cards.length === 0) return;

    const M = cards.length;
    if (startIndex < 0) startIndex = 0;
    if (startIndex > M - 4) startIndex = Math.max(0, M - 4);

    stack.dataset.startIndex = startIndex;

    // Translate stack
    const cardWidth = 240;
    const gap = 20;
    const translation = -startIndex * (cardWidth + gap);

    if (!animate) {
      stack.style.setProperty('transition', 'none', 'important');
    } else {
      stack.style.removeProperty('transition');
    }
    stack.style.transform = `translateX(${translation}px)`;

    // Play/Pause videos based on visibility
    cards.forEach((card, i) => {
      const video = card.querySelector('video');
      if (video) {
        if (i >= startIndex && i < startIndex + 4) {
          video.play().catch(e => {});
        } else {
          video.pause();
        }
      }
    });
  }

  function shuffleStack(sectionId, direction) {
    if (window.innerWidth < 750) {
      const stack = document.getElementById(`reelsStack-${sectionId}`);
      if (!stack) return;
      if (stack.dataset.isAnimatingMobile === 'true') return;

      if (direction === 'prev') {
        const lastCard = stack.lastElementChild;
        if (!lastCard) return;

        stack.dataset.isAnimatingMobile = 'true';
        stack.insertBefore(lastCard, stack.firstElementChild);

        const newCards = Array.from(stack.querySelectorAll('.risaa-video-card'));
        newCards.forEach((card, i) => {
          card.className = 'risaa-video-card';
          const pos = i + 1;
          if (pos === 1) {
            card.classList.add('shuffling-prev');
          } else if (pos <= 3) {
            card.classList.add(`card-${pos}`);
          } else {
            card.classList.add('card-hidden');
          }

          const video = card.querySelector('video');
          if (video) {
            if (pos === 1) video.play().catch(e => {});
            else video.pause();
          }
        });

        setTimeout(() => {
          const topCard = stack.querySelector('.shuffling-prev');
          if (topCard) {
            topCard.classList.remove('shuffling-prev');
            topCard.classList.add('card-1');
          }
          stack.dataset.isAnimatingMobile = 'false';
        }, 800);
      } else {
        const topCard = stack.querySelector('.card-1');
        if (!topCard) return;

        stack.dataset.isAnimatingMobile = 'true';
        topCard.classList.add('shuffling');

        setTimeout(() => {
          topCard.classList.remove('shuffling');
          stack.appendChild(topCard);

          const newCards = Array.from(stack.querySelectorAll('.risaa-video-card'));
          newCards.forEach((card, i) => {
            card.className = 'risaa-video-card';
            const pos = i + 1;
            if (pos <= 3) card.classList.add(`card-${pos}`);
            else card.classList.add('card-hidden');

            const video = card.querySelector('video');
            if (video) {
              if (pos === 1) video.play().catch(e => {});
              else video.pause();
            }
          });

          stack.dataset.isAnimatingMobile = 'false';
        }, 600);
      }
    } else {
      const stack = document.getElementById(`reelsStack-${sectionId}`);
      if (!stack) return;
      const cards = Array.from(stack.querySelectorAll('.risaa-video-card'));
      const M = cards.length;
      if (M <= 4) return; // No need to shuffle if all fit on screen

      let startIndex = parseInt(stack.dataset.startIndex);
      if (isNaN(startIndex)) startIndex = 0;

      if (direction === 'next') {
        if (startIndex >= M - 4) {
          startIndex = 0;
        } else {
          startIndex = Math.min(startIndex + 4, M - 4);
        }
      } else {
        if (startIndex <= 0) {
          startIndex = Math.max(0, M - 4);
        } else {
          startIndex = Math.max(0, startIndex - 4);
        }
      }

      setActiveCarouselPage(sectionId, startIndex, true);
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const stack = document.getElementById('reelsStack-{{ section.id }}');
    if (stack) {
      if (window.innerWidth >= 750) {
        stack.dataset.startIndex = 0;
        setActiveCarouselPage('{{ section.id }}', 0, false);
      } else {
        const topCard = stack.querySelector('.card-1');
        if (topCard) {
          const video = topCard.querySelector('video');
          if (video) video.play().catch(e => {});
        }
      }

      // Touch swipe gestures for mobile
      let reelTouchStartX = 0;
      let reelTouchStartY = 0;
      let reelTouchDeltaX = 0;
      let reelIsSwiping = false;

      const layout = stack.closest('.risaa-reels-layout');
      if (layout) {
        layout.addEventListener('touchstart', (e) => {
          if (window.innerWidth >= 750) return;
          reelTouchStartX = e.touches[0].clientX;
          reelTouchStartY = e.touches[0].clientY;
          reelTouchDeltaX = 0;
          reelIsSwiping = false;
        }, { passive: true });

        layout.addEventListener('touchmove', (e) => {
          if (window.innerWidth >= 750) return;
          const clientX = e.touches[0].clientX;
          const clientY = e.touches[0].clientY;
          reelTouchDeltaX = clientX - reelTouchStartX;
          const deltaY = clientY - reelTouchStartY;

          if (!reelIsSwiping) {
            if (Math.abs(reelTouchDeltaX) > Math.abs(deltaY) && Math.abs(reelTouchDeltaX) > 10) {
              reelIsSwiping = true;
            }
          }

          if (reelIsSwiping) {
            if (e.cancelable) e.preventDefault();
          }
        }, { passive: false });

        layout.addEventListener('touchend', () => {
          if (window.innerWidth >= 750) return;
          if (!reelIsSwiping) return;
          reelIsSwiping = false;

          const threshold = 50;
          if (reelTouchDeltaX < -threshold) {
            shuffleStack('{{ section.id }}', 'next');
          } else if (reelTouchDeltaX > threshold) {
            shuffleStack('{{ section.id }}', 'prev');
          }
        });
      }
    }

    // Auto-advance disabled
    const stackSide = document.querySelector('.risaa-reels-stack-side');
    let autoTimer = null;
    function startAuto() {
      // Disabled autoscroll
    }
    function stopAuto() {
      // Disabled autoscroll
    }

    // Pause on hover, resume on leave
    if (stackSide) {
      stackSide.addEventListener('mouseenter', stopAuto);
      stackSide.addEventListener('mouseleave', startAuto);
    }

    // IntersectionObserver to pause when offscreen
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            startAuto();
          } else {
            stopAuto();
          }
        });
      }, { threshold: 0.05 });
      const sectionEl = document.querySelector('.section-{{ section.id }}-padding');
      if (sectionEl) observer.observe(sectionEl);
    } else {
      startAuto();
    }

    // Resize listener for desktop carousel translation alignment / mobile recovery
    let lastWidth = window.innerWidth;
    window.addEventListener('resize', () => {
      if (window.innerWidth === lastWidth) return;
      const isMobileNow = window.innerWidth < 750;
      const wasMobileBefore = lastWidth < 750;
      lastWidth = window.innerWidth;

      const rStack = document.getElementById('reelsStack-{{ section.id }}');
      if (!rStack) return;

      if (!isMobileNow && wasMobileBefore) {
        // Switched from mobile to desktop
        rStack.style.transform = '';
        const cards = Array.from(rStack.querySelectorAll('.risaa-video-card'));
        cards.forEach(card => {
          card.className = 'risaa-video-card';
        });
        rStack.dataset.startIndex = 0;
        setActiveCarouselPage('{{ section.id }}', 0, false);
      } else if (isMobileNow && !wasMobileBefore) {
        // Switched from desktop to mobile
        rStack.style.transform = '';
        const cards = Array.from(rStack.querySelectorAll('.risaa-video-card'));
        cards.forEach((card, i) => {
          card.className = 'risaa-video-card';
          const pos = i + 1;
          if (pos <= 3) card.classList.add(`card-${pos}`);
          else card.classList.add('card-hidden');

          const video = card.querySelector('video');
          if (video) {
            if (pos === 1) video.play().catch(e => {});
            else video.pause();
          }
        });
      }
    });
  });
</script>

<!-- Modal Structure -->
<div id="risaaVideoModal" class="risaa-video-modal">
  <span class="risaa-close-modal" onclick="closeRisaaModal()">&times;</span>
  <div class="risaa-modal-content">
    <div class="risaa-modal-video">
      <video id="risaaMainVideo" controls autoplay loop>
        <source src="" type="video/mp4">
      </video>
    </div>
    <div class="risaa-modal-sidebar" id="risaaModalSidebar">
      <!-- Product info injected here -->
    </div>
  </div>
</div>

<script>
  const videoData = {
    {% for block in section.blocks %}
      "{{ block.id }}": {
        "video": "{{ block.settings.video_url }}",
        "title": "{{ block.settings.product.title | escape }}",
        "price": "{{ block.settings.product.price | money | escape }}",
        "url": "{{ block.settings.product.url }}",
        "image": "{% if block.settings.product.featured_image %}{{ block.settings.product.featured_image | image_url: width: 300 }}{% else %}https://picsum.photos/300/400?random={{ forloop.index | plus: 100 }}{% endif %}"
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  };

  function openRisaaModal(blockId) {
    const data = videoData[blockId];
    if(!data) return;

    const modal = document.getElementById('risaaVideoModal');
    const video = document.getElementById('risaaMainVideo');
    const sidebar = document.getElementById('risaaModalSidebar');

    video.src = data.video;
    sidebar.innerHTML = `
      <h3 style="color:var(--brand-main); margin-top:0;">Shop the Look</h3>
      <div style="margin-bottom:20px;">
        <img src="${data.image}" style="width:100%; border-radius:5px; margin-bottom:10px;">
        <h4 style="margin:5px 0;">${data.title}</h4>
        <p style="font-weight:bold; color:var(--brand-main);">${data.price}</p>
        <a href="${data.url}" class="btn-premium" style="display:block; text-align:center;">View Details</a>
      </div>
    `;

    modal.classList.add('active');
    video.play();
  }

  function closeRisaaModal() {
    const modal = document.getElementById('risaaVideoModal');
    const video = document.getElementById('risaaMainVideo');
    modal.classList.remove('active');
    video.pause();
    video.src = "";
  }
</script>

