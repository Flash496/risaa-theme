{%- style -%}
  .risaa-watch-and-shop {
    position: relative;
    width: calc(100% - 110px);
    margin: 0 auto;
    padding: 0 10px;
    background: #fff;
    border-radius: 30px;
    overflow: hidden;
  }

  .risaa-reels-layout {
    display: flex;
    max-width: 1350px;
    width: 100%;
    margin: 40px auto;
    align-items: center;
    justify-content: flex-start;
    position: relative;
    overflow: visible;
  }

  .risaa-reels-stack-side {
    position: relative;
    flex: 1;
    width: 100%;
    overflow-x: auto;
    scrollbar-width: none; /* Hide scrollbar for Firefox */
    -ms-overflow-style: none; /* Hide scrollbar for IE/Edge */
  }

  .risaa-reels-stack-side::-webkit-scrollbar {
    display: none; /* Hide scrollbar for Chrome/Safari */
  }

  .risaa-reels-stack {
    display: flex;
    gap: 20px;
    width: max-content;
    height: 554px;
    position: relative;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform;
  }

  .risaa-video-card {
    position: relative;
    flex: 0 0 312px;
    width: 312px;
    height: 554px;
    border-radius: 20px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .risaa-video-card:hover {
    box-shadow: 0 20px 45px rgba(0, 0, 0, 0.28);
  }

  /* HTML5 Video elements */
  .risaa-video-card video.reel-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Audio Toggle Button styles */
  .risaa-video-card .audio-toggle-btn {
    position: absolute;
    top: 15px;
    right: 15px;
    width: 36px;
    height: 36px;
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 25;
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .risaa-video-card .audio-toggle-btn:hover {
    transform: scale(1.05);
    background: rgba(0, 0, 0, 0.6);
  }

  .risaa-video-card .audio-toggle-btn svg {
    width: 16px;
    height: 16px;
    fill: #fff;
    display: block;
  }

  .risaa-video-card .audio-toggle-btn .unmute-icon {
    display: none;
  }

  .risaa-video-card .audio-toggle-btn.unmuted .mute-icon {
    display: none;
  }

  .risaa-video-card .audio-toggle-btn.unmuted .unmute-icon {
    display: block;
  }

  /* Instagram Iframe Cropping Wrapper */
  .instagram-embed-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #000;
  }

  .instagram-iframe-container iframe {
    position: absolute;
    top: -54px;
    left: 0;
    width: 100%;
    height: calc(100% + 110px);
    border: none;
    pointer-events: auto;
  }

  /* Embedded Product Card position & styles */
  .risaa-video-card .active-product-card {
    display: flex !important;
    flex-direction: column !important;
    position: absolute !important;
    bottom: 15px !important;
    right: 15px !important;
    width: 170px !important;
    z-index: 20 !important;
    padding: 10px !important;
    border-radius: 12px !important;
    background: rgba(255, 255, 255, 0.9) !important;
    backdrop-filter: blur(8px) !important;
    -webkit-backdrop-filter: blur(8px) !important;
    box-shadow: 0 10px 25px rgba(0,0,0,0.15) !important;
    border: 1px solid rgba(255, 255, 255, 0.5) !important;
    box-sizing: border-box !important;
    text-decoration: none !important;
  }

  .risaa-video-card .active-product-image-wrap {
    margin-bottom: 8px !important;
    border-radius: 8px !important;
    aspect-ratio: 1/1 !important;
    overflow: hidden !important;
    width: 100% !important;
  }

  .risaa-video-card .active-product-image-wrap img {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }

  .risaa-video-card .active-product-details-wrap {
    display: flex !important;
    flex-direction: column !important;
  }

  .risaa-video-card .active-product-tag {
    font-size: 8px !important;
    margin-bottom: 2px !important;
    letter-spacing: 1px !important;
    text-transform: uppercase !important;
    font-weight: 700 !important;
    color: #f8b799 !important;
  }

  .risaa-video-card .active-product-title {
    font-size: 11px !important;
    line-height: 1.3 !important;
    margin: 0 0 8px 0 !important;
    font-weight: 600 !important;
    color: #1a1a1a !important;
    display: -webkit-box !important;
    -webkit-line-clamp: 2 !important;
    -webkit-box-orient: vertical !important;
    overflow: hidden !important;
  }

  .risaa-video-card .active-product-link {
    display: block !important;
    padding: 6px 10px !important;
    background: #1a1a1a !important;
    color: #fff !important;
    text-decoration: none !important;
    border-radius: 20px !important;
    font-size: 8px !important;
    text-align: center !important;
    text-transform: uppercase !important;
    letter-spacing: 1px !important;
    font-weight: 600 !important;
    transition: all 0.3s ease !important;
  }

  .risaa-video-card .active-product-link:hover {
    background: #f8b799 !important;
    transform: translateY(-1px) !important;
  }

  /* Arrows positioning */
  .risaa-reels-nav {
    position: absolute;
    top: 50%;
    left: -22px;
    right: -22px;
    width: calc(100% + 44px);
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    pointer-events: none;
    z-index: 30;
    padding: 0;
  }

  .nav-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s cubic-bezier(0.165, 0.84, 0.44, 1), background-color 0.3s ease;
    color: #6e1423;
    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.15);
    transform: scale(0.9);
  }

  .nav-arrow svg {
    width: 18px;
    height: 18px;
    stroke: #6e1423;
    stroke-width: 2.5;
    fill: none;
    display: block;
  }

  .risaa-watch-and-shop:hover .nav-arrow {
    opacity: 0.7;
    pointer-events: auto;
    transform: scale(1);
  }

  .nav-arrow:hover {
    opacity: 1;
    background: rgba(255, 255, 255, 0.35);
    transform: scale(1.05);
  }

  @media screen and (max-width: 990px) {
    .risaa-watch-and-shop {
      width: calc(100% - 30px) !important;
    }
  }

  @media screen and (max-width: 749px) {
    .risaa-watch-and-shop {
      border-radius: 16px !important;
    }

    .risaa-reels-layout {
      margin: 20px auto !important;
    }

    .risaa-reels-stack {
      height: 480px !important;
      gap: 15px !important;
    }

    .risaa-video-card {
      flex: 0 0 270px !important;
      width: 270px !important;
      height: 480px !important;
    }

    .risaa-video-card .active-product-card {
      bottom: 12px !important;
      right: 12px !important;
      width: 140px !important;
      padding: 8px !important;
    }

    .risaa-video-card .active-product-image-wrap {
      margin-bottom: 6px !important;
      border-radius: 6px !important;
    }

    .risaa-video-card .active-product-tag {
      font-size: 7px !important;
    }

    .risaa-video-card .active-product-title {
      font-size: 9px !important;
      margin: 0 0 6px 0 !important;
    }

    .risaa-video-card .active-product-link {
      padding: 5px 6px !important;
      font-size: 7px !important;
    }

    .risaa-reels-nav {
      display: none;
    }
  }
{%- endstyle -%}

<div class="risaa-watch-and-shop section-{{ section.id }}-padding" data-anim="roll-up">
  <div class="section-header" style="text-align: center; margin-bottom: 10px; padding-top: 30px; padding-bottom: 15px;">
    <h2 class="h1">{{ section.settings.title }}</h2>
    <p>{{ section.settings.subtitle }}</p>
  </div>

  <div class="risaa-reels-layout">
    <!-- REELS CONTAINER -->
    <div class="risaa-reels-stack-side">
      <div class="risaa-reels-stack" id="reelsStack-{{ section.id }}">
        {% for block in section.blocks %}
          <div
            class="risaa-video-card"
            data-instagram-url="{{ block.settings.instagram_url }}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.video_url != blank %}
              <!-- HTML5 Native Premium Video (Autoplay, loop, muted, full screen, custom audio toggle) -->
              <video class="reel-video" src="{{ block.settings.video_url }}" autoplay loop muted playsinline style="width:100%; height:100%; object-fit:cover;"></video>
              
              <!-- Audio Toggle Button -->
              <div class="audio-toggle-btn" onclick="toggleCardAudio(event, this)">
                <!-- Muted Icon -->
                <svg class="mute-icon" viewBox="0 0 24 24">
                  <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.21.05-.42.05-.63zM19 12c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 9v1.27L9.27 7.55 12 4.82v4.18z"/>
                </svg>
                <!-- Unmuted Icon -->
                <svg class="unmute-icon" viewBox="0 0 24 24">
                  <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
                </svg>
              </div>
            {% elsif block.settings.instagram_url != blank %}
              <!-- Instagram Embed Iframe Container -->
              <div class="instagram-embed-wrapper">
                <div class="instagram-iframe-container" style="width:100%; height:100%;"></div>
              </div>
            {% else %}
              <!-- Mockup Fallback Image Placeholder -->
              <div style="width:100%; height:100%; background:linear-gradient(45deg, #f8b799, #ffd1bc); display:flex; align-items:center; justify-content:center; color:white;">
                <img
                  src="https://picsum.photos/400/700?random={{ forloop.index }}"
                  alt="Reel Placeholder"
                  style="width: 100%; height: 100%; object-fit: cover;"
                >
              </div>
            {% endif %}

            <!-- Embedded Product Info Overlay -->
            {%- assign product = block.settings.product -%}
            {%- if product != blank -%}
              <a href="{{ product.url }}" class="active-product-card" onclick="event.stopPropagation()">
                <div class="active-product-image-wrap">
                  <img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ product.title | escape }}">
                </div>
                <div class="active-product-details-wrap">
                  <span class="active-product-tag">The Look</span>
                  <h3 class="active-product-title">{{ product.title }}</h3>
                  <span class="active-product-link">Shop the Design</span>
                </div>
              </a>
            {%- else -%}
              <!-- Mockup Fallback when no product is selected -->
              <a href="#" class="active-product-card" onclick="event.stopPropagation()">
                <div class="active-product-image-wrap">
                  <img src="https://picsum.photos/300/400?random={{ forloop.index | plus: 100 }}" alt="Featured Design">
                </div>
                <div class="active-product-details-wrap">
                  <span class="active-product-tag">The Look</span>
                  <h3 class="active-product-title">Featured Design - Lehenga Set</h3>
                  <span class="active-product-link">Shop the Design</span>
                </div>
              </a>
            {%- endif -%}
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- Navigation Arrows positioned relative to layout container (only visible/functional on desktop) -->
    <div class="risaa-reels-nav">
      <div class="nav-arrow" onclick="shuffleStack('{{ section.id }}', 'prev')">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="20" y1="12" x2="4" y2="12"/>
          <polyline points="10 6 4 12 10 18"/>
        </svg>
      </div>
      <div class="nav-arrow" onclick="shuffleStack('{{ section.id }}', 'next')">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="4" y1="12" x2="20" y2="12"/>
          <polyline points="14 6 20 12 14 18"/>
        </svg>
      </div>
    </div>
  </div>
</div>

<script>
  function getInstagramEmbedUrl(url) {
    if (!url) return '';
    let cleanUrl = url.split('?')[0]; // Remove query params
    if (!cleanUrl.endsWith('/')) {
      cleanUrl += '/';
    }
    return cleanUrl + 'embed/';
  }

  function toggleCardAudio(event, btnEl) {
    event.stopPropagation();
    event.preventDefault();

    const card = btnEl.closest('.risaa-video-card');
    if (!card) return;

    const video = card.querySelector('video');
    if (!video) return;

    const isMuted = video.muted;
    const allVideos = document.querySelectorAll('.risaa-video-card video');
    const allButtons = document.querySelectorAll('.audio-toggle-btn');

    if (isMuted) {
      // Mute all other videos first
      allVideos.forEach(v => {
        v.muted = true;
      });
      allButtons.forEach(btn => {
        btn.classList.remove('unmuted');
      });

      // Unmute this video
      video.muted = false;
      btnEl.classList.add('unmuted');
    } else {
      // Mute this video
      video.muted = true;
      btnEl.classList.remove('unmuted');
    }
  }

  function setActiveCarouselPage(sectionId, startIndex, animate = true) {
    const stack = document.getElementById(`reelsStack-${sectionId}`);
    if (!stack) return;
    const cards = Array.from(stack.querySelectorAll('.risaa-video-card'));
    if (cards.length === 0) return;

    stack.dataset.startIndex = startIndex;

    // Translate stack
    const cardWidth = 312;
    const gap = 20;
    const translation = -startIndex * (cardWidth + gap);

    if (!animate) {
      stack.style.setProperty('transition', 'none', 'important');
    } else {
      stack.style.removeProperty('transition');
    }
    stack.style.transform = `translateX(${translation}px)`;
  }

  function shuffleStack(sectionId, direction) {
    const stack = document.getElementById(`reelsStack-${sectionId}`);
    if (!stack) return;
    const cards = Array.from(stack.querySelectorAll('.risaa-video-card'));
    const M = cards.length;
    if (M <= 3) return; // No scroll needed if they fit

    let startIndex = parseInt(stack.dataset.startIndex);
    if (isNaN(startIndex)) startIndex = 0;

    if (direction === 'next') {
      if (startIndex >= M - 3) {
        startIndex = 0; // Loop back
      } else {
        startIndex++;
      }
    } else {
      if (startIndex <= 0) {
        startIndex = Math.max(0, M - 3); // Loop to end
      } else {
        startIndex--;
      }
    }

    setActiveCarouselPage(sectionId, startIndex, true);
  }

  document.addEventListener('DOMContentLoaded', () => {
    const stack = document.getElementById('reelsStack-{{ section.id }}');
    const cards = document.querySelectorAll('.risaa-video-card');

    if (stack) {
      stack.dataset.startIndex = 0;
      setActiveCarouselPage('{{ section.id }}', 0, false);
    }

    // Load iframe embed players for all Instagram Reel URLs
    cards.forEach(card => {
      const container = card.querySelector('.instagram-iframe-container');
      const url = card.dataset.instagramUrl;
      if (container && url) {
        const embedUrl = getInstagramEmbedUrl(url);
        container.innerHTML = `
          <iframe src="${embedUrl}" width="100%" height="100%" frameborder="0" scrolling="no" allowtransparency="true" allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share" style="border:none; height:100%; width:100%;"></iframe>
        `;
      }
    });

    // Auto-play/pause videos based on viewport visibility
    const stackSide = document.querySelector('.risaa-reels-stack-side');
    if ('IntersectionObserver' in window && stackSide) {
      const videoObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const video = entry.target.querySelector('video');
          if (video) {
            if (entry.isIntersecting) {
              video.play().catch(e => {});
            } else {
              video.pause();
            }
          }
        });
      }, { 
        root: stackSide,
        threshold: 0.6 
      });

      cards.forEach(card => {
        videoObserver.observe(card);
      });
    }

    // Resize listener for desktop carousel translation alignment / mobile recovery
    let lastWidth = window.innerWidth;
    window.addEventListener('resize', () => {
      if (window.innerWidth === lastWidth) return;
      const isMobileNow = window.innerWidth < 750;
      const wasMobileBefore = lastWidth < 750;
      lastWidth = window.innerWidth;

      const rStack = document.getElementById('reelsStack-{{ section.id }}');
      if (!rStack) return;

      if (!isMobileNow && wasMobileBefore) {
        // Switched from mobile to desktop
        rStack.style.transform = '';
        rStack.dataset.startIndex = 0;
        setActiveCarouselPage('{{ section.id }}', 0, false);
      } else if (isMobileNow && !wasMobileBefore) {
        // Switched from desktop to mobile
        rStack.style.transform = '';
      }
    });
  });
</script>

{% schema %}
{
  "name": "Watch & Shop",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Watch & Shop"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "See our designs in motion"
    }
  ],
  "blocks": [
    {
      "type": "video_block",
      "name": "Reel Block",
      "settings": [
        {
          "type": "text",
          "id": "video_url",
          "label": "Direct Video URL (.mp4)",
          "info": "For premium full-screen autoplay & sound control: upload the Reel video file to Shopify Admin > Content > Files and paste the link here."
        },
        {
          "type": "text",
          "id": "instagram_url",
          "label": "Instagram Reel URL",
          "info": "Optional fallback: Paste the Instagram Reel URL (e.g. https://www.instagram.com/reel/Cx35Y9cr1gY/)"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Featured Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Watch & Shop",
      "blocks": [{ "type": "video_block" }, { "type": "video_block" }, { "type": "video_block" }]
    }
  ]
}
{% endschema %}
