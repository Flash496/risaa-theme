{%- style -%}
  .risaa-watch-and-shop {
    position: relative;
    padding: 100px 20px;
    background: #fff;
    overflow: hidden;
  }

  .risaa-reels-decor {
    position: absolute;
    width: 250px;
    height: 250px;
    opacity: 0.12;
    pointer-events: none;
    z-index: 1;
    background-size: contain;
  }

  .risaa-reels-layout {
    display: flex;
    max-width: 1100px;
    margin: 40px auto;
    align-items: center;
    justify-content: center;
    gap: 60px;
    position: relative;
    z-index: 2;
  }

  /* Reel Stack Side */
  .risaa-reels-stack-side {
    position: relative;
    flex: 0 0 320px;
  }

  .risaa-reels-stack {
    position: relative;
    width: 320px;
    height: 568px;
    perspective: 1000px;
  }

  .risaa-video-card {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 30px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.25);
    transition: all 0.7s cubic-bezier(0.19, 1, 0.22, 1);
    cursor: pointer;
  }

  .risaa-video-card.card-1 {
    transform: rotate(0) translateZ(0);
    z-index: 10;
    opacity: 1;
  }
  .risaa-video-card.card-2 {
    transform: rotate(4deg) translateZ(-30px) translateX(20px);
    z-index: 9;
    opacity: 0.8;
  }
  .risaa-video-card.card-3 {
    transform: rotate(-3deg) translateZ(-60px) translateX(-20px);
    z-index: 8;
    opacity: 0.6;
  }
  .risaa-video-card.card-hidden {
    transform: translateZ(-200px) translateY(100px);
    z-index: 1;
    opacity: 0;
    pointer-events: none;
  }

  .risaa-video-card.shuffling {
    animation: shuffle-animation 0.8s forwards cubic-bezier(0.19, 1, 0.22, 1);
  }

  @keyframes shuffle-animation {
    0% {
      transform: scale(1) translateX(0);
      z-index: 100;
    }
    40% {
      transform: scale(0.9) translateX(-200px) rotate(-15deg);
      opacity: 0.8;
    }
    100% {
      transform: scale(0.8) translateX(0) translateZ(-100px);
      z-index: 1;
      opacity: 0;
    }
  }

  .risaa-video-card video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Product Info Side */
  .risaa-reels-info-side {
    flex: 1;
    max-width: 400px;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 24px;
    animation: fade-in-right 0.8s ease;
  }

  @keyframes fade-in-right {
    from {
      opacity: 0;
      transform: translateX(30px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .active-product-card {
    background: #fff;
    padding: 30px;
    border-radius: 24px;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.06);
    border: 1px solid #f5f5f5;
    transition: opacity 0.25s ease, transform 0.25s ease;
  }

  .active-product-card.look-exit {
    opacity: 0;
    transform: translateY(16px) scale(0.97);
  }

  .active-product-card.look-enter {
    animation: look-card-in 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes look-card-in {
    0% {
      opacity: 0;
      transform: translateY(24px) scale(0.96);
    }
    60% {
      opacity: 1;
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .active-product-tag {
    font-family: 'Montserrat', sans-serif;
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 2px;
    color: #f8b799;
    font-weight: 700;
    margin-bottom: 12px;
    display: block;
  }

  .active-product-title {
    font-family: 'Cinzel', serif;
    font-size: 1.8rem;
    color: #1a1a1a;
    margin: 0 0 10px 0;
    line-height: 1.2;
  }

  .active-product-price {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    color: #666;
    margin-bottom: 24px;
  }

  .active-product-link {
    display: inline-block;
    padding: 15px 40px;
    background: #1a1a1a;
    color: #fff;
    text-decoration: none;
    border-radius: 50px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .active-product-link:hover {
    background: #f8b799;
    transform: translateY(-3px);
  }

  /* Arrows */
  .risaa-reels-nav {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    transform: translateY(-50%);
    display: flex;
    justify-content: space-between;
    padding: 0 40px;
    pointer-events: none; /* Allow clicking through the container */
    z-index: 20;
  }

  .nav-arrow {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(5px);
    color: #1a1a1a;
    pointer-events: auto; /* Re-enable for the buttons */
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
  }

  .nav-arrow:hover {
    background: #f8b799;
    border-color: #f8b799;
    color: #fff;
    transform: scale(1.1);
    box-shadow: 0 15px 30px rgba(248, 183, 153, 0.3);
  }

  @media screen and (max-width: 990px) {
    .risaa-reels-nav {
      position: relative;
      top: auto;
      transform: none;
      padding: 0;
      margin-top: 30px;
      justify-content: center;
    }
  }

  @media screen and (max-width: 990px) {
    .risaa-reels-layout {
      flex-direction: column;
      gap: 40px;
    }
    .risaa-reels-info-side {
      text-align: center;
      align-items: center;
    }
  }

  @media screen and (max-width: 749px) {
    .risaa-reels-stack,
    .risaa-reels-stack-side {
      width: 280px;
      height: 497px;
    }
  }

  /* Modal Styles */
  .risaa-video-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.95);
    z-index: 3000;
    backdrop-filter: blur(15px);
    align-items: center;
    justify-content: center;
  }

  .risaa-video-modal.active {
    display: flex;
  }

  .risaa-modal-content {
    display: flex;
    background: white;
    width: 95%;
    max-width: 1000px;
    height: 85vh;
    border-radius: 30px;
    overflow: hidden;
    position: relative;
    box-shadow: 0 50px 100px -20px rgba(0, 0, 0, 0.5);
    animation: modal-pop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  @keyframes modal-pop {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .risaa-modal-video {
    flex: 1.4;
    background: #000;
  }

  .risaa-modal-video video {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .risaa-modal-sidebar {
    flex: 1;
    padding: 50px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: #fff;
  }

  .risaa-close-modal {
    position: absolute;
    top: 30px;
    right: 30px;
    font-size: 40px;
    color: white;
    cursor: pointer;
    z-index: 3001;
    line-height: 1;
    transition: transform 0.3s ease;
  }

  .risaa-close-modal:hover {
    transform: rotate(90deg);
  }

  @media screen and (max-width: 749px) {
    .risaa-modal-content {
      flex-direction: column;
      height: 95vh;
    }
    .risaa-modal-video {
      flex: 1;
    }
    .risaa-modal-sidebar {
      padding: 30px;
    }
  }
{%- endstyle -%}

<div class="risaa-watch-and-shop section-{{ section.id }}-padding reveal-on-scroll">
  <div class="section-header" data-anim="fade-up" style="text-align: center; margin-bottom: 40px;">
    <h2 class="h1">{{ section.settings.title }}</h2>
    <p>{{ section.settings.subtitle }}</p>
  </div>

  <div class="risaa-reels-layout">
    <!-- REEL STACK -->
    <div class="risaa-reels-stack-side">
      <div class="risaa-reels-stack" id="reelsStack-{{ section.id }}">
        {% for block in section.blocks %}
          <div
            class="risaa-video-card card-{{ forloop.index }} {% if forloop.index > 3 %}card-hidden{% endif %}"
            onclick="handleCardClick(this, '{{ block.id }}')"
            data-block-id="{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.video_url != blank %}
              <video muted loop playsinline class="reel-video">
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
            {% else %}
              <div style="width:100%; height:100%; background:linear-gradient(45deg, #f8b799, #ffd1bc); display:flex; align-items:center; justify-content:center; color:white;">
                <img
                  src="https://ik.imagekit.io/flashspdstr/risaa/Elevate%20your%20ethnic%20wardrobe%20with%20this%20gorgeous_.jpg"
                  class="placeholder-svg"
                  alt="Product Placeholder"
                  style="width: 100%; height: 100%; object-fit: cover;"
                >
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

    <!-- PRODUCT INFO -->
    <div class="risaa-reels-info-side">
      <div id="activeProductInfo-{{ section.id }}" class="active-product-card">
        <!-- Injected by JS -->
      </div>
    </div>
  </div>

  <div class="risaa-reels-nav">
    <div class="nav-arrow" onclick="shuffleStack('{{ section.id }}', 'prev')">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M15 18l-6-6 6-6"/>
      </svg>
    </div>
    <div class="nav-arrow" onclick="shuffleStack('{{ section.id }}', 'next')">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M9 18l6-6-6-6"/>
      </svg>
    </div>
  </div>
</div>

<script>
  function handleCardClick(card, blockId) {
    if (card.classList.contains('card-1')) {
      openRisaaModal(blockId);
    } else {
      shuffleStack('{{ section.id }}', 'next');
    }
  }

  function updateProductInfo(sectionId, blockId) {
    const data = videoData[blockId];
    if (!data) return;

    const container = document.getElementById(`activeProductInfo-${sectionId}`);
    const card = container.closest('.active-product-card') || container;

    // Exit animation
    card.classList.remove('look-enter');
    card.classList.add('look-exit');

    setTimeout(() => {
      container.innerHTML = `
        <div class="active-product-image-wrap" style="margin-bottom: 20px; border-radius: 15px; overflow: hidden; aspect-ratio: 4/5;">
          <img src="https://ik.imagekit.io/flashspdstr/risaa/pink%20sharara%20with%20light%20golden%20embroidery%20with_.jpg" 
               style="width: 100%; height: 100%; object-fit: cover;" 
               alt="Showcased Design">
        </div>
        <span class="active-product-tag">The Look</span>
        <h3 class="active-product-title">${data.title}</h3>
        <p class="active-product-price">${data.price}</p>
        <a href="${data.url}" class="active-product-link">Shop the Design</a>
      `;

      // Enter animation
      card.classList.remove('look-exit');
      void card.offsetWidth; // force reflow to retrigger animation
      card.classList.add('look-enter');
    }, 250);
  }

  function shuffleStack(sectionId, direction) {
    const stack = document.getElementById(`reelsStack-${sectionId}`);
    const topCard = stack.querySelector('.card-1');
    if (!topCard) return;

    topCard.classList.add('shuffling');

    setTimeout(() => {
      topCard.classList.remove('shuffling');
      stack.appendChild(topCard);

      const newCards = Array.from(stack.querySelectorAll('.risaa-video-card'));
      newCards.forEach((card, i) => {
        card.className = 'risaa-video-card';
        const pos = i + 1;
        if (pos <= 3) card.classList.add(`card-${pos}`);
        else card.classList.add('card-hidden');

        const video = card.querySelector('video');
        if (video) {
          if (pos === 1) video.play();
          else video.pause();
        }
      });

      const activeBlockId = stack.querySelector('.card-1').getAttribute('data-block-id');
      updateProductInfo(sectionId, activeBlockId);
    }, 600);
  }

  document.addEventListener('DOMContentLoaded', () => {
    const stack = document.getElementById('reelsStack-{{ section.id }}');
    if (stack) {
      const topCard = stack.querySelector('.card-1');
      if (topCard) {
        const video = topCard.querySelector('video');
        if (video) video.play();
        updateProductInfo('{{ section.id }}', topCard.getAttribute('data-block-id'));
      }
    }

    // Auto-advance every 4 seconds
    const stackSide = document.querySelector('.risaa-reels-stack-side');
    let autoTimer = setInterval(() => {
      shuffleStack('{{ section.id }}', 'next');
    }, 4000);

    // Pause on hover, resume on leave
    if (stackSide) {
      stackSide.addEventListener('mouseenter', () => clearInterval(autoTimer));
      stackSide.addEventListener('mouseleave', () => {
        autoTimer = setInterval(() => {
          shuffleStack('{{ section.id }}', 'next');
        }, 4000);
      });
    }
  });
</script>

<!-- Modal Structure -->
<div id="risaaVideoModal" class="risaa-video-modal">
  <span class="risaa-close-modal" onclick="closeRisaaModal()">&times;</span>
  <div class="risaa-modal-content">
    <div class="risaa-modal-video">
      <video id="risaaMainVideo" controls autoplay loop>
        <source src="" type="video/mp4">
      </video>
    </div>
    <div class="risaa-modal-sidebar" id="risaaModalSidebar">
      <!-- Product info injected here -->
    </div>
  </div>
</div>

<script>
  const videoData = {
    {% for block in section.blocks %}
      "{{ block.id }}": {
        "video": "{{ block.settings.video_url }}",
        "title": "{{ block.settings.product.title | escape }}",
        "price": "{{ block.settings.product.price | money | escape }}",
        "url": "{{ block.settings.product.url }}",
        "image": "{{ block.settings.product.featured_image | image_url: width: 300 }}"
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  };

  function openRisaaModal(blockId) {
    const data = videoData[blockId];
    if(!data) return;

    const modal = document.getElementById('risaaVideoModal');
    const video = document.getElementById('risaaMainVideo');
    const sidebar = document.getElementById('risaaModalSidebar');

    video.src = data.video;
    sidebar.innerHTML = `
      <h3 style="color:var(--brand-main); margin-top:0;">Shop the Look</h3>
      <div style="margin-bottom:20px;">
        <img src="${data.image}" style="width:100%; border-radius:5px; margin-bottom:10px;">
        <h4 style="margin:5px 0;">${data.title}</h4>
        <p style="font-weight:bold; color:var(--brand-main);">${data.price}</p>
        <a href="${data.url}" class="btn-premium" style="display:block; text-align:center;">View Details</a>
      </div>
    `;

    modal.classList.add('active');
    video.play();
  }

  function closeRisaaModal() {
    const modal = document.getElementById('risaaVideoModal');
    const video = document.getElementById('risaaMainVideo');
    modal.classList.remove('active');
    video.pause();
    video.src = "";
  }
</script>

{% schema %}
{
  "name": "Watch & Shop",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Watch & Shop"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "See our designs in motion"
    }
  ],
  "blocks": [
    {
      "type": "video_block",
      "name": "Video & Product",
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (.mp4)",
          "info": "Upload to Shopify Files and paste link here"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Featured Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Watch & Shop",
      "blocks": [{ "type": "video_block" }, { "type": "video_block" }, { "type": "video_block" }]
    }
  ]
}
{% endschema %}
