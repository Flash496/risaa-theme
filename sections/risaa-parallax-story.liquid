{%- style -%}
  #shopify-section-{{ section.id }} {
    margin-top: 0 !important;
    padding-top: 0 !important;
    width: 100% !important;
    max-width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} > * {
    max-width: 100% !important;
  }

  .risaa-parallax-section {
    position: relative;
    z-index: 1;
    padding: 50px 0;
    background-color: var(--brand-undertone-2);
    border-radius: 0 0 32px 32px;
    width: 100%;
  }

  .risaa-parallax-container {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    padding: 0 60px;
    gap: 60px;
  }

  .risaa-parallax-images {
    flex: 1;
    position: relative;
    height: 650px;
  }

  .risaa-img-parallax {
    position: absolute;
    border-radius: 180px 180px 0 0;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    will-change: transform;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .risaa-img-1 {
    width: 350px;
    height: 550px;
    top: 0;
    left: 0;
    z-index: 2;
  }

  .risaa-img-2 {
    width: 300px;
    height: 450px;
    bottom: 50px;
    right: 0;
    z-index: 1;
  }

  .risaa-parallax-text {
    flex: 1;
    z-index: 3;
  }

  .risaa-parallax-text h2 {
    font-size: 4rem;
    margin-bottom: 2rem;
  }

  .risaa-parallax-text p {
    font-size: 1.8rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    color: #444;
  }

  @media screen and (max-width: 989px) {
    .risaa-parallax-container {
      flex-direction: column;
      text-align: center;
    }
    .risaa-parallax-images {
      width: 100%;
      height: 400px;
    }
    .risaa-img-1 {
      width: 200px;
      height: 300px;
    }
    .risaa-img-2 {
      width: 150px;
      height: 250px;
    }
  }
{%- endstyle -%}

<section class="risaa-parallax-section">
  <div class="risaa-parallax-container">
    <div class="risaa-parallax-images">
      <div class="risaa-img-parallax risaa-img-1">
        {% if section.settings.image_1 != blank %}
          {{ section.settings.image_1 | image_url: width: 600 | image_tag: loading: 'lazy' }}
        {% else %}
          <img
            src="https://ik.imagekit.io/flashspdstr/risaa/couture.jpg"
            alt="RiSaa Couture"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"
          >
        {% endif %}
      </div>
      <div class="risaa-img-parallax risaa-img-2">
        {% if section.settings.image_2 != blank %}
          {{ section.settings.image_2 | image_url: width: 600 | image_tag: loading: 'lazy' }}
        {% else %}
          <img
            src="https://ik.imagekit.io/flashspdstr/risaa/bridal.jpg"
            alt="RiSaa Bridal"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"
          >
        {% endif %}
      </div>
    </div>

    <div class="risaa-parallax-text reveal-on-scroll" data-anim="fade-up" data-anim-delay="0.2">
      <span
        class="active-product-tag"
        style="color: var(--brand-main); margin-bottom: 10px; display: block; font-size: 16px;"
        >Since 2021</span
      >
      <h2 style="font-family: 'Cinzel', serif; font-size: 3rem; line-height: 1.1; margin-bottom: 30px;">
        {{ section.settings.heading }}
      </h2>

      <div class="story-content-wrap" style="margin-bottom: 40px;">
        <div
          class="rte"
          style="font-family: 'Montserrat', sans-serif; font-size: 1rem; line-height: 1.8; color: #555; margin-bottom: 20px;"
        >
          <p>
            <strong>Risaa - Design Studio by Rima</strong> was born from a vision to bridge the gap between high-end
            couture and accessible elegance. What started as a passion for exquisite detailing has evolved into a
            full-fledged studio in the heart of Ludhiana, dedicated to celebrating the individuality of the modern woman
            through timeless silhouettes and contemporary fusion.
          </p>

          <p>
            Each piece in our collection is a labor of love, artfully custom-crafted by our master artisans. We believe
            in the philosophy of <strong>slow fashion</strong>—a commitment to quality where time-honored techniques
            like intricate Zardosi are given the space to shine. Experience the Risaa journey — where every stitch tells
            a story of passion, tradition, and accessible luxury.
          </p>
        </div>

        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'story_text' %}
              <div
                class="rte"
                style="font-family: 'Montserrat', sans-serif; font-size: 1rem; line-height: 1.8; color: #555; margin-bottom: 20px;"
                {{ block.shopify_attributes }}
              >
                {{ block.settings.text }}
              </div>
            {% when 'brand_quote' %}
              <blockquote
                style="border-left: 3px solid var(--brand-main); padding-left: 20px; margin: 30px 0; font-family: 'Cinzel', serif; font-style: italic; font-size: 1.2rem; color: #1a1a1a;"
                {{ block.shopify_attributes }}
              >
                "{{ block.settings.quote }}"
                {% if block.settings.author != blank %}
                  <cite style="display: block; font-size: 0.9rem; margin-top: 10px; font-style: normal; font-family: 'Montserrat', sans-serif;"
                    >— {{ block.settings.author -}}
                  </cite>
                {% endif %}
              </blockquote>
          {% endcase %}
        {% endfor %}
      </div>

      {% if section.blocks.size > 0 %}
        <div
          class="story-highlights"
          style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-bottom: 40px;"
        >
          {% for block in section.blocks %}
            {% if block.type == 'highlight' %}
              <div class="highlight-item" {{ block.shopify_attributes }}>
                <h4 style="font-family: 'Cinzel', serif; font-size: 1.1rem; margin-bottom: 8px; color: #1a1a1a;">
                  {{ block.settings.title }}
                </h4>
                <p style="font-family: 'Montserrat', sans-serif; font-size: 0.85rem; color: #777; margin: 0;">
                  {{ block.settings.text }}
                </p>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="btn-premium">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (function () {
    document.addEventListener('DOMContentLoaded', () => {
      const section = document.querySelector('.risaa-parallax-section');
      if (!section) return;

      const img1 = section.querySelector('.risaa-img-1');
      const img2 = section.querySelector('.risaa-img-2');

      let ticking = false;

      function updateStoryParallax() {
        const rect = section.getBoundingClientRect();
        const windowHeight = window.innerHeight;

        const sectionCenter = rect.top + rect.height / 2;
        const viewportCenter = windowHeight / 2;
        const offset = sectionCenter - viewportCenter;

        if (rect.top < windowHeight && rect.bottom > 0) {
          if (window.innerWidth > 989) {
            // img1 (top left) starts farther top-left (-X, -Y) when section is below viewport (offset > 0)
            const speed1X = 0.12;
            const speed1Y = 0.18;
            const x1 = -offset * speed1X;
            const y1 = -offset * speed1Y;
            if (img1) img1.style.transform = `translate3d(${x1}px, ${y1}px, 0)`;

            // img2 (bottom right) starts farther bottom-right (+X, +Y) when section is below viewport (offset > 0)
            const speed2X = 0.15;
            const speed2Y = 0.22;
            const x2 = offset * speed2X;
            const y2 = offset * speed2Y;
            if (img2) img2.style.transform = `translate3d(${x2}px, ${y2}px, 0)`;
          } else {
            if (img1) img1.style.transform = 'none';
            if (img2) img2.style.transform = 'none';
          }
        }
        ticking = false;
      }

      window.addEventListener(
        'scroll',
        () => {
          if (!ticking) {
            window.requestAnimationFrame(updateStoryParallax);
            ticking = true;
          }
        },
        { passive: true }
      );

      window.addEventListener('resize', () => {
        if (!ticking) {
          window.requestAnimationFrame(updateStoryParallax);
          ticking = true;
        }
      });

      updateStoryParallax();
    });
  })();
</script>

{% schema %}
{
  "name": "Parallax Story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The RiSaa Journey"
