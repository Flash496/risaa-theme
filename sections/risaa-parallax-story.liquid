{%- style -%}
  .risaa-parallax-section {
    position: relative;
    z-index: 1;
    padding: 50px 0;
    background-color: var(--brand-undertone-2);
    overflow: hidden;
  }

  .risaa-parallax-container {
    display: flex;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    gap: 60px;
  }

  .risaa-parallax-images {
    flex: 1;
    position: relative;
    height: 600px;
  }

  .risaa-img-parallax {
    position: absolute;
    border-radius: 150px 150px 0 0;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
  }

  .risaa-img-1 {
    width: 300px;
    height: 450px;
    top: 0;
    left: 0;
    z-index: 2;
  }

  .risaa-img-2 {
    width: 250px;
    height: 350px;
    bottom: 50px;
    right: 0;
    z-index: 1;
  }

  .risaa-parallax-text {
    flex: 1;
    z-index: 3;
  }

  .risaa-parallax-text h2 {
    font-size: 4rem;
    margin-bottom: 2rem;
  }

  .risaa-parallax-text p {
    font-size: 1.8rem;
    line-height: 1.8;
    margin-bottom: 2rem;
    color: #444;
  }

  @media screen and (max-width: 989px) {
    .risaa-parallax-container {
      flex-direction: column;
      text-align: center;
    }
    .risaa-parallax-images {
      width: 100%;
      height: 400px;
    }
    .risaa-img-1 {
      width: 200px;
      height: 300px;
    }
    .risaa-img-2 {
      width: 150px;
      height: 250px;
    }
  }
{%- endstyle -%}

<section class="risaa-parallax-section">
  <div class="risaa-parallax-container">
    <div class="risaa-parallax-images">
      <div
        class="risaa-img-parallax risaa-img-1 reveal-on-scroll"
        style="transition-delay: 0.2s;"
        data-anim="slide-left"
        data-anim-delay="0.1"
      >
        {% if section.settings.image_1 != blank %}
          {{ section.settings.image_1 | image_url: width: 600 | image_tag: loading: 'lazy' }}
        {% else %}
          <img
            src="https://ik.imagekit.io/flashspdstr/risaa/couture.jpg"
            alt="RiSaa Couture"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"
          >
        {% endif %}
      </div>
      <div
        class="risaa-img-parallax risaa-img-2 reveal-on-scroll"
        style="transition-delay: 0.5s;"
        data-anim="slide-right"
        data-anim-delay="0.25"
      >
        {% if section.settings.image_2 != blank %}
          {{ section.settings.image_2 | image_url: width: 600 | image_tag: loading: 'lazy' }}
        {% else %}
          <img
            src="https://ik.imagekit.io/flashspdstr/risaa/bridal.jpg"
            alt="RiSaa Bridal"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"
          >
        {% endif %}
      </div>
    </div>

    <div class="risaa-parallax-text reveal-on-scroll" data-anim="fade-up" data-anim-delay="0.2">
      <h2>{{ section.settings.heading }}</h2>
      <div class="rte">
        {{ section.settings.text }}
      </div>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="btn-premium">{{ section.settings.button_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Parallax Story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Story"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>RiSaa is a design studio located in Ludhiana, Punjab. We ship orders worldwide. Here at RiSaa, we are not just about clothes, we're about crafting experiences and catering to your individual preferences!</p>"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Read More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Parallax Story"
    }
  ]
}
{% endschema %}
