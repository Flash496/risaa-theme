        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Parallax Story",
      "blocks": [
        {
          "type": "highlight",
          "settings": {
            "title": "Accessible Luxury",
            "text": "High-end couture quality delivered at accessible price points."
          }
        },
        {
          "type": "highlight",
          "settings": {
            "title": "Slow Fashion",
            "text": "Mindful production that prioritizes quality and longevity over trends."
          }
        },
        {
          "type": "highlight",
          "settings": {
            "title": "Worldwide Shipping",
            "text": "Connecting the elegance of Ludhiana to doorsteps across the globe."
          }
        },
        {
          "type": "highlight",
          "settings": {
