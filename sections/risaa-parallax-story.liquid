{%- style -%}
  #shopify-section-{{ section.id }} {
    margin-top: 0 !important;
    padding-top: 0 !important;
    width: 100% !important;
    max-width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    box-sizing: border-box;
  }

  #shopify-section-{{ section.id }} > * {
    max-width: 100% !important;
  }

  .risaa-parallax-section {
    position: relative;
    z-index: 1;
    padding: 50px 0;
    background-color: #F4EADE;
    border-radius: 32px;
    width: 100%;
    overflow: visible;
  }

  .risaa-parallax-container {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    padding: 0 60px;
    gap: 60px;
  }

  .risaa-parallax-images {
    flex: 1;
    position: relative;
    height: 650px;
  }

  .risaa-img-parallax {
    position: absolute;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    will-change: transform;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .risaa-img-1 {
    width: 350px;
    height: 550px;
    top: 35px;
    left: 30px;
    z-index: 2;
  }

  .risaa-img-2 {
    width: 300px;
    height: 450px;
    bottom: 70px;
    right: 30px;
    z-index: 1;
  }

  .risaa-parallax-text {
    flex: 1;
    z-index: 3;
  }

  /* === BLOOM ANIMATION === */
  .risaa-story-bloom {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .rsb-line {
    opacity: 0;
    filter: blur(7px);
    transform: translateY(8px);
    transition: opacity 0.65s ease, filter 0.65s ease, transform 0.65s ease;
  }

  .rsb-line.rsb-visible {
    opacity: 1;
    filter: blur(0);
    transform: translateY(0);
  }

  .rsb-eyebrow {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.0rem;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--brand-main);
    display: block;
    margin-bottom: 0.2rem;
  }

  .rsb-studio-name {
    font-family: 'Cinzel', Georgia, serif;
    font-size: 2.2rem;
    line-height: 1.2;
    color: #1a1a1a;
    font-weight: 400;
    letter-spacing: 0.06em;
    margin: 0;
  }

  .rsb-studio-name em {
    font-family: 'Great Vibes', cursive;
    font-size: 2.6rem;
    font-style: normal;
    color: var(--brand-main);
    display: inline;
    letter-spacing: 0.02em;
  }

  .rsb-body {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.25rem;
    line-height: 1.65;
    color: #555;
    font-weight: 300;
    margin: 0;
  }

  .rsb-body strong { color: #1a1a1a; font-weight: 500; }
  .rsb-body em { font-style: italic; color: var(--brand-main); }

  .rsb-indent {
    padding-left: 1.2rem;
    border-left: 2px solid rgba(110, 20, 35, 0.2);
  }

  .rsb-pullquote {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(1.4rem, 2.8vw, 2.2rem);
    font-style: italic;
    line-height: 1.35;
    color: var(--brand-main);
    font-weight: 400;
    letter-spacing: 0.01em;
    padding: 0.5rem 0 0.5rem 1.2rem;
    border-left: 2px solid rgba(110, 20, 35, 0.3);
    margin: 0.2rem 0;
    width: 100%;
  }

  .rsb-closing {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    line-height: 1.65;
    color: #444;
    font-weight: 300;
    margin: 0;
  }

  .rsb-closing strong { color: #1a1a1a; font-weight: 500; }

  .rsb-cta {
    display: inline-block;
    margin-top: 0.4rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.0rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--brand-main);
    text-decoration: none;
    border-bottom: 1px solid rgba(110, 20, 35, 0.35);
    padding-bottom: 2px;
    transition: border-color 0.2s ease, opacity 0.2s ease;
    width: fit-content;
  }

  .rsb-cta:hover { opacity: 0.7; border-color: var(--brand-main); }

  @media screen and (max-width: 989px) {
    .risaa-parallax-section {
      padding: 20px 0 80px 0;
    }
    .risaa-parallax-container {
      flex-direction: column;
      text-align: center;
      padding: 0 24px;
      gap: 15px;
    }
    .risaa-parallax-images {
      width: 100%;
      height: 450px;
      margin-bottom: 10px;
      flex: none;
    }
    .risaa-img-1 {
      width: 200px;
      height: 280px;
      top: 30px;
      left: 55px;
    }
    .risaa-img-2 {
      width: 160px;
      height: 220px;
      bottom: 10px;
      right: 25px;
    }
    .risaa-parallax-text {
      width: 100%;
      margin-top: 5px;
      flex: none;
    }
    .rsb-cta {
      align-self: center;
    }
    .rsb-sep {
      display: none !important;
    }
    .rsb-studio-name em {
      display: block !important;
      margin-top: 0.4rem;
    }
  }
{%- endstyle -%}

<section class="risaa-parallax-section">
  <div class="risaa-parallax-container">
    <div class="risaa-parallax-images">
      <div class="risaa-img-parallax risaa-img-1">
        {% if section.settings.image_1 != blank %}
          {{ section.settings.image_1 | image_url: width: 600 | image_tag: loading: 'lazy' }}
        {% else %}
          <img
            src="https://ik.imagekit.io/flashspdstr/risaa/naganath-chiluveru-Uzl-KYPAH44-unsplash.jpg?updatedAt=1778478944071"
            alt="RiSaa Couture"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"
          >
        {% endif %}
      </div>
      <div class="risaa-img-parallax risaa-img-2">
        {% if section.settings.image_2 != blank %}
          {{ section.settings.image_2 | image_url: width: 600 | image_tag: loading: 'lazy' }}
        {% else %}
          <img
            src="https://ik.imagekit.io/flashspdstr/risaa/bridal%20couture.jpg"
            alt="RiSaa Bridal"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"
          >
        {% endif %}
      </div>
    </div>

    <div class="risaa-parallax-text">
      <div class="risaa-story-bloom">
        <span class="rsb-line rsb-eyebrow">Since 2021 &nbsp;·&nbsp; Ludhiana, Punjab</span>

        <p class="rsb-line rsb-studio-name">Risaa — Design Studio <span class="rsb-sep">&nbsp;·&nbsp;</span> <em>by Rima</em></p>

        <p class="rsb-line rsb-pullquote">
          "Each piece is a labor of love, artfully custom-crafted by our master artisans."
        </p>

        <p class="rsb-line rsb-closing">
          Where every stitch tells a story of <strong>passion, tradition,</strong> and
          <strong>accessible luxury.</strong>
        </p>

        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}" class="rsb-line rsb-cta">
            {{- section.settings.button_label }} →</a
          >
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    document.addEventListener('DOMContentLoaded', () => {
      const section = document.querySelector('.risaa-parallax-section');
      if (!section) return;

      const img1 = section.querySelector('.risaa-img-1');
      const img2 = section.querySelector('.risaa-img-2');

      let ticking = false;
      let isIntersecting = false;

      function updateStoryParallax() {
        if (!isIntersecting) {
          ticking = false;
          return;
        }
        const rect = section.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        const isDesktop = window.innerWidth > 989;

        const sectionCenter = rect.top + rect.height / 2;
        const viewportCenter = isDesktop ? (windowHeight / 2) : (windowHeight * 0.75);
        const offset = sectionCenter - viewportCenter;

        if (rect.top < windowHeight && rect.bottom > 0) {
          const speed1X = isDesktop ? 0.12 : 0.08;
          const speed1Y = isDesktop ? 0.18 : 0.12;
          const speed2X = isDesktop ? 0.15 : 0.09;
          const speed2Y = isDesktop ? 0.22 : 0.15;

          // img1 (top left) starts farther top-left (-X, -Y) when section is below viewport (offset > 0)
          const x1 = -offset * speed1X;
          const y1 = -offset * speed1Y;
          if (img1) img1.style.transform = `translate3d(${x1}px, ${y1}px, 0)`;

          // img2 (bottom right) starts farther bottom-right (+X, +Y) when section is below viewport (offset > 0)
          const x2 = offset * speed2X;
          const y2 = offset * speed2Y;
          if (img2) img2.style.transform = `translate3d(${x2}px, ${y2}px, 0)`;
        }
        ticking = false;
      }

      if ('IntersectionObserver' in window) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            isIntersecting = entry.isIntersecting;
            if (isIntersecting && !ticking) {
              window.requestAnimationFrame(updateStoryParallax);
              ticking = true;
            }
          });
        }, { threshold: 0 });
        observer.observe(section);
      } else {
        isIntersecting = true;
      }

      window.addEventListener(
        'scroll',
        () => {
          if (!isIntersecting) return;
          if (!ticking) {
            window.requestAnimationFrame(updateStoryParallax);
            ticking = true;
          }
        },
        { passive: true }
      );

      let lastWidth = window.innerWidth;
      window.addEventListener('resize', () => {
        if (window.innerWidth === lastWidth) return;
        lastWidth = window.innerWidth;
        if (!ticking) {
          window.requestAnimationFrame(updateStoryParallax);
          ticking = true;
        }
      });

      updateStoryParallax();
    });
  })();

  // Bloom reveal — reversible staggered line-by-line on scroll
  (function () {
    var lines = document.querySelectorAll('.risaa-parallax-section .rsb-line');
    if (!lines.length) return;

    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          var el = entry.target;
          var idx = parseInt(el.getAttribute('data-rsb-idx') || '0', 10);
          if (entry.isIntersecting) {
            setTimeout(function () {
              el.classList.add('rsb-visible');
            }, idx * 110);
          } else {
            el.classList.remove('rsb-visible');
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -30px 0px' }
    );

    lines.forEach(function (el, i) {
      el.setAttribute('data-rsb-idx', i);
      observer.observe(el);
    });
  })();
</script>

{% schema %}
{
  "name": "Parallax Story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The RiSaa Journey"
