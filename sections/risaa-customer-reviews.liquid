{%- style -%}
  .risaa-reviews {
    padding: 80px 0 70px;
    background: #fff;
    overflow: hidden;
  }

  /* ── Header ── */
  .risaa-reviews__header {
    text-align: center;
    margin-bottom: 56px;
    padding: 0 20px;
  }

  .risaa-reviews__eyebrow {
    display: block;
    font-family: var(--font-body-family);
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #f8b799;
    font-weight: 600;
    margin-bottom: 14px;
  }

  .risaa-reviews__title {
    font-family: var(--font-heading-family);
    font-size: 2.8rem;
    color: #9a1c20;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 18px;
    line-height: 1.1;
  }

  .risaa-reviews__aggregate {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }

  .risaa-reviews__agg-stars {
    display: flex;
    gap: 3px;
  }

  .risaa-reviews__agg-star {
    color: #c9a84c;
    font-size: 1.1rem;
  }

  .risaa-reviews__agg-label {
    font-family: var(--font-body-family);
    font-size: 1.1rem;
    color: #999;
    letter-spacing: 0.04em;
  }

  .risaa-reviews__agg-score {
    font-family: var(--font-heading-family);
    font-size: 1.3rem;
    color: #1a1a1a;
    font-weight: 600;
  }

  /* ── Carousel ── */
  .risaa-reviews__carousel-outer {
    position: relative;
    overflow: hidden;
  }

  .risaa-reviews__carousel-outer::before,
  .risaa-reviews__carousel-outer::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 60px;
    z-index: 2;
    pointer-events: none;
  }

  .risaa-reviews__carousel-outer::before {
    left: 0;
    background: linear-gradient(to right, #fff, transparent);
  }

  .risaa-reviews__carousel-outer::after {
    right: 0;
    background: linear-gradient(to left, #fff, transparent);
  }

  .risaa-reviews__track {
    display: flex;
    gap: 28px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 8px 60px 16px;
  }

  .risaa-reviews__track::-webkit-scrollbar {
    display: none;
  }

  /* ── Card ── */
  .risaa-reviews__card {
    flex: 0 0 340px;
    scroll-snap-align: start;
    background: #faf8f5;
    border: 1px solid #f0ebe4;
    border-radius: 4px;
    overflow: hidden;
    transition: box-shadow 0.35s ease, transform 0.35s ease;
  }

  .risaa-reviews__card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.07);
  }

  .risaa-reviews__card-photo {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .risaa-reviews__card-body {
    padding: 24px 26px 26px;
  }

  /* Stars + date row */
  .risaa-reviews__card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .risaa-reviews__card-stars {
    display: flex;
    gap: 3px;
  }

  .risaa-reviews__card-star {
    color: #c9a84c;
    font-size: 1.1rem;
  }

  .risaa-reviews__card-star.empty {
    color: #e0d8cc;
  }

  /* Quote */
  .risaa-reviews__card-quote {
    font-family: var(--font-body-family);
    font-size: 1.25rem;
    line-height: 1.75;
    color: #444;
    margin: 0 0 22px;
    padding-left: 14px;
    border-left: 2px solid #9a1c20;
    font-style: italic;
  }

  /* Reviewer */
  .risaa-reviews__card-bottom {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .risaa-reviews__avatar-initial {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #9a1c20;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading-family);
    font-size: 1.4rem;
    color: #fff;
    flex-shrink: 0;
  }

  .risaa-reviews__avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .risaa-reviews__reviewer-name {
    font-family: var(--font-heading-family);
    font-size: 1.2rem;
    color: #1a1a1a;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin: 0;
    line-height: 1.2;
  }

  .risaa-reviews__reviewer-meta {
    font-size: 1rem;
    color: #aaa;
    margin: 3px 0 0;
    letter-spacing: 0.02em;
  }

  .risaa-reviews__verified {
    margin-left: auto;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #4ade80;
    font-weight: 600;
    white-space: nowrap;
  }

  /* ── Nav ── */
  .risaa-reviews__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: 44px;
  }

  .risaa-reviews__nav-btn {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1px solid #e0d8cc;
    background: transparent;
    color: #1a1a1a;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .risaa-reviews__nav-btn svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
  }

  .risaa-reviews__nav-btn:hover {
    background: #9a1c20;
    border-color: #9a1c20;
    color: #fff;
  }

  .risaa-reviews__dots {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .risaa-reviews__dot {
    width: 6px;
    height: 6px;
    border-radius: 3px;
    background: #e0d8cc;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .risaa-reviews__dot.active {
    background: #9a1c20;
    width: 22px;
  }

  @media screen and (max-width: 989px) {
    .risaa-reviews__card {
      flex: 0 0 300px;
    }
  }

  @media screen and (max-width: 749px) {
    .risaa-reviews {
      padding: 50px 0 44px;
    }
    .risaa-reviews__title {
      font-size: 2.2rem;
    }
    .risaa-reviews__card {
      flex: 0 0 270px;
    }
    .risaa-reviews__track {
      padding: 8px 24px 16px;
      gap: 18px;
    }
  }
{%- endstyle -%}

<section class="risaa-reviews reveal-on-scroll" id="risaa-reviews-{{ section.id }}">
  <div class="risaa-reviews__header" data-anim="fade-up">
    <span class="risaa-reviews__eyebrow">What Our Brides Say</span>
    <h2 class="risaa-reviews__title">{{ section.settings.title }}</h2>
    <div class="risaa-reviews__aggregate">
      <div class="risaa-reviews__agg-stars">
        {%- for i in (1..5) -%}
          <span class="risaa-reviews__agg-star">★</span>
        {%- endfor -%}
      </div>
      <span class="risaa-reviews__agg-score">{{ section.settings.aggregate_score }}</span>
      <span class="risaa-reviews__agg-label">· {{ section.settings.review_count }}</span>
    </div>
  </div>

  <div class="risaa-reviews__carousel-outer">
    <div class="risaa-reviews__track" id="risaa-rev-track-{{ section.id }}">
      {%- assign rev_imgs = 'https://ik.imagekit.io/flashspdstr/risaa/Screenshot%202026-05-11%20122743.png,https://ik.imagekit.io/flashspdstr/risaa/Elevate%20your%20ethnic%20wardrobe%20with%20this%20gorgeous_.jpg,https://ik.imagekit.io/flashspdstr/risaa/Stunning%20royal%20red%20bridal%20lehenga%20with%20heavy_.jpg,https://ik.imagekit.io/flashspdstr/risaa/festive%20glamour%20in%20this%20stunner%20_.jpg,https://ik.imagekit.io/flashspdstr/risaa/pink%20sharara%20with%20light%20golden%20embroidery%20with_.jpg'
        | split: ','
      -%}
      {%- for block in section.blocks -%}
        {%- assign star_count = block.settings.rating | plus: 0 -%}
        {%- assign fallback_img = rev_imgs[forloop.index0] | default: rev_imgs[0] -%}
        <div class="risaa-reviews__card" {{ block.shopify_attributes }}>
          {%- if block.settings.photo != blank -%}
            {{
              block.settings.photo
              | image_url: width: 700
              | image_tag: class: 'risaa-reviews__card-photo', loading: 'lazy', alt: block.settings.reviewer_name
            }}
          {%- else -%}
            <img
              src="{{ fallback_img }}"
              alt="{{ block.settings.reviewer_name }}"
              class="risaa-reviews__card-photo"
              loading="lazy"
            >
          {%- endif -%}

          <div class="risaa-reviews__card-body">
            <div class="risaa-reviews__card-top">
              <div class="risaa-reviews__card-stars">
                {%- for i in (1..5) -%}
                  <span class="risaa-reviews__card-star{% if i > star_count %} empty{% endif %}">★</span>
                {%- endfor -%}
              </div>
              {%- if block.settings.show_verified -%}
                <span class="risaa-reviews__verified">✓ Verified</span>
              {%- endif -%}
            </div>

            <p class="risaa-reviews__card-quote">{{ block.settings.review_text }}</p>

            <div class="risaa-reviews__card-bottom">
              {%- if block.settings.avatar != blank -%}
                {{
                  block.settings.avatar
                  | image_url: width: 100
                  | image_tag: class: 'risaa-reviews__avatar', alt: block.settings.reviewer_name
                }}
              {%- else -%}
                <div class="risaa-reviews__avatar-initial">{{ block.settings.reviewer_name | slice: 0 }}</div>
              {%- endif -%}
              <div>
                <p class="risaa-reviews__reviewer-name">{{ block.settings.reviewer_name }}</p>
                {%- if block.settings.reviewer_meta != blank -%}
                  <p class="risaa-reviews__reviewer-meta">{{ block.settings.reviewer_meta }}</p>
                {%- endif -%}
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="risaa-reviews__nav">
    <div class="risaa-reviews__dots" id="risaa-rev-dots-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="risaa-reviews__dot{% if forloop.first %} active{% endif %}"></div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  (function () {
    const id = '{{ section.id }}';
    const track = document.getElementById('risaa-rev-track-' + id);
    const dotsWrap = document.getElementById('risaa-rev-dots-' + id);
    const prevBtn = document.getElementById('risaa-rev-prev-' + id);
    const nextBtn = document.getElementById('risaa-rev-next-' + id);
    if (!track) return;

    const dots = dotsWrap ? Array.from(dotsWrap.querySelectorAll('.risaa-reviews__dot')) : [];
    let activeIdx = 0;

    function cardWidth() {
      const c = track.querySelector('.risaa-reviews__card');
      return c ? c.offsetWidth + parseInt(getComputedStyle(track).gap) : 368;
    }

    function goTo(idx) {
      const total = track.querySelectorAll('.risaa-reviews__card').length;
      activeIdx = Math.max(0, Math.min(idx, total - 1));
      track.scrollTo({ left: activeIdx * cardWidth(), behavior: 'smooth' });
      dots.forEach((d, i) => d.classList.toggle('active', i === activeIdx));
    }

    prevBtn && prevBtn.addEventListener('click', () => goTo(activeIdx - 1));
    nextBtn && nextBtn.addEventListener('click', () => goTo(activeIdx + 1));
    dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));

    let t;
    track.addEventListener('scroll', () => {
      clearTimeout(t);
      t = setTimeout(() => {
        activeIdx = Math.round(track.scrollLeft / cardWidth());
        dots.forEach((d, i) => d.classList.toggle('active', i === activeIdx));
      }, 80);
    });
  })();
</script>

{% schema %}
{
  "name": "Customer Reviews",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "Brides of RiSaa" },
    { "type": "text", "id": "aggregate_score", "label": "Aggregate Score", "default": "4.9" },
    { "type": "text", "id": "review_count", "label": "Review Count Text", "default": "200+ Happy Clients" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "photo", "label": "Customer Photo" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar" },
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "default": 5, "label": "Star Rating" },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "RiSaa made my dream lehenga a reality. The craftsmanship, the fit, the detailing — absolutely beyond what I imagined!"
        },
        { "type": "text", "id": "reviewer_name", "label": "Name", "default": "Priya S." },
        { "type": "text", "id": "reviewer_meta", "label": "Location / Occasion", "default": "Bridal · Ludhiana" },
        { "type": "checkbox", "id": "show_verified", "label": "Show Verified Badge", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": { "reviewer_name": "Priya S.", "reviewer_meta": "Bridal · Ludhiana", "rating": 5 }
        },
        {
          "type": "review",
          "settings": { "reviewer_name": "Anika R.", "reviewer_meta": "Sangeet · Delhi", "rating": 5 }
        },
        {
          "type": "review",
          "settings": { "reviewer_name": "Meera K.", "reviewer_meta": "Trousseau · Mumbai", "rating": 5 }
        },
        {
          "type": "review",
          "settings": { "reviewer_name": "Simran D.", "reviewer_meta": "Reception · Chandigarh", "rating": 5 }
        }
      ]
    }
  ]
}
{% endschema %}
