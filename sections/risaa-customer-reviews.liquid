{%- style -%}
  .risaa-reviews {
    padding: 80px 0 70px;
    background: #F4EADE;
    overflow: hidden;
  }

  /* ── Header ── */
  .risaa-reviews__header {
    text-align: center;
    margin-bottom: 36px;
    padding: 0 20px;
  }

  .risaa-reviews__eyebrow {
    display: none;
    font-family: 'Jost', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #f8b799;
    font-weight: 600;
    margin-bottom: 12px;
  }

  .risaa-reviews__title {
    font-family: var(--font-heading-family);
    font-size: 3rem;
    color: #6E1423;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 12px;
    line-height: 1.1;
    font-weight: 400;
  }

  .risaa-reviews__aggregate {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .risaa-reviews__agg-score {
    font-family: var(--font-heading-family);
    font-size: 1.8rem;
    font-weight: 400;
    color: #D4AF37;
    line-height: 1;
  }

  .risaa-reviews__agg-right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }

  .risaa-reviews__agg-stars {
    display: flex;
    gap: 2px;
  }

  .risaa-reviews__agg-star {
    color: #D4AF37;
    font-size: 1.1rem;
    line-height: 1;
  }

  .risaa-reviews__agg-label {
    font-family: var(--font-body-family);
    font-size: 1rem;
    color: rgba(110, 20, 35, 0.6);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Review image — full-bleed top of card ── */
  .risaa-reviews__card-image {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 12px 12px 0 0 !important;
    flex-shrink: 0;
  }

  /* ── Carousel ── */
  .risaa-reviews__carousel-outer {
    position: relative;
    overflow: hidden;
  }

  .risaa-reviews__carousel-outer::before,
  .risaa-reviews__carousel-outer::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 60px;
    z-index: 2;
    pointer-events: none;
  }

  .risaa-reviews__carousel-outer::before {
    left: 0;
    background: linear-gradient(to right, #F4EADE, transparent);
  }

  .risaa-reviews__carousel-outer::after {
    right: 0;
    background: linear-gradient(to left, #F4EADE, transparent);
  }

  .risaa-reviews__track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 8px 60px 20px;
  }

  .risaa-reviews__track::-webkit-scrollbar {
    display: none;
  }

  /* ── Card ── */
  .risaa-reviews__card {
    flex: 0 0 419px;
    scroll-snap-align: start;
    background: #fff;
    border: 1px solid rgba(216, 167, 100, 0.24);
    border-radius: 12px 12px 0 0 !important;
    box-shadow: none;
    transition: border-color 0.25s ease, transform 0.25s ease;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .risaa-reviews__card:hover {
    border-color: rgba(216, 167, 100, 0.7);
    transform: translateY(-3px);
  }

  /* padded body below the image */
  .risaa-reviews__card-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 16px 18px 18px;
    flex: 1;
  }

  /* Top row: avatar + name + meta */
  .risaa-reviews__card-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .risaa-reviews__avatar-initial {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Jost', sans-serif;
    font-size: 1.5rem;
    font-weight: 500;
    color: #fff;
    flex-shrink: 0;
    text-transform: uppercase;
  }

  /* Google-style avatar colours cycling through 4 */
  .risaa-reviews__card:nth-child(4n + 1) .risaa-reviews__avatar-initial {
    background: #4285f4;
  }
  .risaa-reviews__card:nth-child(4n + 2) .risaa-reviews__avatar-initial {
    background: #ea4335;
  }
  .risaa-reviews__card:nth-child(4n + 3) .risaa-reviews__avatar-initial {
    background: #34a853;
  }
  .risaa-reviews__card:nth-child(4n + 4) .risaa-reviews__avatar-initial {
    background: #fbbc04;
  }

  .risaa-reviews__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .risaa-reviews__card-meta {
    flex: 1;
    min-width: 0;
  }

  .risaa-reviews__reviewer-name {
    font-family: 'Jost', sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    color: #202124;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .risaa-reviews__reviewer-meta {
    font-family: 'Jost', sans-serif;
    font-size: 1.1rem;
    color: #70757a;
    margin: 2px 0 0;
  }

  /* Stars row */
  .risaa-reviews__card-stars-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .risaa-reviews__card-stars {
    display: flex;
    gap: 1px;
  }

  .risaa-reviews__card-star {
    color: #D4AF37;
    font-size: 1.15rem;
    line-height: 1;
  }

  .risaa-reviews__card-star.empty {
    color: #dadce0;
  }

  .risaa-reviews__card-date {
    display: none;
  }

  /* Review text */
  .risaa-reviews__card-quote-wrapper {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .risaa-reviews__card-quote {
    font-family: var(--font-body-family);
    font-size: 1.18rem;
    line-height: 1.55;
    color: rgba(18, 18, 18, 0.74);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .risaa-reviews__card-quote.is-expanded {
    -webkit-line-clamp: unset;
    display: block;
  }

  .risaa-reviews__read-more {
    background: none;
    border: none;
    color: #6E1423;
    font-family: var(--font-body-family);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    padding: 0;
    margin-top: 6px;
    text-decoration: underline;
    display: none; /* Shown by JS if overflowing */
  }

  .risaa-reviews__read-more.is-visible {
    display: inline-block;
  }

  .risaa-reviews__signoff {
    color: rgba(110, 20, 35, 0.62);
    font-family: var(--font-heading-family);
    font-size: 1.25rem;
    font-style: italic;
    letter-spacing: 0.04em;
    margin: 2px 0 0;
    text-align: right;
  }

  /* ── Dots ── */
  .risaa-reviews__nav {
    display: flex;
    justify-content: center;
    margin-top: 32px;
  }

  .risaa-reviews__dots {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .risaa-reviews__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #dadce0;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .risaa-reviews__dot.active {
    background: #6E1423;
    width: 20px;
    border-radius: 3px;
  }

  @media screen and (max-width: 989px) {
    .risaa-reviews__card {
      flex: 0 0 389px;
    }
  }

  @media screen and (max-width: 749px) {
    .risaa-reviews {
      padding: 50px 0 44px;
    }
    .risaa-reviews__title {
      font-size: 2.2rem;
    }
    .risaa-reviews__card {
      flex: 0 0 367px;
    }
    .risaa-reviews__track {
      padding: 8px 24px 16px;
      gap: 12px;
    }
  }
{%- endstyle -%}

{%- assign date_labels = '1 week ago,2 weeks ago,1 month ago,2 months ago,3 months ago,4 months ago,5 months ago,6 months ago'
  | split: ','
-%}

<section class="risaa-reviews reveal-on-scroll" id="risaa-reviews-{{ section.id }}">
  <div class="risaa-reviews__header">
    <h2 class="risaa-reviews__title">{{ section.settings.title }}</h2>
    <div class="risaa-reviews__aggregate">
      <span class="risaa-reviews__agg-score">{{ section.settings.aggregate_score }}</span>
      <div class="risaa-reviews__agg-right">
        <div class="risaa-reviews__agg-stars">
          {%- for i in (1..5) -%}
            <span class="risaa-reviews__agg-star">★</span>
          {%- endfor -%}
        </div>
        <span class="risaa-reviews__agg-label">{{ section.settings.review_count }}</span>
      </div>
    </div>
  </div>

  <div class="risaa-reviews__carousel-outer">
    <div class="risaa-reviews__track" id="risaa-rev-track-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- assign star_count = block.settings.rating | plus: 0 -%}
        {%- assign date_label = date_labels[forloop.index0] | default: '6 months ago' -%}
        <div class="risaa-reviews__card" {{ block.shopify_attributes }}>
          <!-- Review image sits at top, full-bleed -->
          {%- if block.settings.review_image != blank -%}
            {{
              block.settings.review_image
              | image_url: width: 600
              | image_tag: class: 'risaa-reviews__card-image', alt: block.settings.reviewer_name
            }}
          {%- else -%}
            {%- assign _rev_imgs = 'https://ik.imagekit.io/flashspdstr/risaa/bridal.jpg,https://ik.imagekit.io/flashspdstr/risaa/sangeet.jpg,https://ik.imagekit.io/flashspdstr/risaa/couture.jpg,https://ik.imagekit.io/flashspdstr/risaa/reception.jpg,https://ik.imagekit.io/flashspdstr/risaa/pret.jpg,https://ik.imagekit.io/flashspdstr/risaa/trousseau.png,https://ik.imagekit.io/flashspdstr/risaa/Ruby%20primary.jpg,https://ik.imagekit.io/flashspdstr/risaa/pink%20sharara%20with%20light%20golden%20embroidery%20with_.jpg'
              | split: ','
            -%}
            {%- assign _rev_img_idx = forloop.index0 | modulo: 8 -%}
            <img
              class="risaa-reviews__card-image"
              src="{{ _rev_imgs[_rev_img_idx] }}"
              alt="{{ block.settings.reviewer_name }}"
              loading="lazy"
            >
          {%- endif -%}

          <!-- Padded body -->
          <div class="risaa-reviews__card-body">
            <!-- Stars -->
            <div class="risaa-reviews__card-stars-row">
              <div class="risaa-reviews__card-stars">
                {%- for i in (1..5) -%}
                  <span class="risaa-reviews__card-star{% if i > star_count %} empty{% endif %}">★</span>
                {%- endfor -%}
              </div>
              <span class="risaa-reviews__card-date">{{ date_label }}</span>
            </div>

            <!-- Review text -->
            <div class="risaa-reviews__card-quote-wrapper">
              <p class="risaa-reviews__card-quote">{{ block.settings.review_text | strip_html }}</p>
              <button type="button" class="risaa-reviews__read-more" aria-expanded="false">Read More</button>
            </div>
            <p class="risaa-reviews__signoff">- {{ block.settings.reviewer_name }}</p>
          </div>
          <!-- /.card-body -->
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="risaa-reviews__nav">
    <div class="risaa-reviews__dots" id="risaa-rev-dots-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="risaa-reviews__dot{% if forloop.first %} active{% endif %}"></div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  (function () {
    const id = '{{ section.id }}';
    const track = document.getElementById('risaa-rev-track-' + id);
    const dotsWrap = document.getElementById('risaa-rev-dots-' + id);
    if (!track) return;

    const dots = dotsWrap ? Array.from(dotsWrap.querySelectorAll('.risaa-reviews__dot')) : [];
    const originalCards = Array.from(track.querySelectorAll('.risaa-reviews__card'));
    const originalCount = originalCards.length;
    let activeIdx = 0;
    let autoTimer = null;
    let isPaused = false;
    let resetTimer = null;
    let isResetting = false;

    originalCards.forEach((card) => {
      const clone = card.cloneNode(true);
      clone.setAttribute('aria-hidden', 'true');
      clone.dataset.carouselClone = 'true';
      track.appendChild(clone);
    });

    function total() {
      return originalCount;
    }

    function cardWidth() {
      const c = track.querySelector('.risaa-reviews__card');
      return c ? c.offsetWidth + parseInt(getComputedStyle(track).gap) : 316;
    }

    function checkOverflow() {
      track.querySelectorAll('.risaa-reviews__card-quote').forEach((quote) => {
        const btn = quote.nextElementSibling;
        if (btn && btn.classList.contains('risaa-reviews__read-more')) {
          // Temporarily remove clamp to check full height
          const wasExpanded = quote.classList.contains('is-expanded');
          if (!wasExpanded) {
            const isOverflowing = quote.scrollHeight > quote.clientHeight;
            btn.classList.toggle('is-visible', isOverflowing);
          }
        }
      });
    }

    function goTo(idx) {
      const n = total();
      if (!n) return;

      clearTimeout(resetTimer);

      if (idx < 0) {
        isResetting = true;
        track.scrollLeft = n * cardWidth();
        idx = n - 1;
        requestAnimationFrame(() => {
          isResetting = false;
          goTo(idx);
        });
        return;
      }

      activeIdx = idx;
      track.scrollTo({ left: idx * cardWidth(), behavior: 'smooth' });
      dots.forEach((d, i) => d.classList.toggle('active', i === activeIdx));

      if (idx >= n) {
        activeIdx = 0;
        dots.forEach((d, i) => d.classList.toggle('active', i === 0));
        resetTimer = setTimeout(() => {
          isResetting = true;
          track.scrollLeft = 0;
          requestAnimationFrame(() => {
            isResetting = false;
          });
        }, 520);
      }
    }

    function next() {
      goTo(activeIdx + 1);
    }

    function startAuto() {
      clearInterval(autoTimer);
      autoTimer = setInterval(() => {
        if (!isPaused) next();
      }, 2000);
    }

    /* dot clicks */
    dots.forEach((d, i) =>
      d.addEventListener('click', () => {
        goTo(i);
        isPaused = true;
        clearTimeout(window['_risaa_resume_' + id]);
        window['_risaa_resume_' + id] = setTimeout(() => {
          isPaused = false;
        }, 6000);
      })
    );

    /* pause on hover */
    track.addEventListener('mouseenter', () => {
      isPaused = true;
    });
    track.addEventListener('mouseleave', () => {
      isPaused = false;
    });

    /* pause on touch / manual drag */
    track.addEventListener(
      'touchstart',
      () => {
        isPaused = true;
      },
      { passive: true }
    );
    track.addEventListener(
      'touchend',
      () => {
        clearTimeout(window['_risaa_resume_' + id]);
        window['_risaa_resume_' + id] = setTimeout(() => {
          isPaused = false;
        }, 4000);
      },
      { passive: true }
    );

    /* sync dot on manual scroll */
    let scrollT;
    track.addEventListener('scroll', () => {
      if (isResetting) return;
      clearTimeout(scrollT);
      scrollT = setTimeout(() => {
        const n = total();
        if (!n) return;
        const rawIdx = Math.round(track.scrollLeft / cardWidth());
        activeIdx = rawIdx % n;
        dots.forEach((d, i) => d.classList.toggle('active', i === activeIdx));

        if (rawIdx >= n) {
          isResetting = true;
          track.scrollLeft = (rawIdx - n) * cardWidth();
          requestAnimationFrame(() => {
            isResetting = false;
          });
        }
      }, 80);
    });

    /* Read More Toggle */
    track.addEventListener('click', (e) => {
      if (e.target.classList.contains('risaa-reviews__read-more')) {
        const btn = e.target;
        const quote = btn.previousElementSibling;
        const isExpanded = quote.classList.toggle('is-expanded');
        btn.textContent = isExpanded ? 'Read Less' : 'Read More';
        btn.setAttribute('aria-expanded', isExpanded);
        isPaused = true;
      }
    });

    window.addEventListener('resize', checkOverflow);
    checkOverflow();

    startAuto();
  })();
</script>

{% schema %}
{
  "name": "Customer Reviews",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "BEAUTIES OF RISAA" },
    { "type": "text", "id": "aggregate_score", "label": "Aggregate Score", "default": "4.9" },
    { "type": "text", "id": "review_count", "label": "Review Count Text", "default": "200+ Reviews" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "review_image", "label": "Review Image" },
        { "type": "image_picker", "id": "avatar", "label": "Avatar Photo" },
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "default": 5, "label": "Star Rating" },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "RiSaa made my dream lehenga a reality. The craftsmanship, the fit, the detailing — absolutely beyond what I imagined!"
        },
        { "type": "text", "id": "reviewer_name", "label": "Name", "default": "Priya S." },
        { "type": "text", "id": "reviewer_meta", "label": "Location / Occasion", "default": "Bridal · Ludhiana" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": { "reviewer_name": "Priya S.", "reviewer_meta": "Bridal · Ludhiana", "rating": 5 }
        },
        {
          "type": "review",
          "settings": { "reviewer_name": "Anika R.", "reviewer_meta": "Sangeet · Delhi", "rating": 5 }
        },
        {
          "type": "review",
          "settings": { "reviewer_name": "Meera K.", "reviewer_meta": "Trousseau · Mumbai", "rating": 5 }
        },
        {
          "type": "review",
          "settings": { "reviewer_name": "Simran D.", "reviewer_meta": "Reception · Chandigarh", "rating": 5 }
        }
      ]
    }
  ]
}
{% endschema %}
