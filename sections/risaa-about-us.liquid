{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Assistant:wght@300;400;600&display=swap');

  .risaa-about-wrapper {
    background-color: var(--brand-text);
    color: var(--brand-dark);
    overflow: hidden;
  }

  /* === HERO === */
  .risaa-about-hero {
    width: 100%;
    min-height: 70vh;
    background: linear-gradient(135deg, var(--brand-main) 0%, #6b1014 60%, #2c0608 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .risaa-about-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('{{ 'white_leaves_decoration.png' | asset_url }}');
    background-repeat: repeat;
    background-size: 120px auto;
    opacity: 0.06;
  }

  .risaa-about-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: var(--brand-text);
    padding: 4rem 2rem;
  }

  .risaa-about-hero-content .eyebrow {
    font-family: var(--font-body);
    font-size: 1.2rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--brand-undertone-2);
    margin-bottom: 1.5rem;
    display: block;
  }

  .risaa-about-hero-content h1 {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 8vw, 8rem);
    color: var(--brand-text);
    margin-bottom: 1rem;
    line-height: 1.1;
    letter-spacing: 0.05em;
  }

  .risaa-about-hero-content .tagline {
    font-size: 1.6rem;
    letter-spacing: 0.2em;
    color: var(--brand-undertone-2);
    margin-bottom: 2.5rem;
    font-style: italic;
  }

  .risaa-about-categories {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .risaa-about-categories span {
    border: 1px solid rgba(255, 255, 255, 0.4);
    color: var(--brand-text);
    padding: 0.5rem 1.5rem;
    font-size: 1.1rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition: all 0.3s ease;
  }

  .risaa-about-categories span:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  /* === BRAND PILLARS === */
  .risaa-about-pillars {
    background: var(--brand-undertone-2);
    padding: 5rem 2rem;
    text-align: center;
  }

  .risaa-pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .risaa-pillar {
    padding: 3rem 2rem;
    background: var(--brand-text);
    border-top: 4px solid var(--brand-main);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .risaa-pillar:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(154, 28, 32, 0.15);
  }

  .risaa-pillar-icon {
    font-size: 3rem;
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    margin: 0 auto 1.2rem;
    background: linear-gradient(135deg, var(--brand-undertone-2) 0%, var(--brand-text) 100%);
    border-radius: 50%;
    box-shadow: 0 8px 20px rgba(154, 28, 32, 0.2);
  }

  .risaa-pillar-icon svg {
    width: 40px;
    height: 40px;
    fill: var(--brand-main);
  }

  .risaa-pillar h3 {
    font-size: 1.8rem;
    color: var(--brand-main);
    margin-bottom: 0.8rem;
  }

  .risaa-pillar p {
    font-size: 1.3rem;
    color: #555;
    line-height: 1.7;
  }

  /* === STORY SECTION === */
  .risaa-about-story {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 500px;
  }

  .risaa-story-text {
    padding: 6rem 5rem;
    background: var(--brand-main);
    color: var(--brand-text);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .risaa-story-text .eyebrow {
    font-size: 1.1rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--brand-undertone-2);
    margin-bottom: 1.5rem;
  }

  .risaa-story-text h2 {
    font-size: 3.5rem;
    color: var(--brand-text);
    margin-bottom: 2rem;
    line-height: 1.2;
  }

  .risaa-story-text p {
    font-size: 1.4rem;
    line-height: 1.9;
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 1.5rem;
  }

  .risaa-story-image {
    position: relative;
    overflow: hidden;
    min-height: 400px;
    background: var(--brand-undertone-1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .risaa-story-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .risaa-story-image-placeholder {
    text-align: center;
    color: var(--brand-text);
    padding: 2rem;
    opacity: 0.7;
  }

  /* === INFO CARDS === */
  .risaa-about-info {
    padding: 6rem 2rem;
    background: var(--brand-text);
    max-width: 1200px;
    margin: 0 auto;
  }

  .risaa-about-info h2 {
    text-align: center;
    font-size: 3rem;
    color: var(--brand-main);
    margin-bottom: 4rem;
  }

  .risaa-info-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .risaa-info-card {
    background: var(--brand-undertone-2);
    padding: 3rem;
    border-radius: 4px;
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    transition: transform 0.3s ease;
  }

  .risaa-info-card:hover {
    transform: translateY(-4px);
  }

  .risaa-info-card-icon {
    font-size: 2.8rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, var(--brand-main) 0%, #6b1014 100%);
    border-radius: 12px;
    box-shadow: 0 6px 15px rgba(154, 28, 32, 0.2);
  }

  .risaa-info-card-icon svg {
    width: 30px;
    height: 30px;
    fill: var(--brand-text);
  }

  .risaa-info-card h4 {
    font-size: 1.5rem;
    color: var(--brand-main);
    margin-bottom: 0.8rem;
  }

  .risaa-info-card p,
  .risaa-info-card a {
    font-size: 1.3rem;
    color: #444;
    line-height: 1.7;
    text-decoration: none;
  }

  .risaa-info-card a:hover {
    color: var(--brand-main);
  }

  /* === SOCIAL SECTION === */
  .risaa-about-social {
    background: var(--brand-main);
    padding: 5rem 2rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .risaa-about-social::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('{{ 'white_leaves_decoration.png' | asset_url }}');
    background-repeat: repeat;
    background-size: 100px auto;
    opacity: 0.05;
  }

  .risaa-about-social h2 {
    font-size: 3rem;
    color: var(--brand-text);
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }

  .risaa-about-social p {
    font-size: 1.4rem;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 3rem;
    position: relative;
    z-index: 1;
  }

  .risaa-social-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .risaa-social-link {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.2rem 2.5rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: var(--brand-text);
    text-decoration: none;
    font-size: 1.3rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: all 0.3s ease;
    backdrop-filter: blur(4px);
  }

  .risaa-social-link:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-3px);
  }

  .risaa-social-link .social-icon {
    font-size: 1.8rem;
  }

  .risaa-social-link .social-icon svg {
    width: 24px;
    height: 24px;
    fill: currentColor;
  }

  /* === MAPS SECTION === */
  .risaa-about-maps {
    padding: 4rem 2rem;
    background: var(--brand-text);
    max-width: 1200px;
    margin: 0 auto;
  }

  .risaa-about-maps h2 {
    text-align: center;
    font-size: 2.5rem;
    color: var(--brand-main);
    margin-bottom: 2rem;
  }

  .risaa-map-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .risaa-map-container {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  .risaa-map-container iframe {
    width: 100%;
    height: 400px;
    border: none;
  }

  .risaa-map-address {
    padding: 2rem;
    background: var(--brand-undertone-2);
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  /* === YOUTUBE SHORTS CAROUSEL === */
  .risaa-youtube-shorts {
    padding: 5rem 2rem;
    background: var(--brand-undertone-2);
    text-align: center;
  }

  .risaa-youtube-shorts h2 {
    font-size: 2.5rem;
    color: var(--brand-main);
    margin-bottom: 0.5rem;
  }

  .risaa-youtube-shorts p {
    font-size: 1.2rem;
    color: #666;
    margin-bottom: 2.5rem;
  }

  .risaa-shorts-carousel {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 1rem 2rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
    max-width: 1400px;
    margin: 0 auto;
  }

  .risaa-shorts-carousel::-webkit-scrollbar {
    display: none;
  }

  .risaa-short-card {
    flex: 0 0 200px;
    scroll-snap-align: start;
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
    transition: transform 0.3s ease;
  }

  .risaa-short-card:hover {
    transform: scale(1.05);
  }

  .risaa-short-card iframe {
    width: 200px;
    height: 355px;
    border: none;
    display: block;
  }

  .risaa-shorts-nav {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .risaa-shorts-nav button {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: 2px solid var(--brand-main);
    background: transparent;
    color: var(--brand-main);
    font-size: 1.5rem;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .risaa-shorts-nav button:hover {
    background: var(--brand-main);
    color: var(--brand-text);
  }

  @media screen and (max-width: 749px) {
    .risaa-shorts-carousel {
      gap: 1rem;
      padding: 1rem;
    }

    .risaa-short-card {
      flex: 0 0 160px;
    }

    .risaa-short-card iframe {
      width: 160px;
      height: 284px;
    }
  }

  /* === YOUTUBE SECTION === */
  .risaa-about-youtube {
    padding: 5rem 2rem;
    background: var(--brand-undertone-2);
    text-align: center;
  }

  .risaa-about-youtube h2 {
    font-size: 2.5rem;
    color: var(--brand-main);
    margin-bottom: 1rem;
  }

  .risaa-about-youtube p {
    font-size: 1.3rem;
    color: #555;
    margin-bottom: 2.5rem;
  }

  .risaa-youtube-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .risaa-youtube-card {
    background: var(--brand-text);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .risaa-youtube-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
  }

  .risaa-youtube-card iframe {
    width: 100%;
    height: 200px;
    border: none;
  }

  .risaa-youtube-card-content {
    padding: 1.5rem;
  }

  .risaa-youtube-card h4 {
    font-size: 1.2rem;
    color: var(--brand-main);
    margin-bottom: 0.5rem;
  }

  .risaa-youtube-card p {
    font-size: 1rem;
    color: #666;
    margin-bottom: 1rem;
  }

  .risaa-youtube-card a {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    background: var(--brand-main);
    color: var(--brand-text);
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    transition: background 0.3s ease;
  }

  .risaa-youtube-card a:hover {
    background: #6b1014;
  }

  /* === COLLAB BANNER === */
  .risaa-collab-banner {
    background: var(--brand-undertone-2);
    padding: 4rem 2rem;
    text-align: center;
  }

  .risaa-collab-banner h3 {
    font-size: 2.5rem;
    color: var(--brand-main);
    margin-bottom: 1rem;
  }

  .risaa-collab-banner p {
    font-size: 1.4rem;
    color: #555;
    margin-bottom: 2rem;
  }

  .risaa-collab-banner a.btn-premium {
    font-size: 1.2rem;
    letter-spacing: 0.2em;
  }

  /* === RESPONSIVE === */
  @media screen and (max-width: 768px) {
    .risaa-about-hero-content h1 {
      font-size: 4rem;
    }
    .risaa-pillars-grid {
      grid-template-columns: 1fr;
    }
    .risaa-about-story {
      grid-template-columns: 1fr;
    }
    .risaa-story-text {
      padding: 4rem 2rem;
    }
    .risaa-info-grid {
      grid-template-columns: 1fr;
    }
    .risaa-story-image {
      min-height: 280px;
    }
  }
{%- endstyle -%}

<div class="risaa-about-wrapper">
  <!-- HERO -->
  <div class="risaa-about-hero">
    <div class="risaa-about-hero-content reveal-on-scroll">
      <span class="eyebrow">Ludhiana, Punjab • Worldwide Shipping</span>
      <h1>RiSaa</h1>
      <p class="tagline">Design Studio by Rima</p>
      <p style="font-size:1.6rem; color: var(--brand-undertone-2); letter-spacing:0.15em;">
        Couture &bull; Bridal &bull; Prêt &bull; Fusion
      </p>
      <p style="font-size:1.3rem; margin-top:1.5rem; color:rgba(255,255,255,0.75); font-style:italic;">
        "Artfully custom-crafted for individuality"
      </p>
      <div class="risaa-about-categories" style="margin-top:3rem;">
        {%- assign about_cats = 'Bridal,Couture,Pret,Trousseau,Indian Traditional,Western,Indo-Western' | split: ',' -%}
        {% for cat in about_cats %}
          <span>{{ cat }}</span>
        {% endfor %}
      </div>
    </div>
  </div>

  <!-- BRAND PILLARS -->
  <div class="risaa-about-pillars reveal-on-scroll">
    <div class="risaa-pillars-grid">
      <div class="risaa-pillar">
        <span class="risaa-pillar-icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
        </span>
        <h3>Made-to-Order Bridal</h3>
        <p>
          Every bridal piece is crafted exclusively for you — designed to fit your vision, your body, and your story.
        </p>
      </div>
      <div class="risaa-pillar" style="transition-delay:0.1s;">
        <span class="risaa-pillar-icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
          </svg>
        </span>
        <h3>Accessible Luxury</h3>
        <p>
          Premium quality and stunning design, made available to everyone. Fashion that celebrates you without
          compromise.
        </p>
      </div>
      <div class="risaa-pillar" style="transition-delay:0.2s;">
        <span class="risaa-pillar-icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
          </svg>
        </span>
        <h3>Slow Fashion</h3>
        <p>
          We believe in timeless over trendy. Each piece is crafted with intention, care, and a commitment to lasting
          elegance.
        </p>
      </div>
    </div>
  </div>

  <!-- OUR STORY -->
  <div class="risaa-about-story">
    <div class="risaa-story-text reveal-on-scroll">
      <span class="eyebrow">Our Story</span>
      <h2>More Than Clothes. We Craft Experiences.</h2>
      <p>Hello everyone! RiSaa is a design studio located in Ludhiana, Punjab — and we ship orders worldwide.</p>
      <p>
        Here at RiSaa, we are not just about clothes. We're about crafting experiences and catering to your individual
        preferences. We believe in creating outfits that speak volumes about your unique style and fit your budget as
        well.
      </p>
      <p>Every stitch is a testament to our commitment to your individuality.</p>
    </div>
    <div class="risaa-story-image">
      {% if section.settings.story_image != blank %}
        {{ section.settings.story_image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
      {% else %}
        <div class="risaa-story-image-placeholder">
          <p style="font-size:1.4rem; font-style:italic;">Add your studio or fashion photo here via the Theme Editor</p>
        </div>
      {% endif %}
    </div>
  </div>

  <!-- VISIT & CONTACT INFO -->
  <div class="risaa-about-info">
    <h2 class="reveal-on-scroll">Find Us &amp; Get In Touch</h2>
    <div class="risaa-info-grid">
      <div class="risaa-info-card reveal-on-scroll">
        <span class="risaa-info-card-icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
          </svg>
        </span>
        <div>
          <h4>Our Studio</h4>
          <p>
            117-B, Jyoti Colony, Part B, Model Town Extension,<br>
            Model Town, Ludhiana, Punjab 141002
          </p>
          <a
            href="https://maps.app.goo.gl/GijLheNTVLk7mghM9"
            target="_blank"
            rel="noopener"
            style="color:var(--brand-main); font-weight:600; margin-top:0.8rem; display:inline-block;"
            >Open in Google Maps →</a
          >
        </div>
      </div>

      <div class="risaa-info-card reveal-on-scroll" style="transition-delay:0.1s;">
        <span class="risaa-info-card-icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"/>
          </svg>
        </span>
        <div>
          <h4>Studio Hours</h4>
          <p>
            Monday – Saturday<br>
            9:00 AM to 6:30 PM
          </p>
          <p style="margin-top:0.8rem; color: var(--brand-main); font-style:italic;">Closed on Sundays</p>
        </div>
      </div>

      <div class="risaa-info-card reveal-on-scroll" style="transition-delay:0.15s;">
        <span class="risaa-info-card-icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
        </span>
        <div>
          <h4>Call or WhatsApp</h4>
          <a
            href="tel:+919501032126"
            style="font-size:1.8rem; font-weight:600; color:var(--brand-main); display:block; margin-bottom:0.5rem;"
            >+91 95010 32126</a
          >
          <a href="https://wa.me/919501032126" target="_blank" rel="noopener" style="color:#25D366; font-weight:600;"
            >Chat on WhatsApp →</a
          >
        </div>
      </div>

      <div class="risaa-info-card reveal-on-scroll" style="transition-delay:0.2s;">
        <span class="risaa-info-card-icon">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
