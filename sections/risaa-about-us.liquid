    function risaaShortsScroll(direction) {
      const carousel = document.getElementById('risaa-shorts-carousel');
      if (!carousel) return;
      const scrollAmount = 220;
      carousel.scrollBy({ left: direction * scrollAmount, behavior: 'smooth' });
