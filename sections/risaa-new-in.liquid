{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .risaa-new-in {
    padding: 2.5rem 0;
    background: var(--brand-text);
    position: relative;
    overflow: hidden;
  }

  .risaa-new-in__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .risaa-new-in__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .risaa-new-in__eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--brand-main);
    box-shadow: 0 0 0 3px rgba(154, 28, 32, 0.2);
  }

  .risaa-new-in__eyebrow-text {
    font-family: var(--font-body);
    font-size: 1.2rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--brand-main);
    font-weight: 600;
  }

  .risaa-new-in__title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    color: var(--brand-main);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }

  .risaa-new-in__subtitle {
    color: #666;
    font-size: 1.4rem;
    margin-top: 0.5rem;
    font-family: var(--font-body);
  }

  .risaa-new-in__view-all {
    text-align: center;
    margin-top: 2.5rem;
  }

  @media screen and (max-width: 749px) {
    .risaa-new-in {
      padding: 1.5rem 0;
    }
    .risaa-new-in__title {
      font-size: 2rem;
    }
  }
{%- endstyle -%}

<section class="risaa-new-in reveal-on-scroll" id="risaa-new-in-{{ section.id }}">
  <div class="page-width">
    <div class="risaa-new-in__header" data-anim="fade-up">
      <h2 class="risaa-new-in__title">{{ section.settings.title }}</h2>
    </div>

    <ul
      class="grid product-grid contains-card contains-card--product grid--4-col-desktop grid--2-col-tablet-down"
      role="list"
      data-anim-stagger
      data-anim-delay="0.05"
      data-anim-step="0.06"
    >
      {% if section.settings.collection != blank and section.settings.collection.products.size > 0 %}
        {%- assign skip_card_product_styles = false -%}
        {% for product in section.settings.collection.products limit: 4 %}
          <li class="grid__item">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: 'portrait',
              show_secondary_image: true,
              show_vendor: false,
              show_rating: false,
              lazy_load: true,
              skip_styles: skip_card_product_styles,
              section_id: section.id
            %}
            {%- assign skip_card_product_styles = true -%}
          </li>
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <li class="grid__item">
            {%- assign placeholder_image = 'product-apparel-' | append: i -%}
            {% render 'card-product', media_aspect_ratio: 'portrait', placeholder_image: placeholder_image %}
          </li>
        {% endfor %}
      {% endif %}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "New In",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "New In" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Fresh from the atelier, made with love" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "url", "id": "view_all_link", "label": "View All Link" }
  ],
  "presets": [
    {
      "name": "New In",
      "settings": { "title": "New In", "subtitle": "Fresh from the atelier, made with love" }
    }
  ]
}
{% endschema %}
