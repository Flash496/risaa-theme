{%- style -%}
  .risaa-new-in {
    padding: 0 0 30px 0;
    background: #f4eade;
    position: relative;
    overflow: hidden;
  }

  .risaa-new-in__header {
    text-align: center;
    margin-bottom: 10px;
    padding-top: 20px;
    padding-bottom: 15px;
  }

  .risaa-new-in__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .risaa-new-in__eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--brand-main);
    box-shadow: 0 0 0 3px rgba(110, 20, 35, 0.2);
  }

  .risaa-new-in__eyebrow-text {
    font-family: var(--font-body);
    font-size: 1.2rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--brand-main);
    font-weight: 600;
  }

  .risaa-new-in__title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    color: var(--brand-main);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 1.2;
  }

  .risaa-new-in__subtitle {
    color: #666;
    font-size: 1.4rem;
    margin-top: 0.5rem;
    font-family: var(--font-body);
  }

  .risaa-new-in__view-all {
    text-align: center;
    margin-top: 2.5rem;
  }

  .risaa-new-in__carousel {
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
    padding-inline: 60px;
    clip-path: inset(0 60px);
  }

  .risaa-new-in__track {
    --risaa-carousel-gap: max(0px, calc(var(--grid-desktop-horizontal-spacing) - 10px));
    display: flex;
    flex-wrap: nowrap;
    gap: var(--risaa-carousel-gap);
    margin: 0;
    padding: 0;
    list-style: none;
    transition: transform 0.35s ease;
    will-change: transform;
  }

  .risaa-new-in__item {
    flex: 0 0 calc((100% - (var(--risaa-carousel-gap) * 3)) / 4);
    width: calc((100% - (var(--risaa-carousel-gap) * 3)) / 4);
    max-width: calc((100% - (var(--risaa-carousel-gap) * 3)) / 4);
    min-width: 0;
    list-style: none;
  }

  .risaa-new-in__controls {
    display: flex;
    position: absolute;
    top: 50%;
    left: 0.8rem;
    right: 0.8rem;
    z-index: 2;
    justify-content: space-between;
    gap: 0;
    margin: 0;
    transform: translateY(calc(-50% - 20px));
    pointer-events: none;
  }

  .risaa-new-in__button {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 3.6rem;
    height: 3.6rem;
    border: 0;
    background: transparent;
    color: #fff;
    box-shadow: none;
    pointer-events: auto;
    font-size: 3.6rem;
    font-weight: 700;
    line-height: 1;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.28);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .risaa-new-in__controls {
    left: 60px;
    right: 60px;
  }

  .risaa-new-in__button:hover {
    transform: scale(1.08);
  }

  .risaa-new-in__button[disabled] {
    opacity: 0.35;
  }

  .risaa-new-in__button .icon {
    display: none;
  }

  .risaa-new-in__button--prev .icon {
    transform: rotate(90deg);
  }

  .risaa-new-in__button--next .icon {
    transform: rotate(-90deg);
  }

  @media screen and (max-width: 749px) {
    .risaa-new-in {
      padding: 0;
    }
    .risaa-new-in__title {
      font-size: 2rem;
    }
    .risaa-new-in__track {
      --risaa-carousel-gap: max(0px, calc(var(--grid-mobile-horizontal-spacing) - 10px));
    }
    .risaa-new-in__item {
      flex-basis: calc((100% - var(--risaa-carousel-gap)) / 2);
      width: calc((100% - var(--risaa-carousel-gap)) / 2);
      max-width: calc((100% - var(--risaa-carousel-gap)) / 2);
    }
  }
{%- endstyle -%}

<section class="risaa-new-in reveal-on-scroll" id="risaa-new-in-{{ section.id }}">
  <div class="page-width">
    <div class="risaa-new-in__header">
      <h2 class="risaa-new-in__title">{{ section.settings.title }}</h2>
    </div>

    <div
      class="risaa-new-in__carousel"
      data-anim-stagger
      data-anim-delay="0.05"
      data-anim-step="0.06"
      data-risaa-carousel
    >
      <ul
        class="product-grid contains-card contains-card--product risaa-new-in__track"
        role="list"
        aria-label="{{ 'general.slider.name' | t }}"
        data-risaa-carousel-track
      >
        {% if section.settings.collection != blank and section.settings.collection.products.size > 0 %}
          {%- assign skip_card_product_styles = false -%}
          {% for product in section.settings.collection.products limit: 8 %}
            {%- assign curated_card_image_index = forloop.index0 | plus: 4 -%}
            <li class="risaa-new-in__item">
              {% render 'card-product',
                card_product: product,
                media_aspect_ratio: 'portrait',
                show_secondary_image: true,
                show_vendor: false,
                show_rating: false,
                lazy_load: true,
                skip_styles: skip_card_product_styles,
                section_id: section.id,
                landing_card_price: 'true',
                custom_card_image_index: curated_card_image_index
              %}
              {%- assign skip_card_product_styles = true -%}
            </li>
          {% endfor %}
        {% else %}
          {% for i in (1..8) %}
            <li class="risaa-new-in__item">
              {%- assign placeholder_index = i | plus: 4 -%}
              {%- assign placeholder_image = 'product-apparel-' | append: placeholder_index -%}
              {% render 'card-product',
                media_aspect_ratio: 'portrait',
                placeholder_image: placeholder_image,
                landing_card_price: 'true'
              %}
            </li>
          {% endfor %}
        {% endif %}
      </ul>
      <div class="risaa-new-in__controls">
        <button type="button" class="risaa-new-in__button risaa-new-in__button--prev" aria-label="{{ 'general.slider.previous_slide' | t }}" data-risaa-carousel-prev>
          <span aria-hidden="true">&#8249;</span>
        </button>
        <button type="button" class="risaa-new-in__button risaa-new-in__button--next" aria-label="{{ 'general.slider.next_slide' | t }}" data-risaa-carousel-next>
          <span aria-hidden="true">&#8250;</span>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  (() => {
    const carousel = document.querySelector('#risaa-new-in-{{ section.id }} [data-risaa-carousel]');
    if (!carousel || carousel.dataset.risaaCarouselReady === 'true') return;

    const track = carousel.querySelector('[data-risaa-carousel-track]');
    const prev = carousel.querySelector('[data-risaa-carousel-prev]');
    const next = carousel.querySelector('[data-risaa-carousel-next]');
    if (track.children.length <= 4) return;

    carousel.dataset.risaaCarouselReady = 'true';

    const step = () => {
      const styles = window.getComputedStyle(track);
      const gap = parseFloat(styles.columnGap || styles.gap) || 0;
      return track.children[0] ? track.children[0].getBoundingClientRect().width + gap : 0;
    };
    let isAnimating = false;
    let direction = null;

    prev.addEventListener('click', () => {
      if (isAnimating) return;
      isAnimating = true;
      direction = 'prev';
      track.style.transition = 'none';
      track.insertBefore(track.lastElementChild, track.firstElementChild);
      track.style.transform = `translateX(${-step()}px)`;
      track.offsetHeight;
      requestAnimationFrame(() => {
        track.style.transition = '';
        track.style.transform = 'translateX(0)';
      });
    });
    next.addEventListener('click', () => {
      if (isAnimating) return;
      isAnimating = true;
      direction = 'next';
      track.style.transform = `translateX(${-step()}px)`;
    });
    track.addEventListener('transitionend', () => {
      if (direction === 'next') {
        track.style.transition = 'none';
        track.appendChild(track.firstElementChild);
        track.style.transform = 'translateX(0)';
        track.offsetHeight;
        requestAnimationFrame(() => {
          track.style.transition = '';
          direction = null;
          isAnimating = false;
        });
        return;
      }
      direction = null;
      isAnimating = false;
    });
    window.addEventListener('resize', () => {
      track.style.transition = 'none';
      track.style.transform = 'translateX(0)';
      requestAnimationFrame(() => {
        track.style.transition = '';
      });
    });
  })();
</script>

{% schema %}
{
  "name": "New In",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "New In" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Fresh from the atelier, made with love" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "url", "id": "view_all_link", "label": "View All Link" }
  ],
  "presets": [
    {
      "name": "New In",
      "settings": { "title": "New In", "subtitle": "Fresh from the atelier, made with love" }
    }
  ]
}
{% endschema %}
