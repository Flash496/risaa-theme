{%- style -%}
  .risaa-new-in {
    padding: 5rem 0;
    background: var(--brand-text);
    position: relative;
    overflow: hidden;
  }

  .risaa-new-in::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: url('white_leaves_decoration.png');
    background-position: top right;
    background-repeat: no-repeat;
    background-size: 300px;
    opacity: 0.5;
    pointer-events: none;
  }

  .risaa-new-in__container {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 1;
  }

  @media screen and (min-width: 750px) {
    .risaa-new-in__container {
      padding: 0 5rem;
    }
  }

  .risaa-new-in__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .risaa-new-in__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .risaa-new-in__eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--brand-main);
    box-shadow: 0 0 0 3px rgba(154, 28, 32, 0.2);
  }

  .risaa-new-in__eyebrow-text {
    font-family: var(--font-body);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--brand-main);
    font-weight: 600;
  }

  .risaa-new-in__title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    color: var(--brand-main);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }

  .risaa-new-in__subtitle {
    color: #666;
    font-size: 1.1rem;
    margin-top: 0.5rem;
    font-family: var(--font-body);
  }

  /* ── Carousel wrapper ── */
  .risaa-new-in__carousel-wrap {
    position: relative;
  }

  .risaa-new-in__track-outer {
    overflow: hidden;
  }

  .risaa-new-in__track {
    display: flex;
    gap: 1.2rem;
    transition: transform 0.45s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
    cursor: grab;
    user-select: none;
  }

  .risaa-new-in__track.is-dragging {
    cursor: grabbing;
    transition: none;
  }

  /* ── Card ── */
  .risaa-new-in__card {
    flex: 0 0 var(--ni-card-width, 22%);
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.3s ease;
  }

  .risaa-new-in__card:hover {
    transform: translateY(-5px);
  }
  .risaa-new-in__card:hover .risaa-new-in__img img {
    transform: scale(1.05);
  }

  .risaa-new-in__img {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .risaa-new-in__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .risaa-new-in__badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: linear-gradient(135deg, var(--brand-main) 0%, #6b1014 100%);
    color: var(--brand-text);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 3px;
    font-weight: 600;
    box-shadow: 0 2px 8px rgba(154, 28, 32, 0.3);
  }

  .risaa-new-in__info {
    padding: 0.7rem 0.2rem 0;
  }

  .risaa-new-in__name {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    color: var(--brand-dark);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.3rem;
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .risaa-new-in__price {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--brand-main);
    font-weight: 500;
  }

  /* ── Arrow buttons ── */
  .risaa-new-in__arrow {
    position: absolute;
    top: 38%;
    transform: translateY(-50%);
    z-index: 10;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    border: 1.5px solid rgba(154, 28, 32, 0.25);
    background: white;
    color: var(--brand-main);
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
    transition: background 0.2s, color 0.2s, opacity 0.2s;
    opacity: 0.85;
  }

  .risaa-new-in__arrow:hover {
    background: var(--brand-main);
    color: white;
    opacity: 1;
  }

  .risaa-new-in__arrow--prev {
    left: -22px;
  }
  .risaa-new-in__arrow--next {
    right: -22px;
  }

  .risaa-new-in__arrow[disabled] {
    opacity: 0.25;
    pointer-events: none;
  }

  /* ── Dots ── */
  .risaa-new-in__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 1.8rem;
  }

  .risaa-new-in__dot {
    width: 7px;
    height: 7px;
    border-radius: 4px;
    background: rgba(154, 28, 32, 0.2);
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    padding: 0;
  }

  .risaa-new-in__dot.active {
    background: var(--brand-main);
    width: 22px;
  }

  /* ── View all ── */
  .risaa-new-in__view-all {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* ── Responsive card widths ── */
  @media screen and (min-width: 990px) {
    .risaa-new-in__card {
      --ni-card-width: 22%;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .risaa-new-in__card {
      --ni-card-width: 30%;
    }
    .risaa-new-in__arrow--prev {
      left: -16px;
    }
    .risaa-new-in__arrow--next {
      right: -16px;
    }
  }

  @media screen and (max-width: 749px) {
    .risaa-new-in {
      padding: 3rem 0;
    }
    .risaa-new-in__container {
      padding: 0 1.2rem;
    }
    .risaa-new-in__title {
      font-size: 2rem;
    }
    .risaa-new-in__card {
      --ni-card-width: 46%;
    }
    .risaa-new-in__arrow {
      display: none;
    }
    .risaa-new-in__track {
      gap: 0.8rem;
    }
  }
{%- endstyle -%}

<section class="risaa-new-in reveal-on-scroll" id="risaa-new-in-{{ section.id }}">
  <div class="risaa-new-in__container">
    <div class="risaa-new-in__header" data-anim="fade-up">
      <div class="risaa-new-in__eyebrow">
        <span class="risaa-new-in__eyebrow-dot"></span>
        <span class="risaa-new-in__eyebrow-text">Just Arrived</span>
      </div>
      <h2 class="risaa-new-in__title">{{ section.settings.title }}</h2>
      {% if section.settings.subtitle != blank %}
        <p class="risaa-new-in__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="risaa-new-in__carousel-wrap" data-anim="fade-up" data-anim-delay="0.15">
      <button class="risaa-new-in__arrow risaa-new-in__arrow--prev" id="ni-prev-{{ section.id }}" aria-label="Previous">
        &#8592;
      </button>
      <button class="risaa-new-in__arrow risaa-new-in__arrow--next" id="ni-next-{{ section.id }}" aria-label="Next">
        &#8594;
      </button>

      <div class="risaa-new-in__track-outer">
        <div class="risaa-new-in__track" id="ni-track-{{ section.id }}">
          {% if section.settings.collection != blank and section.settings.collection.products.size > 0 %}
            {% for product in section.settings.collection.products limit: 12 %}
              <a href="{{ product.url }}" class="risaa-new-in__card">
                <div class="risaa-new-in__img">
                  {% if product.featured_image != blank %}
                    {{
                      product.featured_image
                      | image_url: width: 500
                      | image_tag: loading: 'lazy', alt: product.title
                    }}
                  {% else %}
                    {{ 'product-apparel-1' | placeholder_svg_tag }}
                  {% endif %}
                  <span class="risaa-new-in__badge">New</span>
                </div>
                <div class="risaa-new-in__info">
                  <p class="risaa-new-in__name">{{ product.title | truncate: 28 }}</p>
                  <p class="risaa-new-in__price">{{ product.price | money }}</p>
                </div>
              </a>
            {% endfor %}
          {% else %}
            {% for i in (1..8) %}
              <div class="risaa-new-in__card">
                <div class="risaa-new-in__img">
                  {{ 'product-apparel-1' | placeholder_svg_tag }}
                  <span class="risaa-new-in__badge">New</span>
                </div>
                <div class="risaa-new-in__info">
                  <p class="risaa-new-in__name">New Arrival</p>
                  <p class="risaa-new-in__price">₹XX,XXX</p>
                </div>
              </div>
            {% endfor %}
          {% endif %}
        </div>
      </div>

      <div class="risaa-new-in__dots" id="ni-dots-{{ section.id }}"></div>
    </div>

    {% if section.settings.view_all_link != blank %}
      <div class="risaa-new-in__view-all" data-anim="fade-up" data-anim-delay="0.3">
        <a href="{{ section.settings.view_all_link }}" class="btn-premium">View All New Arrivals →</a>
      </div>
    {% endif %}
  </div>
</section>

<script>
  (function () {
    const id = '{{ section.id }}';
    const track = document.getElementById('ni-track-' + id);
    const dotsWrap = document.getElementById('ni-dots-' + id);
    const prevBtn = document.getElementById('ni-prev-' + id);
    const nextBtn = document.getElementById('ni-next-' + id);
    if (!track) return;

    let current = 0;

    function getVisible() {
      const w = track.parentElement.offsetWidth;
      const cardW = track.children[0] ? track.children[0].offsetWidth : 1;
      const gap = parseFloat(getComputedStyle(track).gap) || 0;
      return Math.max(1, Math.round(w / (cardW + gap)));
    }

    function totalCards() {
      return track.children.length;
    }

    function maxIndex() {
      return Math.max(0, totalCards() - getVisible());
    }

    function buildDots() {
      dotsWrap.innerHTML = '';
      const pages = maxIndex() + 1;
      for (let i = 0; i < pages; i++) {
        const d = document.createElement('button');
        d.className = 'risaa-new-in__dot' + (i === 0 ? ' active' : '');
        d.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        d.addEventListener('click', () => goTo(i));
        dotsWrap.appendChild(d);
      }
    }

    function updateDots() {
      Array.from(dotsWrap.children).forEach((d, i) => d.classList.toggle('active', i === current));
    }

    function goTo(idx) {
      current = Math.max(0, Math.min(idx, maxIndex()));
      const cardW = track.children[0] ? track.children[0].offsetWidth : 0;
      const gap = parseFloat(getComputedStyle(track).gap) || 0;
      track.style.transform = 'translateX(-' + current * (cardW + gap) + 'px)';
      updateDots();
      if (prevBtn) prevBtn.disabled = current === 0;
      if (nextBtn) nextBtn.disabled = current >= maxIndex();
    }

    if (prevBtn) prevBtn.addEventListener('click', () => goTo(current - 1));
    if (nextBtn) nextBtn.addEventListener('click', () => goTo(current + 1));

    // Touch / drag
    let startX = 0,
      isDragging = false,
      dragDelta = 0;
    track.addEventListener('mousedown', (e) => {
      isDragging = true;
      startX = e.clientX;
      track.classList.add('is-dragging');
    });
    window.addEventListener('mousemove', (e) => {
      if (!isDragging) return;
      dragDelta = e.clientX - startX;
    });
    window.addEventListener('mouseup', () => {
      if (!isDragging) return;
      isDragging = false;
      track.classList.remove('is-dragging');
      if (dragDelta < -50) goTo(current + 1);
      else if (dragDelta > 50) goTo(current - 1);
      dragDelta = 0;
    });
    track.addEventListener(
      'touchstart',
      (e) => {
        startX = e.touches[0].clientX;
      },
      { passive: true }
    );
    track.addEventListener('touchend', (e) => {
      const diff = e.changedTouches[0].clientX - startX;
      if (diff < -40) goTo(current + 1);
      else if (diff > 40) goTo(current - 1);
    });

    // Init + resize
    function init() {
      buildDots();
      goTo(0);
    }
    init();
    window.addEventListener('resize', () => {
      buildDots();
      goTo(Math.min(current, maxIndex()));
    });
  })();
</script>

{% schema %}
{
  "name": "New In",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "New In" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Fresh from the atelier, made with love" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "url", "id": "view_all_link", "label": "View All Link" }
  ],
  "presets": [
    {
      "name": "New In",
      "settings": { "title": "New In", "subtitle": "Fresh from the atelier, made with love" }
    }
  ]
}
{% endschema %}
