{%- style -%}
  .risaa-process {
    background-color: var(--brand-text);
    padding: 6rem 0;
    position: relative;
    border-bottom: 1px solid rgba(110, 20, 35, 0.08);
  }

  .risaa-process__header {
    text-align: center;
    margin-bottom: 5rem;
    will-change: transform;
    transform-style: preserve-3d;
  }

  .risaa-process__eyebrow {
    font-family: var(--font-body);
    font-size: 1.2rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--brand-gold);
    font-weight: 500;
    margin-bottom: 1rem;
    display: block;
  }

  .risaa-process__title {
    font-family: 'Cinzel', Georgia, serif !important;
    font-size: 3rem !important;
    color: var(--brand-main) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.18em !important;
    line-height: 1.1 !important;
    font-weight: 400 !important;
    margin: 0;
  }

  .risaa-process__subtitle {
    font-family: 'Great Vibes', cursive !important;
    font-size: 2rem !important;
    color: var(--brand-main);
    text-transform: none !important;
    letter-spacing: 0.04em !important;
    font-weight: 400 !important;
    margin-top: 8px !important;
  }

  .risaa-process__grid {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2.5rem;
    position: relative;
  }

  .risaa-process__step {
    flex: 1;
    text-align: center;
    position: relative;
    padding: 2rem 1.5rem;
    background: rgba(255, 255, 255, 0.3);
    border: 1px solid rgba(110, 20, 35, 0.04);
    will-change: transform;
    transform-style: preserve-3d;
  }

  .risaa-process__number {
    font-family: 'Cinzel', Georgia, serif;
    font-size: 4rem;
    color: rgba(110, 20, 35, 0.15);
    margin-bottom: 1.5rem;
    font-weight: 400;
    line-height: 1;
    display: inline-block;
    border-bottom: 1px solid var(--brand-gold);
    padding-bottom: 0.5rem;
  }

  .risaa-process__step-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--brand-main);
    letter-spacing: 0.12em;
    margin: 0 0 1rem;
    text-transform: uppercase;
  }

  .risaa-process__step-desc {
    font-family: var(--font-body);
    font-size: 1.25rem;
    color: var(--brand-dark);
    line-height: 1.6;
    margin: 0;
    font-weight: 300;
    opacity: 0.85;
  }

  @media screen and (max-width: 989px) {
    .risaa-process__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  @media screen and (max-width: 749px) {
    .risaa-process {
      padding: 4.5rem 0;
    }
    .risaa-process__header {
      margin-bottom: 3.5rem;
    }
    .risaa-process__title {
      font-size: 2.2rem !important;
    }
    .risaa-process__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .risaa-process__step {
      padding: 1.5rem 1rem;
    }
  }
{%- endstyle -%}

<section class="risaa-process" id="risaa-process-{{ section.id }}">
  <div class="page-width">
    <div class="risaa-process__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="risaa-process__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="risaa-process__title">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <div class="risaa-process__subtitle">{{ section.settings.subtitle }}</div>
      {%- endif -%}
    </div>

    <div class="risaa-process__grid">
      {%- for block in section.blocks -%}
        <div class="risaa-process__step" {{ block.shopify_attributes }}>
          <div class="risaa-process__number">0{{ forloop.index }}</div>
          <h3 class="risaa-process__step-title">{{ block.settings.step_title }}</h3>
          <p class="risaa-process__step-desc">{{ block.settings.step_desc }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('risaa-process-{{ section.id }}');
    if (!section) return;
    const cards = section.querySelectorAll('.risaa-process__step');
    const header = section.querySelector('.risaa-process__header');
    
    // Fixed speeds — consistent every load, clearly different from each other
    // Header is slowest, cards vary noticeably
    const headerSpeed = 0.28;
    const cardSpeeds = [0.22, 0.13, 0.35, 0.16]; // card 1, 2, 3, 4
    
    let cardStaticOffsets = [];
    let headerStaticOffset = 0;
    
    const calculateOffsets = () => {
      // Save current transforms
      const savedHeaderTransform = header ? header.style.transform : '';
      const savedCardTransforms = Array.from(cards).map(card => card.style.transform);
      
      // Temporarily clear transforms to get static layout positions
      if (header) header.style.transform = '';
      cards.forEach(card => card.style.transform = '');
      
      const sectionRect = section.getBoundingClientRect();
      const sectionTop = sectionRect.top + window.scrollY;
      
      if (header) {
        headerStaticOffset = (header.getBoundingClientRect().top + window.scrollY) - sectionTop;
      }
      
      cardStaticOffsets = Array.from(cards).map(card => {
        return (card.getBoundingClientRect().top + window.scrollY) - sectionTop;
      });
      
      // Restore transforms
      if (header) header.style.transform = savedHeaderTransform;
      cards.forEach((card, idx) => {
        card.style.transform = savedCardTransforms[idx] || '';
      });
    };
    
    const handleScroll = () => {
      const rect = section.getBoundingClientRect();
      const sectionTop = rect.top;
      const windowHeight = window.innerHeight;
      
      // Header target viewport position
      const headerTargetTop = windowHeight * 0.2;
      const headerStaticTop = sectionTop + headerStaticOffset;
      const headerDiff = headerStaticTop - headerTargetTop;
      
      // Animate Header
      if (header) {
        let headerYMove = headerDiff * headerSpeed;
        let headerRotation = headerDiff * 0.05;
        headerRotation = Math.max(0, Math.min(60, headerRotation));
        
        if (headerDiff < 0) {
          headerYMove = headerDiff * (headerSpeed * 0.6);
          headerRotation = 0;
        }
        
        header.style.transform = `perspective(1000px) translateY(${headerYMove}px) rotateX(${headerRotation}deg)`;
      }

      // Animate Cards
      cards.forEach((card, index) => {
        const speed = cardSpeeds[index];
        const cardStaticOffset = cardStaticOffsets[index] || 0;
        const cardStaticTop = sectionTop + cardStaticOffset;
        
        // Target viewport position for the card to settle
        const cardTargetTop = windowHeight * 0.35;
        const cardDiff = cardStaticTop - cardTargetTop;
        
        let yMove = cardDiff * speed;
        
        // Rolling rotation effect only applies when scrolling in (below target)
        let rotation = cardDiff * 0.05;
        rotation = Math.max(0, Math.min(60, rotation)); // Clamp rotation
        
        // If it scrolls past the target point, keep parallax but remove rotation
        if (cardDiff < 0) {
          yMove = cardDiff * (speed * 0.6); // reduce parallax speed when scrolling upwards
          rotation = 0;
        }
        
        card.style.transform = `perspective(1000px) translateY(${yMove}px) rotateX(${rotation}deg)`;
      });
    };
    
    // Initial calculate and layout
    calculateOffsets();
    handleScroll();
    
    window.addEventListener('scroll', () => {
      requestAnimationFrame(handleScroll);
    }, { passive: true });
    
    window.addEventListener('resize', () => {
      calculateOffsets();
      requestAnimationFrame(handleScroll);
    });
    
    window.addEventListener('load', () => {
      calculateOffsets();
      requestAnimationFrame(handleScroll);
    });
  });
</script>

{% schema %}
{
  "name": "Risaa Couture Process",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Our Couture Process"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle (Cursive)",
      "default": "Your custom design, crafted with care"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "step_title",
          "label": "Step Title",
          "default": "Consult & Design"
        },
        {
          "type": "textarea",
          "id": "step_desc",
          "label": "Step Description",
          "default": "Connect with us on WhatsApp to discuss custom modifications, sizes, colors, or fabrics."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Risaa Couture Process",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_title": "Choose & Customise",
            "step_desc": "Explore our designs online or start a conversation to share custom adjustments and fabric requests."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_title": "Share Measurements",
            "step_desc": "Provide your size details via our simple measurement chart, or get assisted live by our stylist team."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_title": "Artisanal Stitching",
            "step_desc": "Our master tailors and artisans hand-stitch and finish your garment to ensure a premium custom fit."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_title": "Global Hand-Delivery",
            "step_desc": "Every order is inspected for quality, beautifully wrapped, and shipped with tracking worldwide."
          }
        }
      ]
    }
  ]
}
{% endschema %}
