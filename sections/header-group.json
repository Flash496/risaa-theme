{
  "name": "t:sections.header.name",
  "type": "header",
  "sections": {
    "announcement-marquee": {
      "type": "announcement-marquee",
      "blocks": {
        "welcome": { "type": "announcement", "settings": { "text": "Welcome offer: 10% off your first order" } },
        "a1": { "type": "announcement", "settings": { "text": "Sale alerts & discounts" } },
        "a2": { "type": "announcement", "settings": { "text": "Free pan-India shipping" } },
        "a3": { "type": "announcement", "settings": { "text": "24 hr dispatch on selected items" } }
      },
      "block_order": ["welcome", "a1", "a2", "a3"]
    },
    "header": {
      "type": "header",
      "settings": {
        "color_scheme": "scheme-3",
        "logo_position": "middle-left",
        "menu": "main-menu",
        "menu_type_desktop": "dropdown",
        "sticky_header_type": "always",
        "show_line_separator": false,
        "enable_country_selector": false,
        "enable_language_selector": false,
        "mobile_logo_position": "center",
        "margin_bottom": 0,
        "padding_top": 12,
        "padding_bottom": 12
      }
    }
  },
  "order": [
    "announcement-marquee",
    "header"
  ]
}
