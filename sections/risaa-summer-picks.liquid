{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .risaa-summer-picks {
    padding: 0;
    background: #f4eade;
    position: relative;
    overflow: hidden;
  }

  .risaa-summer-picks__header {
    text-align: center;
    margin-bottom: 0;
  }

  .risaa-summer-picks__title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    color: var(--brand-main);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }

  @media screen and (max-width: 749px) {
    .risaa-summer-picks {
      padding: 0;
    }
    .risaa-summer-picks__title {
      font-size: 2rem;
    }
  }
{%- endstyle -%}

<section class="risaa-summer-picks reveal-on-scroll" id="risaa-summer-picks-{{ section.id }}">
  <div class="page-width">
    <div class="risaa-summer-picks__header">
      <h2 class="risaa-summer-picks__title">{{ section.settings.title }}</h2>
    </div>

    <ul
      class="grid product-grid contains-card contains-card--product grid--4-col-desktop grid--2-col-tablet-down"
      role="list"
      data-anim-stagger
      data-anim-delay="0.05"
      data-anim-step="0.06"
    >
      {% if section.settings.collection != blank and section.settings.collection.products.size > 0 %}
        {%- assign skip_card_product_styles = false -%}
        {% for product in section.settings.collection.products limit: 4 %}
          {%- assign curated_card_image_index = forloop.index0 -%}
          <li class="grid__item">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: 'portrait',
              show_secondary_image: true,
              show_vendor: false,
              show_rating: false,
              lazy_load: true,
              skip_styles: skip_card_product_styles,
              section_id: section.id,
              landing_card_price: 'true',
              custom_card_image_index: curated_card_image_index
            %}
            {%- assign skip_card_product_styles = true -%}
          </li>
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <li class="grid__item">
            {%- assign placeholder_image = 'product-apparel-' | append: i -%}
            {% render 'card-product',
              media_aspect_ratio: 'portrait',
              placeholder_image: placeholder_image,
              placeholder_image_offset: 0,
              landing_card_price: 'true'
            %}
          </li>
        {% endfor %}
      {% endif %}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Summer Picks",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "Sun-Kissed Picks" },
    { "type": "collection", "id": "collection", "label": "Collection" }
  ],
  "presets": [
    {
      "name": "Summer Picks",
      "settings": { "title": "Sun-Kissed Picks" }
    }
  ]
}
{% endschema %}
