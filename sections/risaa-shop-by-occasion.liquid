{%- style -%}
  .risaa-occasions {
    padding: 0 0 60px;
    background: #faf8f5;
  }

  .risaa-occasions__header {
    text-align: center;
    margin-bottom: 20px;
    padding: 0 20px;
  }

  .risaa-occasions__eyebrow {
    font-family: var(--font-body-family);
    font-size: 0.75rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: #f8b799;
    display: block;
    margin-bottom: 14px;
    font-weight: 600;
  }

  .risaa-occasions__title {
    font-family: var(--font-heading-family);
    font-size: 3rem;
    color: #9a1c20;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 1.1;
  }

  /* Outer clipping container */
  .risaa-occasions__carousel-outer {
    position: relative;
    width: 100%;
    overflow: hidden;
    user-select: none;
    cursor: grab;
    z-index: 2;
    background: #faf8f5;
    padding-top: 25px;
    margin-top: -25px;
  }

  .risaa-occasions__carousel-outer.is-dragging {
    box-shadow: none;
  }

  /* Fade edges */
  .risaa-occasions__carousel-outer::before,
  .risaa-occasions__carousel-outer::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 3;
    pointer-events: none;
  }
  .risaa-occasions__carousel-outer::before {
    left: 0;
    background: linear-gradient(to right, #faf8f5, transparent);
  }
  .risaa-occasions__carousel-outer::after {
    right: 0;
    background: linear-gradient(to left, #faf8f5, transparent);
  }

  /* Arrow buttons */
  .risaa-occasions__arrow {
    position: absolute;
    top: 45%;
    transform: translateY(-50%);
    z-index: 10;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid rgba(154, 28, 32, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.3s ease, background 0.2s ease;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
    pointer-events: none;
    padding: 0;
  }
  .risaa-occasions__arrow svg {
    width: 18px;
    height: 18px;
    stroke: #9a1c20;
    stroke-width: 2.5;
    fill: none;
    display: block;
  }
  .risaa-occasions__arrow--prev {
    left: 16px;
  }
  .risaa-occasions__arrow--next {
    right: 16px;
  }

  .risaa-occasions__carousel-outer:hover .risaa-occasions__arrow {
    opacity: 1;
    pointer-events: auto;
  }
  .risaa-occasions__arrow:hover {
    background: #d8a764;
    border-color: #d8a764;
  }
  .risaa-occasions__arrow:hover svg {
    stroke: #ffffff;
  }

  /* Belt — JS drives translateX, no CSS animation */
  .risaa-occasions__belt {
    display: flex;
    gap: 24px;
    padding: 0 0 24px;
    width: max-content;
    will-change: transform;
  }

  /* Card */
  .risaa-occasions__card {
    flex: 0 0 317px;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }
  .risaa-occasions__card:hover {
    transform: translateY(-8px);
  }

  .risaa-occasions__img-wrap {
    width: 317px;
    height: 446px;
    overflow: hidden;
    border-radius: 158px 158px 18px 18px;
    position: relative;
    background: #f1dcd2;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08), 0 32px 40px -8px rgba(150, 100, 10, 0.5);
    transition: box-shadow 0.4s ease;
  }
  .risaa-occasions__card:hover .risaa-occasions__img-wrap {
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1), 0 36px 48px -6px rgba(150, 100, 10, 0.72);
  }
  .risaa-occasions__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    display: block;
    border-radius: 158px 158px 18px 18px;
  }
  .risaa-occasions__card:hover .risaa-occasions__img {
    transform: scale(1.06);
  }

  .risaa-occasions__name {
    font-family: var(--font-heading-family);
    font-size: 1.4rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #1a1a1a;
    text-align: center;
    margin: 16px 0 0;
    transition: color 0.3s ease;
  }
  .risaa-occasions__card:hover .risaa-occasions__name {
    color: #9a1c20;
  }

  @media screen and (max-width: 749px) {
    .risaa-occasions {
      padding: 50px 0 40px;
    }
    .risaa-occasions__title {
      font-size: 2.2rem;
    }
    .risaa-occasions__card {
      flex: 0 0 245px;
    }
    .risaa-occasions__img-wrap {
      width: 245px;
      height: 346px;
      border-radius: 122px 122px 14px 14px;
    }
    .risaa-occasions__img {
      border-radius: 122px 122px 14px 14px;
    }
    .risaa-occasions__belt {
      gap: 16px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign occ_images = 'https://ik.imagekit.io/flashspdstr/risaa/bridal.jpg,https://ik.imagekit.io/flashspdstr/risaa/sangeet.jpg,https://ik.imagekit.io/flashspdstr/risaa/mehendi.png,https://ik.imagekit.io/flashspdstr/risaa/reception.jpg,https://ik.imagekit.io/flashspdstr/risaa/couture.jpg,https://ik.imagekit.io/flashspdstr/risaa/pret.jpg,https://ik.imagekit.io/flashspdstr/risaa/trousseau.png,https://ik.imagekit.io/flashspdstr/risaa/Ruby%20primary.jpg,https://ik.imagekit.io/flashspdstr/risaa/pink%20sharara%20with%20light%20golden%20embroidery%20with_.jpg,https://ik.imagekit.io/flashspdstr/risaa/Elevate%20your%20ethnic%20wardrobe%20with%20this%20gorgeous_.jpg' | split: ','
  assign occ_names = 'Bridal,Sangeet,Mehendi,Reception,Couture,Pret,Trousseau,Festive,Cocktail,Casual Chic' | split: ','
  assign occ_links = '/collections/bridal,/collections/sangeet,/collections/mehendi,/collections/reception,/collections/couture,/collections/pret,/collections/trousseau,/collections/festive,/collections/cocktail,/collections/all' | split: ','
-%}

<section class="risaa-occasions reveal-on-scroll">
  <div class="risaa-occasions__header">
    {%- if section.settings.eyebrow != blank -%}
      <span class="risaa-occasions__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h2 class="risaa-occasions__title">{{ section.settings.title }}</h2>
  </div>

  <div class="risaa-occasions__carousel-outer" id="occasionsOuter-{{ section.id }}">
    <button
      class="risaa-occasions__arrow risaa-occasions__arrow--prev"
      id="occasionsPrev-{{ section.id }}"
      aria-label="Previous"
    >
      <svg viewBox="0 0 24 24">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <button
      class="risaa-occasions__arrow risaa-occasions__arrow--next"
      id="occasionsNext-{{ section.id }}"
      aria-label="Next"
    >
      <svg viewBox="0 0 24 24">
        <polyline points="9 6 15 12 9 18"/>
      </svg>
    </button>

    <div class="risaa-occasions__belt" id="occasionsBelt-{{ section.id }}">
      {%- comment -%}Render 3 copies so there's always content on both sides{%- endcomment -%}
      {%- for i in (1..3) -%}
        {%- for block in section.blocks -%}
          {%- assign img_index = forloop.index0 | modulo: 10 -%}
          {%- assign card_name = block.settings.occasion_name | default: occ_names[img_index] -%}
          {%- assign card_link = block.settings.link | default: occ_links[img_index] -%}
          {%- assign fallback_img = occ_images[img_index] -%}
          <a href="{{ card_link }}" class="risaa-occasions__card" draggable="false">
            <div class="risaa-occasions__img-wrap">
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 600
                  | image_tag: class: 'risaa-occasions__img', loading: 'lazy', alt: card_name, draggable: 'false'
                }}
              {%- else -%}
                <img
                  src="{{ fallback_img }}"
                  alt="{{ card_name }}"
                  class="risaa-occasions__img"
                  loading="lazy"
                  draggable="false"
                  width="317"
                  height="446"
                >
              {%- endif -%}
            </div>
            <p class="risaa-occasions__name">{{ card_name }}</p>
          </a>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var sid = '{{ section.id }}';
    var outer = document.getElementById('occasionsOuter-' + sid);
    var belt = document.getElementById('occasionsBelt-' + sid);
    var btnPrev = document.getElementById('occasionsPrev-' + sid);
    var btnNext = document.getElementById('occasionsNext-' + sid);
    if (!outer || !belt) return;

    /* ── Config ── */
    var SPEED = 0.6; // px per frame at 60 fps (auto-scroll)
    var STEP = 341; // card (317) + gap (24) — for arrow nudge
    var GAP = 24;

    /* ── State ── */
    var pos = 0; // current translateX (negative = scrolled right)
    var velocity = 0; // extra velocity from drag momentum
    var paused = false;
    var isDown = false;
    var dragStartX = 0;
    var dragStartPos = 0;
    var hasDragged = false;
    var lastDragX = 0;
    var lastDragT = 0;
    var resumeTimer = null;
    var raf = null;
    var oneSetW = 0; // width of one set of cards

    /* ── Measure one set width after layout ── */
    function measure() {
      var cards = belt.querySelectorAll('.risaa-occasions__card');
      var n = cards.length / 3; // 3 copies rendered
      if (n < 1) return;
      var w = 0;
      for (var i = 0; i < n; i++) w += cards[i].offsetWidth + GAP;
      oneSetW = w;
      // Start in the middle copy so we can scroll both ways
      pos = -oneSetW;
      apply();
    }

    /* ── Apply transform ── */
    function apply() {
      belt.style.transform = 'translateX(' + pos + 'px)';
    }

    /* ── Wrap pos to stay in middle copy ── */
    function wrap() {
      if (!oneSetW) return;
      // If we've scrolled past the end of the middle copy, jump back one set
      if (pos <= -oneSetW * 2) pos += oneSetW;
      // If we've scrolled before the start of the middle copy, jump forward one set
      if (pos > 0) pos -= oneSetW;
    }

    /* ── RAF loop ── */
    function tick() {
      raf = requestAnimationFrame(tick);
      if (!paused) {
        pos -= SPEED;
      }
      // Apply momentum from drag
      if (Math.abs(velocity) > 0.1) {
        pos += velocity;
        velocity *= 0.92; // friction
      } else {
        velocity = 0;
      }
      wrap();
      apply();
    }

    /* ── Pause / resume ── */
    function pause() {
      paused = true;
    }
    function resume() {
      paused = false;
    }
    function scheduleResume(ms) {
      clearTimeout(resumeTimer);
      resumeTimer = setTimeout(function () {
        if (!outer.matches(':hover')) resume();
      }, ms);
    }

    /* ── Arrow nudge (smooth) ── */
    function nudge(dir) {
      pause();
      var target = pos + dir * -STEP;
      var start = pos;
      var t0 = null;
      var dur = 420;
      function ease(t) {
        return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
      }
      function animNudge(ts) {
        if (!t0) t0 = ts;
        var p = Math.min((ts - t0) / dur, 1);
        pos = start + (target - start) * ease(p);
        wrap();
        apply();
        if (p < 1) {
          requestAnimationFrame(animNudge);
        } else {
          pos = target;
          wrap();
          apply();
          scheduleResume(2000);
        }
      }
      requestAnimationFrame(animNudge);
    }

    /* ── Arrows ── */
    if (btnPrev)
      btnPrev.addEventListener('click', function (e) {
        e.stopPropagation();
        nudge(-1);
      });
    if (btnNext)
      btnNext.addEventListener('click', function (e) {
        e.stopPropagation();
        nudge(1);
      });

    /* ── Hover ── */
    outer.addEventListener('mouseenter', pause);
    outer.addEventListener('mouseleave', function () {
      if (!isDown) scheduleResume(500);
    });

    /* ── Mouse drag ── */
    outer.addEventListener('mousedown', function (e) {
      if (e.target.closest('.risaa-occasions__arrow')) return;
      pause();
      isDown = true;
      hasDragged = false;
      dragStartX = e.pageX;
      dragStartPos = pos;
      lastDragX = e.pageX;
      lastDragT = Date.now();
      velocity = 0;
      outer.classList.add('is-dragging');
    });

    window.addEventListener('mouseup', function () {
      if (!isDown) return;
      isDown = false;
      outer.classList.remove('is-dragging');
      scheduleResume(hasDragged ? 1800 : 500);
    });

    window.addEventListener('mousemove', function (e) {
      if (!isDown) return;
      var diff = e.pageX - dragStartX;
      if (Math.abs(diff) > 3) hasDragged = true;
      // Track velocity for momentum
      var now = Date.now();
      var dt = now - lastDragT || 1;
      velocity = ((e.pageX - lastDragX) / dt) * 16; // scale to ~px/frame
      lastDragX = e.pageX;
      lastDragT = now;
      pos = dragStartPos + diff;
      wrap();
      apply();
    });

    /* ── Block clicks on drag ── */
    outer.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function (e) {
        if (hasDragged) e.preventDefault();
      });
    });

    /* ── Touch ── */
    var tStartX = 0,
      tStartPos = 0,
      tDragged = false,
      tLastX = 0,
      tLastT = 0;

    outer.addEventListener(
      'touchstart',
      function (e) {
        pause();
        tStartX = e.touches[0].clientX;
        tStartPos = pos;
        tDragged = false;
        tLastX = tStartX;
        tLastT = Date.now();
        velocity = 0;
        outer.classList.add('is-dragging');
      },
      { passive: true }
    );

    outer.addEventListener(
      'touchmove',
      function (e) {
        var diff = e.touches[0].clientX - tStartX;
        if (Math.abs(diff) > 5) tDragged = true;
        var now = Date.now();
        velocity = ((e.touches[0].clientX - tLastX) / (now - tLastT || 1)) * 16;
        tLastX = e.touches[0].clientX;
        tLastT = now;
        pos = tStartPos + diff;
        wrap();
        apply();
      },
      { passive: true }
    );

    outer.addEventListener('touchend', function () {
      outer.classList.remove('is-dragging');
      scheduleResume(tDragged ? 1800 : 400);
    });

    outer.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('touchend', function (e) {
        if (tDragged) e.preventDefault();
      });
    });

    /* ── Init ── */
    requestAnimationFrame(function () {
      measure();
      tick();
    });
  })();
</script>

{% schema %}
{
  "name": "Shop by Occasion",
  "tag": "section",
  "class": "section",
  "max_blocks": 10,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "Dressed for Every Moment" },
    { "type": "text", "id": "title", "label": "Title", "default": "Shop by Occasion" },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll Speed (seconds)",
      "min": 20,
      "max": 80,
      "step": 5,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "occasion",
      "name": "Occasion",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "occasion_name", "label": "Occasion Name", "default": "Wedding" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Occasion",
      "blocks": [
        { "type": "occasion", "settings": { "occasion_name": "Bridal" } },
        { "type": "occasion", "settings": { "occasion_name": "Sangeet" } },
        { "type": "occasion", "settings": { "occasion_name": "Mehendi" } },
        { "type": "occasion", "settings": { "occasion_name": "Reception" } },
        { "type": "occasion", "settings": { "occasion_name": "Couture" } },
        { "type": "occasion", "settings": { "occasion_name": "Pret" } },
        { "type": "occasion", "settings": { "occasion_name": "Trousseau" } },
        { "type": "occasion", "settings": { "occasion_name": "Festive" } },
        { "type": "occasion", "settings": { "occasion_name": "Cocktail" } },
        { "type": "occasion", "settings": { "occasion_name": "Casual Chic" } }
      ]
    }
  ]
}
{% endschema %}
