{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .risaa-rts {
    padding: 2.5rem 0;
    background: var(--brand-text);
    position: relative;
    overflow: hidden;
  }

  .risaa-rts::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: url('white_leaves_decoration.png');
    background-position: top left;
    background-repeat: no-repeat;
    background-size: 300px;
    opacity: 0.5;
    pointer-events: none;
  }

  .risaa-rts__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .risaa-rts__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .risaa-rts__eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #fbbf24;
    box-shadow: 0 0 0 3px rgba(251, 191, 36, 0.25);
  }

  .risaa-rts__eyebrow-text {
    font-family: var(--font-body);
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fbbf24;
    font-weight: 600;
  }

  .risaa-rts__title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    color: var(--brand-main);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }

  .risaa-rts__subtitle {
    color: #666;
    font-size: 1.1rem;
    margin-top: 0.5rem;
  }

  .risaa-rts__dispatch-info {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .risaa-rts__dispatch-badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.1) 0%, rgba(251, 191, 36, 0.05) 100%);
    border: 1px solid rgba(251, 191, 36, 0.3);
    padding: 0.6rem 1rem;
    border-radius: 6px;
  }

  .risaa-rts__truck-icon {
    font-size: 1.2rem;
  }

  .risaa-rts__dispatch-text {
    font-size: 0.9rem;
    color: #fbbf24;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .risaa-rts__view-all {
    text-align: center;
    margin-top: 2.5rem;
  }

  @media screen and (max-width: 749px) {
    .risaa-rts {
      padding: 1.5rem 0;
    }
    .risaa-rts__title {
      font-size: 2rem;
    }
    .risaa-rts__dispatch-info {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
{%- endstyle -%}

<section class="risaa-rts reveal-on-scroll">
  <div class="page-width">
    <div class="risaa-rts__header" data-anim="fade-up">
      <div class="risaa-rts__eyebrow">
        <span class="risaa-rts__eyebrow-dot"></span>
        <span class="risaa-rts__eyebrow-text">In Stock · Ships Quickly</span>
      </div>
      <h2 class="risaa-rts__title">{{ section.settings.title }}</h2>
      {% if section.settings.subtitle != blank %}
        <p class="risaa-rts__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}
      <div class="risaa-rts__dispatch-info" data-anim-stagger data-anim-delay="0.3" data-anim-step="0.12">
        <div class="risaa-rts__dispatch-badge">
          <span class="risaa-rts__truck-icon">🚚</span>
          <span class="risaa-rts__dispatch-text">{{ section.settings.dispatch_days }}</span>
        </div>
        <div class="risaa-rts__dispatch-badge">
          <span class="risaa-rts__truck-icon">📦</span>
          <span class="risaa-rts__dispatch-text">{{ section.settings.dispatch_note }}</span>
        </div>
      </div>
    </div>

    <ul
      class="grid product-grid contains-card contains-card--product grid--4-col-desktop grid--2-col-tablet-down"
      role="list"
      data-anim-stagger
      data-anim-delay="0.05"
      data-anim-step="0.06"
    >
      {% if section.settings.collection != blank and section.settings.collection.products.size > 0 %}
        {%- assign skip_card_product_styles = false -%}
        {% for product in section.settings.collection.products limit: 4 %}
          <li class="grid__item">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: 'portrait',
              show_secondary_image: true,
              show_vendor: false,
              show_rating: false,
              lazy_load: true,
              skip_styles: skip_card_product_styles,
              section_id: section.id
            %}
            {%- assign skip_card_product_styles = true -%}
          </li>
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <li class="grid__item">
            {%- assign placeholder_image = 'product-apparel-' | append: i -%}
            {% render 'card-product', media_aspect_ratio: 'portrait', placeholder_image: placeholder_image %}
          </li>
        {% endfor %}
      {% endif %}
    </ul>

    {% if section.settings.view_all_link != blank %}
      <div class="risaa-rts__view-all" data-anim="fade-up" data-anim-delay="0.3">
        <a href="{{ section.settings.view_all_link }}" class="btn-premium">Shop Ready to Ship →</a>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Ready to Ship",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "Ready to Ship" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Handpicked pieces crafted and ready for you" },
    { "type": "collection", "id": "collection", "label": "Collection (Ready to Ship)" },
    { "type": "text", "id": "dispatch_days", "label": "Dispatch Timeframe", "default": "Ships in 24 Hours" },
    { "type": "text", "id": "dispatch_note", "label": "Dispatch Note", "default": "Free shipping above ₹5,000" },
    { "type": "url", "id": "view_all_link", "label": "View All Link" }
  ],
  "presets": [
    {
      "name": "Ready to Ship",
      "settings": { "title": "Ready to Ship", "subtitle": "Handpicked pieces crafted and ready for you" }
    }
  ]
}
{% endschema %}
