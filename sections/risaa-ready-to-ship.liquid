{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .risaa-rts {
    padding: 2.5rem 0;
    background: var(--brand-text);
    position: relative;
    overflow: hidden;
  }

  .risaa-rts__header {
    text-align: center;
    margin-bottom: 20px;
  }

  .risaa-rts__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .risaa-rts__eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #fbbf24;
    box-shadow: 0 0 0 3px rgba(251, 191, 36, 0.25);
  }

  .risaa-rts__eyebrow-text {
    font-family: var(--font-body);
    font-size: 1.2rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fbbf24;
    font-weight: 600;
  }

  .risaa-rts__title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    color: var(--brand-main);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }

  .risaa-rts__subtitle {
    color: #666;
    font-size: 1.4rem;
    margin-top: 0.5rem;
  }

  .risaa-rts__dispatch-info {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1.2rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .risaa-rts__dispatch-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1.4rem;
    border: 1px solid rgba(154, 28, 32, 0.25);
    border-radius: 2px;
    background: transparent;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .risaa-rts__dispatch-badge::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(154, 28, 32, 0.04) 0%, transparent 100%);
    pointer-events: none;
  }

  .risaa-rts__dispatch-badge:hover {
    border-color: rgba(154, 28, 32, 0.5);
    background: rgba(154, 28, 32, 0.03);
  }

  .risaa-rts__badge-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
  }

  .risaa-rts__badge-icon svg {
    width: 16px;
    height: 16px;
    stroke: var(--brand-main);
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .risaa-rts__badge-content {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .risaa-rts__badge-label {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.2rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-main);
    opacity: 0.6;
    line-height: 1;
  }

  .risaa-rts__dispatch-text {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--brand-main);
    letter-spacing: 0.06em;
    line-height: 1.2;
  }

  /* Divider between badges */
  .risaa-rts__dispatch-divider {
    width: 1px;
    height: 32px;
    background: rgba(154, 28, 32, 0.2);
    flex-shrink: 0;
  }

  .risaa-rts__view-all {
    text-align: center;
    margin-top: 2.5rem;
  }

  @media screen and (max-width: 749px) {
    .risaa-rts {
      padding: 1.5rem 0;
    }
    .risaa-rts__title {
      font-size: 2rem;
    }
    .risaa-rts__dispatch-info {
      flex-direction: column;
      gap: 0.5rem;
    }
  }
{%- endstyle -%}

<section class="risaa-rts reveal-on-scroll">
  <div class="page-width">
    <div class="risaa-rts__header" data-anim="fade-up">
      <h2 class="risaa-rts__title">{{ section.settings.title }}</h2>
    </div>

    <ul
      class="grid product-grid contains-card contains-card--product grid--4-col-desktop grid--2-col-tablet-down"
      role="list"
      data-anim-stagger
      data-anim-delay="0.05"
      data-anim-step="0.06"
    >
      {% if section.settings.collection != blank and section.settings.collection.products.size > 0 %}
        {%- assign skip_card_product_styles = false -%}
        {% for product in section.settings.collection.products limit: 4 %}
          <li class="grid__item">
            {% render 'card-product',
              card_product: product,
              media_aspect_ratio: 'portrait',
              show_secondary_image: true,
              show_vendor: false,
              show_rating: false,
              lazy_load: true,
              skip_styles: skip_card_product_styles,
              section_id: section.id
            %}
            {%- assign skip_card_product_styles = true -%}
          </li>
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <li class="grid__item">
            {%- assign placeholder_image = 'product-apparel-' | append: i -%}
            {% render 'card-product', media_aspect_ratio: 'portrait', placeholder_image: placeholder_image %}
          </li>
        {% endfor %}
      {% endif %}
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "Ready to Ship",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "Ready to Ship" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Handpicked pieces crafted and ready for you" },
    { "type": "collection", "id": "collection", "label": "Collection (Ready to Ship)" },
    { "type": "text", "id": "dispatch_days", "label": "Dispatch Timeframe", "default": "Ships in 24 Hours" },
    { "type": "text", "id": "dispatch_note", "label": "Dispatch Note", "default": "Free shipping above ₹5,000" },
    { "type": "url", "id": "view_all_link", "label": "View All Link" }
  ],
  "presets": [
    {
      "name": "Ready to Ship",
      "settings": { "title": "Ready to Ship", "subtitle": "Handpicked pieces crafted and ready for you" }
    }
  ]
}
{% endschema %}
