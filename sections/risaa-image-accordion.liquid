{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .risaa-accordion-container {
    position: relative;
    width: 100%;
    height: {{ section.settings.height_desktop }}px;
    overflow: hidden;
    padding: 0 15px;
  }

  .risaa-accordion-item {
    position: absolute;
    top: 0;
    height: 100%;
    overflow: hidden;
    cursor: pointer;
    border-radius: 10px;
    transform-origin: left center;
    /* Only GPU-composited properties */
    transition:
      transform 0.85s cubic-bezier(0.76, 0, 0.24, 1);
    will-change: transform;
  }

  .risaa-accordion-item img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    /* Counter-scale the image so it doesn't stretch with the card */
    transform-origin: left center;
    transition: transform 0.85s cubic-bezier(0.76, 0, 0.24, 1);
    will-change: transform;
    display: block;
  }

  .risaa-accordion-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 3rem;
    background: linear-gradient(transparent, rgba(0,0,0,0.78));
    color: white;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.45s ease 0.3s,
      transform 0.45s cubic-bezier(0.16, 1, 0.3, 1) 0.3s;
  }

  .risaa-accordion-item.is-active .risaa-accordion-info {
    opacity: 1;
    transform: translateY(0);
  }

  .risaa-accordion-info h3 {
    color: white;
    margin: 0;
    font-size: 2.4rem;
  }

  .risaa-accordion-info p {
    margin: 10px 0 0;
    font-size: 1.4rem;
    opacity: 0.9;
  }

  @media screen and (max-width: 749px) {
    .risaa-accordion-container {
      position: static;
      display: flex;
      flex-direction: column;
      height: auto;
      gap: 10px;
      padding: 0 15px;
    }
    .risaa-accordion-item {
      position: static;
      height: 250px;
      width: 100% !important;
      transform: none !important;
      transition: none;
    }
    .risaa-accordion-item img {
      transform: none !important;
    }
    .risaa-accordion-info {
      opacity: 1;
      transform: translateY(0);
      padding: 1.5rem;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding reveal-on-scroll">
  <div class="section-header" data-anim="fade-up">
    <h2>{{ section.settings.title }}</h2>
    {% if section.settings.subtitle != blank %}
      <p>{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>

  <div
    class="risaa-accordion-container"
    data-anim-stagger
    data-anim-delay="0.1"
    data-anim-step="0.1"
    id="risaa-accordion-{{ section.id }}"
  >
    {% for block in section.blocks %}
      <div class="risaa-accordion-item" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
        {% else %}
          {%- assign _acc_imgs = 'https://ik.imagekit.io/flashspdstr/risaa/bridal.jpg,https://ik.imagekit.io/flashspdstr/risaa/couture.jpg,https://ik.imagekit.io/flashspdstr/risaa/pret.jpg,https://ik.imagekit.io/flashspdstr/risaa/trousseau.png'
            | split: ','
          -%}
          {%- assign _acc_img = _acc_imgs[forloop.index0] | default: _acc_imgs[0] -%}
          <img
            src="{{ _acc_img }}"
            alt="{{ block.settings.heading }}"
            loading="lazy"
            style="width:100%;height:100%;object-fit:cover;"
          >
        {% endif %}

        <div class="risaa-accordion-info">
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.subheading }}</p>
          {% if block.settings.link != blank %}
            <a
              href="{{ block.settings.link }}"
              class="btn-premium"
              style="margin-top: 15px; border-color: white; color: white;"
              >Shop Now</a
            >
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<script>
  (function () {
    function initAccordion(container) {
      if (!container) return;
      var items = Array.from(container.querySelectorAll('.risaa-accordion-item'));
      var n = items.length;
      if (!n) return;

      var GAP = 6;
      var activeIdx = -1;

      function layout(animate) {
        var totalW = container.offsetWidth - 30;
        var unitW, expandedW;

        if (activeIdx === -1) {
          unitW = (totalW - GAP * (n - 1)) / n;
          expandedW = unitW;
        } else {
          var totalGap = GAP * (n - 1);
          var units = (n - 1) * 0.6 + 4;
          unitW = (totalW - totalGap) / units;
          expandedW = unitW * 4;
        }

        if (!animate) {
          items.forEach(function (item) {
            item.style.transition = 'none';
          });
        }

        var x = 0;
        items.forEach(function (item, i) {
          var w = activeIdx !== -1 && i === activeIdx ? expandedW : unitW;
          item.style.width = w + 'px';
          item.style.transform = 'translateX(' + x + 'px)';
          x += w + GAP;
          item.classList.toggle('is-active', i === activeIdx);
        });

        if (!animate) {
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              items.forEach(function (item) {
                item.style.transition = '';
              });
            });
          });
        }
      }

      // Position items from left edge of container
      items.forEach(function (item) {
        item.style.left = '15px';
      });

      layout(false);

      items.forEach(function (item, i) {
        item.addEventListener('mouseenter', function () {
          activeIdx = i;
          layout(true);
        });
      });

      container.addEventListener('mouseleave', function () {
        activeIdx = -1;
        layout(true);
      });

      var resizeTimer;
      window.addEventListener('resize', function () {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function () {
          layout(false);
        }, 100);
      });
    }

    function boot() {
      document.querySelectorAll('[id^="risaa-accordion-"]').forEach(initAccordion);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }

    if (window.Shopify && Shopify.designMode) {
      document.addEventListener('shopify:section:load', function (e) {
        var c = e.target.querySelector('[id^="risaa-accordion-"]');
        if (c) initAccordion(c);
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Image Accordion",
  "tag": "section",
  "class": "section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Explore Our Collections"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Custom-crafted for individuality"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Desktop Height",
      "default": 600
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Accordion Panel",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Couture"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Elegant designs for special occasions"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Accordion",
      "blocks": [
        { "type": "panel", "settings": { "heading": "Bridal" } },
        { "type": "panel", "settings": { "heading": "Couture" } },
        { "type": "panel", "settings": { "heading": "Pret" } }
      ]
    }
  ]
}
{% endschema %}
