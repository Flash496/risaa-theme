{%- style -%}
  .risaa-welcome-popup-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(5px);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease, visibility 0.5s ease;
  }

  .risaa-welcome-popup-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .risaa-welcome-popup {
    background: var(--brand-text);
    width: 90%;
    max-width: 620px;
    display: flex;
    flex-direction: column;
    border-radius: 32px 0 32px 0;
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0,0,0,0.3);
    transform: translateY(30px);
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }


  .risaa-welcome-popup-overlay.active .risaa-welcome-popup {
    transform: translateY(0);
  }

  .risaa-popup-close {
    position: absolute;
    top: 15px;
    right: 15px;
    background: transparent;
    border: none;
    font-size: 24px;
    color: var(--brand-text);
    cursor: pointer;
    z-index: 10;
    transition: transform 0.3s ease;
  }

  @media screen and (max-width: 749px) {
    .risaa-popup-close {
      color: var(--brand-main);
    }
  }

  .risaa-popup-close:hover {
    transform: rotate(90deg);
  }

  .risaa-popup-image {
    flex: 1;
    display: block;
    width: 100%;
    height: 180px;
    object-fit: cover;
    object-position: center;
  }

  @media screen and (min-width: 750px) {
    .risaa-welcome-popup {
      flex-direction: row;
    }
    
    .risaa-popup-image {
      height: 100%;
      min-height: 320px;
      width: 45%;
    }
  }

  .risaa-popup-content {
    flex: 1.2;
    padding: 2rem 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media screen and (min-width: 750px) {
    .risaa-popup-content {
      padding: 2.5rem 2rem;
    }
  }


  .risaa-popup-eyebrow {
    font-family: var(--font-body);
    font-size: 0.9rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--brand-undertone-1);
    margin-bottom: 1rem;
  }

  .risaa-popup-title {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    color: var(--brand-main);
    margin-bottom: 0.75rem;
    line-height: 1.2;
    font-variant-numeric: lining-nums;
    font-feature-settings: "lnum" 1;
  }

  .risaa-popup-text {
    font-size: 1.1rem;
    color: #555;
    margin-bottom: 2rem;
  }

  .risaa-popup-code {
    display: inline-block;
    padding: 12px 24px;
    background: #f9f9f9;
    border: 1px dashed var(--brand-main);
    color: var(--brand-main);
    font-family: var(--font-body);
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    margin-bottom: 2rem;
  }

  .risaa-popup-btn {
    display: inline-block;
    padding: 12px 32px;
    background: var(--brand-main);
    color: var(--brand-text);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.9rem;
    border: 1px solid var(--brand-main);
    cursor: pointer;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .risaa-popup-btn:hover {
    background: transparent;
    color: var(--brand-main);
  }
{%- endstyle -%}

<div id="RisaaWelcomePopup" class="risaa-welcome-popup-overlay">
  <div class="risaa-welcome-popup">
    <button class="risaa-popup-close" id="RisaaPopupClose" aria-label="Close">&times;</button>
    
    {% if section.settings.image != blank %}
      <img class="risaa-popup-image" src="{{ section.settings.image | image_url: width: 600 }}" alt="Welcome Offer">
    {% else %}
      <img class="risaa-popup-image" src="https://ik.imagekit.io/flashspdstr/risaa/pink%20sharara%20with%20light%20golden%20embroidery%20with_.jpg" alt="Welcome Offer">
    {% endif %}
    
    <div class="risaa-popup-content">
      <span class="risaa-popup-eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="risaa-popup-title">{{ section.settings.title }}</h2>
      <p class="risaa-popup-text">{{ section.settings.text }}</p>
      
      {% if section.settings.code != blank %}
        <div class="risaa-popup-code">{{ section.settings.code }}</div>
      {% endif %}
      
      <button class="risaa-popup-btn" id="RisaaPopupContinue">{{ section.settings.btn_text }}</button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const popup = document.getElementById('RisaaWelcomePopup');
    const closeBtn = document.getElementById('RisaaPopupClose');
    const continueBtn = document.getElementById('RisaaPopupContinue');

    // Scroll trigger
    const scrollTrigger = () => {
      // Show when user scrolls down
      if (window.scrollY > 300) {
        popup.classList.add('active');
        window.removeEventListener('scroll', scrollTrigger);
      }
    };

    window.addEventListener('scroll', scrollTrigger);

    const closePopup = () => {
      popup.classList.remove('active');
    };

    closeBtn.addEventListener('click', closePopup);
    continueBtn.addEventListener('click', closePopup);
    
    // Close on overlay click
    popup.addEventListener('click', function(e) {
      if (e.target === popup) {
        closePopup();
      }
    });
  });
</script>

{% schema %}
{
  "name": "Welcome Popup",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Popup Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Welcome to RiSaa"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Unlock 10% Off"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Sign up for our newsletter or use the code below to get 10% off your first order of handcrafted luxury."
    },
    {
      "type": "text",
      "id": "code",
      "label": "Discount Code",
      "default": "WELCOME10"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Continue Shopping"
    }
  ],
  "presets": [
    {
      "name": "Welcome Popup"
    }
  ]
}
{% endschema %}
