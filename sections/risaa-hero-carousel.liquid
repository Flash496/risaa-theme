{%- style -%}
  .risaa-hero-carousel {
    position: relative;
    width: 100%;
    height: 80vh;
    overflow: hidden;
  }

  .risaa-carousel-track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .risaa-carousel-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .risaa-carousel-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .risaa-carousel-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.2) 100%);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    color: var(--brand-text);
  }

  .risaa-carousel-overlay h2 {
    color: var(--brand-text);
    font-size: 5rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease 0.3s;
  }

  .risaa-carousel-overlay p {
    font-size: 1.8rem;
    max-width: 600px;
    margin-bottom: 2.5rem;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease 0.5s;
  }

  .risaa-carousel-overlay .btn-premium {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease 0.7s;
    background: transparent;
    border-color: var(--brand-text);
  }

  .risaa-carousel-overlay .btn-premium:hover {
    background: var(--brand-text);
    color: var(--brand-main);
  }

  .risaa-carousel-slide.active .risaa-carousel-overlay h2,
  .risaa-carousel-slide.active .risaa-carousel-overlay p,
  .risaa-carousel-slide.active .risaa-carousel-overlay .btn-premium {
    opacity: 1;
    transform: translateY(0);
  }

  .risaa-carousel-controls {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 15px;
    z-index: 10;
  }

  .risaa-carousel-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .risaa-carousel-dot.active {
    background-color: var(--brand-text);
    transform: scale(1.3);
  }

  .risaa-carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    color: var(--brand-text);
    font-size: 3rem;
    cursor: pointer;
    z-index: 10;
    opacity: 0.6;
    transition: opacity 0.3s;
  }

  .risaa-carousel-arrow:hover {
    opacity: 1;
  }

  .risaa-arrow-left {
    left: 30px;
  }

  .risaa-arrow-right {
    right: 30px;
  }

  @media screen and (max-width: 749px) {
    .risaa-hero-carousel {
      height: 60vh;
    }
    .risaa-carousel-overlay h2 {
      font-size: 3rem;
    }
    .risaa-carousel-overlay p {
      font-size: 1.4rem;
      padding: 0 20px;
    }
    .risaa-arrow-left {
      left: 10px;
    }
    .risaa-arrow-right {
      right: 10px;
    }
  }
{%- endstyle -%}

<div class="risaa-hero-carousel" id="risaa-carousel-{{ section.id }}" data-anim="fade" data-anim-delay="0">
  <div class="risaa-carousel-track" id="risaa-track-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="risaa-carousel-slide {% if forloop.first %}active{% endif %}" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {{
            block.settings.image
            | image_url: width: 2000
            | image_tag: class: 'risaa-carousel-image', loading: 'lazy'
          }}
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'risaa-carousel-image' }}
        {% endif %}

        <div class="risaa-carousel-overlay">
          <h2>{{ block.settings.title }}</h2>
          <p>{{ block.settings.subtitle }}</p>
          {% if block.settings.btn_label != blank %}
            <a href="{{ block.settings.btn_link }}" class="btn-premium">{{ block.settings.btn_label }}</a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  <button class="risaa-carousel-arrow risaa-arrow-left" onclick="moveCarousel{{ section.id | replace: '-', '_' }}(-1)">
    &#10094;
  </button>
  <button class="risaa-carousel-arrow risaa-arrow-right" onclick="moveCarousel{{ section.id | replace: '-', '_' }}(1)">
    &#10095;
  </button>

  <div class="risaa-carousel-controls" id="risaa-controls-{{ section.id }}">
    {% for block in section.blocks %}
      <div
        class="risaa-carousel-dot {% if forloop.first %}active{% endif %}"
        onclick="setCarousel{{ section.id | replace: '-', '_' }}({{ forloop.index0 }})"
      ></div>
    {% endfor %}
  </div>
</div>

<script>
  let currentSlide{{ section.id | replace: '-', '_' }} = 0;
  const totalSlides{{ section.id | replace: '-', '_' }} = {{ section.blocks.size }};
  const track{{ section.id | replace: '-', '_' }} = document.getElementById('risaa-track-{{ section.id }}');
  const dots{{ section.id | replace: '-', '_' }} = document.getElementById('risaa-controls-{{ section.id }}').children;
  const slides{{ section.id | replace: '-', '_' }} = track{{ section.id | replace: '-', '_' }}.children;
  let autoPlay{{ section.id | replace: '-', '_' }};

  function updateCarousel{{ section.id | replace: '-', '_' }}() {
    track{{ section.id | replace: '-', '_' }}.style.transform = `translateX(-${currentSlide{{ section.id | replace: '-', '_' }} * 100}%)`;
    
    for(let i=0; i<totalSlides{{ section.id | replace: '-', '_' }}; i++) {
      dots{{ section.id | replace: '-', '_' }}[i].classList.remove('active');
      slides{{ section.id | replace: '-', '_' }}[i].classList.remove('active');
    }
    
    dots{{ section.id | replace: '-', '_' }}[currentSlide{{ section.id | replace: '-', '_' }}].classList.add('active');
    slides{{ section.id | replace: '-', '_' }}[currentSlide{{ section.id | replace: '-', '_' }}].classList.add('active');
  }

  function moveCarousel{{ section.id | replace: '-', '_' }}(direction) {
    currentSlide{{ section.id | replace: '-', '_' }} = (currentSlide{{ section.id | replace: '-', '_' }} + direction + totalSlides{{ section.id | replace: '-', '_' }}) % totalSlides{{ section.id | replace: '-', '_' }};
    updateCarousel{{ section.id | replace: '-', '_' }}();
    resetAutoPlay{{ section.id | replace: '-', '_' }}();
  }

  function setCarousel{{ section.id | replace: '-', '_' }}(index) {
    currentSlide{{ section.id | replace: '-', '_' }} = index;
    updateCarousel{{ section.id | replace: '-', '_' }}();
    resetAutoPlay{{ section.id | replace: '-', '_' }}();
  }

  function startAutoPlay{{ section.id | replace: '-', '_' }}() {
    autoPlay{{ section.id | replace: '-', '_' }} = setInterval(() => {
      moveCarousel{{ section.id | replace: '-', '_' }}(1);
    }, 5000);
  }

  function resetAutoPlay{{ section.id | replace: '-', '_' }}() {
    clearInterval(autoPlay{{ section.id | replace: '-', '_' }});
    startAutoPlay{{ section.id | replace: '-', '_' }}();
  }

  // Initialize
  setTimeout(() => {
    slides{{ section.id | replace: '-', '_' }}[0].classList.add('active');
  }, 100);
  startAutoPlay{{ section.id | replace: '-', '_' }}();
</script>

{% schema %}
{
  "name": "Hero Carousel",
  "tag": "section",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "New Collection"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subheading",
          "default": "Discover the latest trends"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Carousel",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "title": "Bridal Couture",
            "subtitle": "Artfully custom-crafted for individuality",
            "btn_label": "Explore Bridal"
          }
        },
        {
          "type": "slide",
          "settings": {
            "title": "Accessible Luxury",
            "subtitle": "Slow Fashion • Prêt • Fusion",
            "btn_label": "Shop All"
          }
        }
      ]
    }
  ]
}
{% endschema %}
