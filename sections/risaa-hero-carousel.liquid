{%- style -%}
  .risaa-hero-carousel {
    position: relative;
    width: 100%;
    height: calc(80vh + 45px);
    overflow: hidden;
  }

  .risaa-carousel-track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .risaa-carousel-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .risaa-carousel-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .risaa-carousel-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.2) 100%);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    color: var(--brand-text);
  }

  .risaa-carousel-overlay h2 {
    color: var(--brand-text);
    font-size: 5rem;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease 0.3s;
  }

  .risaa-carousel-overlay p {
    font-size: 1.8rem;
    max-width: 600px;
    margin-bottom: 2.5rem;
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease 0.5s;
  }

  .risaa-carousel-overlay .btn-premium {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease 0.7s;
    background: transparent;
    border-color: var(--brand-text);
  }

  .risaa-carousel-overlay .btn-premium:hover {
    background: var(--brand-text);
    color: var(--brand-main);
  }

  .risaa-carousel-slide.active .risaa-carousel-overlay h2,
  .risaa-carousel-slide.active .risaa-carousel-overlay p,
  .risaa-carousel-slide.active .risaa-carousel-overlay .btn-premium {
    opacity: 1;
    transform: translateY(0);
  }

  .risaa-carousel-controls {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 15px;
    z-index: 10;
  }

  .risaa-carousel-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.4);
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .risaa-carousel-dot.active {
    background-color: var(--brand-text);
    transform: scale(1.3);
  }

  .risaa-carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    color: var(--brand-text);
    font-size: 3rem;
    cursor: pointer;
    z-index: 10;
    opacity: 0.6;
    transition: opacity 0.3s;
  }

  .risaa-carousel-arrow:hover {
    opacity: 1;
  }

  .risaa-arrow-left {
    left: 30px;
  }

  .risaa-arrow-right {
    right: 30px;
  }

  /* ── Per-slide text styles ── */

  /* Slide 1 — Bridal Couture: dramatic italic serif, bottom-left */
  .risaa-carousel-slide:nth-child(1) .risaa-carousel-overlay {
    align-items: flex-start;
    justify-content: flex-end;
    text-align: left;
    padding: 0 0 6rem 6rem;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.65) 0%, rgba(0, 0, 0, 0.1) 60%, transparent 100%);
  }
  .risaa-carousel-slide:nth-child(1) .risaa-carousel-overlay h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 6.5rem;
    letter-spacing: 0.02em;
    line-height: 1.05;
    text-transform: none;
    max-width: 700px;
  }
  .risaa-carousel-slide:nth-child(1) .risaa-carousel-overlay p {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    max-width: 500px;
  }

  /* Slide 2 — Accessible Luxury: wide-tracked editorial, centered */
  .risaa-carousel-slide:nth-child(2) .risaa-carousel-overlay {
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.15) 100%);
  }
  .risaa-carousel-slide:nth-child(2) .risaa-carousel-overlay h2 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-weight: 300;
    font-size: 5.5rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    line-height: 1.2;
  }
  .risaa-carousel-slide:nth-child(2) .risaa-carousel-overlay p {
    font-family: 'Assistant', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    opacity: 0.85;
  }

  /* Slide 3 — Trousseau Dreams: right-side composition, script + details grouped */
  .risaa-carousel-slide:nth-child(3) .risaa-carousel-overlay {
    align-items: flex-end;
    justify-content: center;
    flex-direction: column;
    text-align: right;
    padding: 0 5rem 0 0;
    background: linear-gradient(to left, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.25) 50%, transparent 80%);
    gap: 1.2rem;
  }
  .risaa-carousel-slide:nth-child(3) .risaa-carousel-overlay h2 {
    font-family: 'Great Vibes', cursive;
    font-size: 9rem;
    letter-spacing: 0.02em;
    text-transform: none;
    font-weight: 400;
    line-height: 1;
    max-width: 600px;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.35);
  }
  .risaa-carousel-slide:nth-child(3) .risaa-carousel-overlay p {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 1.7rem;
    letter-spacing: 0.1em;
    max-width: 420px;
    border-right: 2px solid rgba(255, 255, 255, 0.45);
    padding-right: 1.2rem;
    color: rgba(255, 255, 255, 0.88);
  }
  .risaa-carousel-slide:nth-child(3) .risaa-carousel-overlay .btn-premium {
    align-self: flex-end;
  }

  /* Slide 4 — Pret Collection: left-anchored with vertical accent + clean stacked layout */
  .risaa-carousel-slide:nth-child(4) .risaa-carousel-overlay {
    align-items: flex-start;
    justify-content: center;
    flex-direction: row;
    text-align: left;
    padding: 0 0 0 5rem;
    background: linear-gradient(100deg, rgba(0, 0, 0, 0.65) 0%, rgba(0, 0, 0, 0.2) 50%, transparent 75%);
    gap: 2.5rem;
  }
  /* Vertical accent bar */
  .risaa-carousel-slide:nth-child(4) .risaa-carousel-overlay::before {
    content: '';
    display: block;
    width: 2px;
    height: 180px;
    background: linear-gradient(to bottom, transparent, rgba(255, 255, 255, 0.7), transparent);
    flex-shrink: 0;
    align-self: center;
  }
  /* Text block sits to the right of the bar */
  .risaa-carousel-slide:nth-child(4) .risaa-carousel-overlay > * {
    flex-shrink: 0;
  }
  .risaa-carousel-slide:nth-child(4) .risaa-carousel-overlay h2 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 100;
    font-size: 7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1;
    color: rgba(255, 255, 255, 0.93);
    align-self: center;
  }
  /* Subtitle + button stacked vertically, centered on the bar */
  .risaa-carousel-slide:nth-child(4) .risaa-carousel-overlay p {
    font-family: 'Montserrat', sans-serif;
    font-weight: 300;
    font-size: 1.05rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    align-self: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.35);
    padding-bottom: 1rem;
  }
  .risaa-carousel-slide:nth-child(4) .risaa-carousel-overlay .btn-premium {
    align-self: center;
    letter-spacing: 0.2em;
    font-size: 1rem;
    margin-left: -1rem;
  }

  /* Slide 5 — New Arrivals: outline text center with subtitle as flanked eyebrow above */
  .risaa-carousel-slide:nth-child(5) .risaa-carousel-overlay {
    align-items: center;
    justify-content: center;
    flex-direction: column;
    text-align: center;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.2) 50%, rgba(0, 0, 0, 0.4) 100%);
    gap: 0;
  }
  .risaa-carousel-slide:nth-child(5) .risaa-carousel-overlay p {
    font-family: 'Cinzel', Georgia, serif;
    font-size: 1rem;
    letter-spacing: 0.55em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.65);
    display: flex;
    align-items: center;
    gap: 1.4rem;
    margin-bottom: 1.2rem;
    order: -1;
  }
  .risaa-carousel-slide:nth-child(5) .risaa-carousel-overlay p::before,
  .risaa-carousel-slide:nth-child(5) .risaa-carousel-overlay p::after {
    content: '';
    display: block;
    width: 60px;
    height: 1px;
    background: rgba(255, 255, 255, 0.45);
    flex-shrink: 0;
  }
  .risaa-carousel-slide:nth-child(5) .risaa-carousel-overlay h2 {
    font-family: 'Cinzel', Georgia, serif;
    font-weight: 400;
    font-size: 6.5rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    line-height: 1;
    -webkit-text-stroke: 1.5px rgba(255, 255, 255, 0.9);
    color: transparent;
    text-shadow: 0 0 80px rgba(255, 255, 255, 0.12);
  }
  .risaa-carousel-slide:nth-child(5) .risaa-carousel-overlay .btn-premium {
    margin-top: 2.5rem;
    letter-spacing: 0.3em;
    font-family: 'Cinzel', Georgia, serif;
    font-size: 1rem;
  }

  @media screen and (max-width: 749px) {
    .risaa-hero-carousel {
      height: 60vh;
    }
    .risaa-arrow-left {
      left: 10px;
    }
    .risaa-arrow-right {
      right: 10px;
    }
  }
{%- endstyle -%}

<div class="risaa-hero-carousel" id="risaa-carousel-{{ section.id }}" data-anim="fade" data-anim-delay="0">
  <div class="risaa-carousel-track" id="risaa-track-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="risaa-carousel-slide {% if forloop.first %}active{% endif %}" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {{
            block.settings.image
            | image_url: width: 2000
            | image_tag: class: 'risaa-carousel-image', loading: 'lazy'
          }}
        {% elsif block.settings.image_url != blank %}
          <img
            src="{{ block.settings.image_url }}"
            alt="{{ block.settings.title }}"
            class="risaa-carousel-image"
            loading="lazy"
          >
        {% else %}
          {%- assign slide_imgs = 'https://ik.imagekit.io/flashspdstr/risaa/beautiful-turkish-girl-long-red-dress-walks-summer-old-city%20(1).jpg,https://ik.imagekit.io/flashspdstr/risaa/alok-verma-jQ3UdoWiFis-unsplash.jpg,https://ik.imagekit.io/flashspdstr/risaa/naganath-chiluveru-Uzl-KYPAH44-unsplash.jpg,https://ik.imagekit.io/flashspdstr/risaa/akhil-pawar-Ys52rPvPbpU-unsplash.jpg,https://ik.imagekit.io/flashspdstr/risaa/beautiful-turkish-girl-long-red-dress-walks-summer-old-city.jpg'
            | split: ','
          -%}
          {%- assign slide_img = slide_imgs[forloop.index0] | default: slide_imgs[0] -%}
          <img src="{{ slide_img }}" alt="{{ block.settings.title }}" class="risaa-carousel-image" loading="lazy">
        {% endif %}

        <div class="risaa-carousel-overlay">
          <h2>{{ block.settings.title }}</h2>
          <p>{{ block.settings.subtitle }}</p>
          {% if block.settings.btn_label != blank %}
            <a href="{{ block.settings.btn_link }}" class="btn-premium">{{ block.settings.btn_label }}</a>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  <button class="risaa-carousel-arrow risaa-arrow-left" onclick="moveCarousel{{ section.id | replace: '-', '_' }}(-1)">
    &#10094;
  </button>
  <button class="risaa-carousel-arrow risaa-arrow-right" onclick="moveCarousel{{ section.id | replace: '-', '_' }}(1)">
    &#10095;
  </button>

  <div class="risaa-carousel-controls" id="risaa-controls-{{ section.id }}">
    {% for block in section.blocks %}
      <div
        class="risaa-carousel-dot {% if forloop.first %}active{% endif %}"
        onclick="setCarousel{{ section.id | replace: '-', '_' }}({{ forloop.index0 }})"
      ></div>
    {% endfor %}
  </div>
</div>

<script>
  let currentSlide{{ section.id | replace: '-', '_' }} = 0;
  const totalSlides{{ section.id | replace: '-', '_' }} = {{ section.blocks.size }};
  const track{{ section.id | replace: '-', '_' }} = document.getElementById('risaa-track-{{ section.id }}');
  const dots{{ section.id | replace: '-', '_' }} = document.getElementById('risaa-controls-{{ section.id }}').children;
  const slides{{ section.id | replace: '-', '_' }} = track{{ section.id | replace: '-', '_' }}.children;
  let autoPlay{{ section.id | replace: '-', '_' }};

  function updateCarousel{{ section.id | replace: '-', '_' }}() {
    track{{ section.id | replace: '-', '_' }}.style.transform = `translateX(-${currentSlide{{ section.id | replace: '-', '_' }} * 100}%)`;
    
    for(let i=0; i<totalSlides{{ section.id | replace: '-', '_' }}; i++) {
      dots{{ section.id | replace: '-', '_' }}[i].classList.remove('active');
      slides{{ section.id | replace: '-', '_' }}[i].classList.remove('active');
    }
    
    dots{{ section.id | replace: '-', '_' }}[currentSlide{{ section.id | replace: '-', '_' }}].classList.add('active');
    slides{{ section.id | replace: '-', '_' }}[currentSlide{{ section.id | replace: '-', '_' }}].classList.add('active');
  }

  function moveCarousel{{ section.id | replace: '-', '_' }}(direction) {
    currentSlide{{ section.id | replace: '-', '_' }} = (currentSlide{{ section.id | replace: '-', '_' }} + direction + totalSlides{{ section.id | replace: '-', '_' }}) % totalSlides{{ section.id | replace: '-', '_' }};
    updateCarousel{{ section.id | replace: '-', '_' }}();
    resetAutoPlay{{ section.id | replace: '-', '_' }}();
  }

  function setCarousel{{ section.id | replace: '-', '_' }}(index) {
    currentSlide{{ section.id | replace: '-', '_' }} = index;
    updateCarousel{{ section.id | replace: '-', '_' }}();
    resetAutoPlay{{ section.id | replace: '-', '_' }}();
  }

  function startAutoPlay{{ section.id | replace: '-', '_' }}() {
    autoPlay{{ section.id | replace: '-', '_' }} = setInterval(() => {
      moveCarousel{{ section.id | replace: '-', '_' }}(1);
    }, 5000);
  }

  function resetAutoPlay{{ section.id | replace: '-', '_' }}() {
    clearInterval(autoPlay{{ section.id | replace: '-', '_' }});
    startAutoPlay{{ section.id | replace: '-', '_' }}();
  }

  // Initialize
  setTimeout(() => {
    slides{{ section.id | replace: '-', '_' }}[0].classList.add('active');
  }, 100);
  startAutoPlay{{ section.id | replace: '-', '_' }}();
</script>

{% schema %}
{
  "name": "Hero Carousel",
  "tag": "section",
  "max_blocks": 8,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL",
          "info": "Enter external image URL (overrides image picker)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "New Collection"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subheading",
          "default": "Discover the latest trends"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Carousel",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "title": "Bridal Couture",
            "subtitle": "Artfully custom-crafted for individuality",
            "btn_label": "Explore Bridal"
          }
        },
        {
          "type": "slide",
          "settings": {
            "title": "Accessible Luxury",
            "subtitle": "Slow Fashion • Prêt • Fusion",
            "btn_label": "Shop All"
          }
        }
      ]
    }
  ]
}
{% endschema %}
