{%- style -%}
  .risaa-hero-carousel {
    position: relative;
    width: 100%;
    height: calc(90vh);
    overflow: hidden;
  }

  .risaa-carousel-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .risaa-carousel-slide {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 1.2s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .risaa-carousel-slide.active {
    opacity: 1;
    pointer-events: auto;
  }

  .risaa-carousel-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1);
    transition: transform 6.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .risaa-carousel-slide.active .risaa-carousel-image {
    transform: scale(1.2);
  }

  .risaa-carousel-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
    transition: all 0.5s ease;
    z-index: 5;
  }

  /* Alignment Variants */
  .risaa-carousel-overlay--center {
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 3rem;
    background: rgba(0, 0, 0, 0.35);
  }

  /* Default: no vertical shift */
  .risaa-carousel-overlay-content {
    transform: translateY(0);
  }

  /* Only lift specific slides by title */
  .risaa-carousel-slide[data-slide-title='bridal couture'] .risaa-carousel-overlay-content,
  .risaa-carousel-slide[data-slide-title='pret collection'] .risaa-carousel-overlay-content {
    transform: translateY(-50px);
  }

  .risaa-carousel-overlay--left {
    justify-content: flex-end;
    align-items: flex-start;
    text-align: left;
    padding: 0 0 8rem 8rem;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.65) 0%, rgba(0, 0, 0, 0.25) 50%, transparent 100%);
  }

  .risaa-carousel-overlay--right {
    justify-content: flex-end;
    align-items: flex-end;
    text-align: right;
    padding: 0 8rem 8rem 0;
    background: linear-gradient(to left, rgba(0, 0, 0, 0.65) 0%, rgba(0, 0, 0, 0.25) 50%, transparent 100%);
  }

  /* Typography Styles (Unified & Minimalist) */
  .risaa-carousel-overlay h2 {
    color: #ffffff !important;
    font-family: var(--font-heading-family) !important;
    font-size: 4.8rem;
    font-weight: 400 !important;
    line-height: 1.2;
    margin: 0 0 1.6rem 0;
    text-transform: uppercase !important;
    opacity: 0;
    letter-spacing: 0.1em;
    transform: translateY(15px);
    transition: opacity 1s ease, transform 1s ease;
    transition-delay: 0.3s;
  }

  .risaa-carousel-slide.active .risaa-carousel-overlay h2 {
    opacity: 1;
    transform: translateY(0);
  }

  .risaa-carousel-overlay p {
    color: #ffffff !important;
    font-family: var(--font-body-family) !important;
    font-size: 1.6rem;
    font-weight: 300 !important;
    max-width: 600px;
    margin: 0 0 3.2rem 0;
    text-transform: uppercase !important;
    opacity: 0;
    letter-spacing: 0.15em;
    transform: translateY(15px);
    transition: opacity 1s ease, transform 1s ease;
    transition-delay: 0.5s;
  }

  .risaa-carousel-slide.active .risaa-carousel-overlay p {
    opacity: 1;
    transform: translateY(0);
  }

  .risaa-carousel-overlay .btn-premium {
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 1s ease 0.7s, transform 1s ease 0.7s, background-color 0.3s ease, color 0.3s ease,
      border-color 0.3s ease;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.8) !important;
    color: #ffffff !important;
    padding: 14px 36px !important;
    letter-spacing: 0.15em !important;
    font-size: 1.2rem !important;
    text-transform: uppercase !important;
    font-family: var(--font-body-family) !important;
    border-radius: 0 !important;
    text-decoration: none;
    display: inline-block;
  }

  .risaa-carousel-slide.active .risaa-carousel-overlay .btn-premium {
    opacity: 1;
    transform: translateY(0);
  }

  @media screen and (max-width: 749px) {
    .risaa-hero-carousel {
      height: 75vh;
    }
    .risaa-carousel-overlay--left,
    .risaa-carousel-overlay--right {
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 2.5rem;
      background: rgba(0, 0, 0, 0.45);
    }
    .risaa-carousel-overlay h2 {
      font-size: 3rem;
      margin-bottom: 1rem;
      letter-spacing: 0.1em;
    }
    .risaa-carousel-overlay p {
      font-size: 1.2rem;
      margin-bottom: 2rem;
      letter-spacing: 0.18em;
    }
    .risaa-carousel-overlay .btn-premium {
      padding: 11px 28px !important;
      font-size: 0.95rem !important;
    }
    .risaa-carousel-dashboard {
      bottom: 20px;
      gap: 16px;
      padding: 8px 16px;
    }
    .risaa-carousel-progress-wrap {
      width: 50px;
    }
  }
{%- endstyle -%}

<div class="risaa-hero-carousel" id="risaa-carousel-{{ section.id }}" data-anim="fade" data-anim-delay="0">
  <div class="risaa-carousel-track" id="risaa-track-{{ section.id }}">
    {% for block in section.blocks %}
      <div
        class="risaa-carousel-slide {% if forloop.first %}active{% endif %}"
        data-slide-title="{{ block.settings.title | downcase }}"
        {{ block.shopify_attributes }}
      >
        {% if block.settings.image != blank %}
          {{
            block.settings.image
            | image_url: width: 2000
            | image_tag: class: 'risaa-carousel-image', loading: 'lazy'
          }}
        {% elsif block.settings.image_url != blank %}
          <img
            src="{{ block.settings.image_url }}"
            alt="{{ block.settings.title }}"
            class="risaa-carousel-image"
            loading="lazy"
          >
        {% else %}
          {%- assign slide_imgs = 'https://ik.imagekit.io/flashspdstr/risaa/bridal%20couture.jpg,https://ik.imagekit.io/flashspdstr/risaa/hero%20banner.jpg,https://ik.imagekit.io/flashspdstr/risaa/collection%201.jpg,https://ik.imagekit.io/flashspdstr/risaa/hero%20banner345.jpg,https://ik.imagekit.io/flashspdstr/risaa/desi%20flower%20field%20eid%20girl.jpg'
            | split: ','
          -%}
          {%- assign slide_img = slide_imgs[forloop.index0] | default: slide_imgs[0] -%}
          <img src="{{ slide_img }}" alt="{{ block.settings.title }}" class="risaa-carousel-image" loading="lazy">
        {% endif %}

        <div class="risaa-carousel-overlay risaa-carousel-overlay--{{ block.settings.alignment | default: 'center' }}">
          <div class="risaa-carousel-overlay-content">
            <h2>{{ block.settings.title }}</h2>
            <p>{{ block.settings.subtitle }}</p>
            {% if block.settings.btn_label != blank %}
              <a href="{{ block.settings.btn_link }}" class="btn-premium">{{ block.settings.btn_label }}</a>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<script>
  let currentSlide{{ section.id | replace: '-', '_' }} = 0;
  const totalSlides{{ section.id | replace: '-', '_' }} = {{ section.blocks.size }};
  const track{{ section.id | replace: '-', '_' }} = document.getElementById('risaa-track-{{ section.id }}');
  const slides{{ section.id | replace: '-', '_' }} = track{{ section.id | replace: '-', '_' }}.children;
  let autoPlay{{ section.id | replace: '-', '_' }};

  function updateCarousel{{ section.id | replace: '-', '_' }}() {
    for (let i = 0; i < totalSlides{{ section.id | replace: '-', '_' }}; i++) {
      slides{{ section.id | replace: '-', '_' }}[i].classList.remove('active');
    }
    slides{{ section.id | replace: '-', '_' }}[currentSlide{{ section.id | replace: '-', '_' }}].classList.add('active');
  }

  function moveCarousel{{ section.id | replace: '-', '_' }}(direction) {
    currentSlide{{ section.id | replace: '-', '_' }} = (currentSlide{{ section.id | replace: '-', '_' }} + direction + totalSlides{{ section.id | replace: '-', '_' }}) % totalSlides{{ section.id | replace: '-', '_' }};
    updateCarousel{{ section.id | replace: '-', '_' }}();
    resetAutoPlay{{ section.id | replace: '-', '_' }}();
  }

  function startAutoPlay{{ section.id | replace: '-', '_' }}() {
    autoPlay{{ section.id | replace: '-', '_' }} = setInterval(() => {
      moveCarousel{{ section.id | replace: '-', '_' }}(1);
    }, 6000);
  }

  function resetAutoPlay{{ section.id | replace: '-', '_' }}() {
    clearInterval(autoPlay{{ section.id | replace: '-', '_' }});
    startAutoPlay{{ section.id | replace: '-', '_' }}();
  }

  // Initialize — first slide visible immediately
  slides{{ section.id | replace: '-', '_' }}[0].classList.add('active');
  startAutoPlay{{ section.id | replace: '-', '_' }}();
</script>

{% schema %}
{
  "name": "Hero Carousel",
  "tag": "section",
  "max_blocks": 8,
  "settings": [],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL",
          "info": "Enter external image URL (overrides image picker)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Text Alignment",
          "options": [
            { "value": "center", "label": "Center" },
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "center"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "New Collection"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subheading",
          "default": "Discover the latest trends"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Carousel",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "title": "Bridal Couture",
            "subtitle": "Artfully custom-crafted for individuality",
            "btn_label": "Explore Bridal"
          }
        },
        {
          "type": "slide",
          "settings": {
            "title": "Accessible Luxury",
            "subtitle": "Slow Fashion • Prêt • Fusion",
            "btn_label": "Shop All"
          }
        }
      ]
    }
  ]
}
{% endschema %}
