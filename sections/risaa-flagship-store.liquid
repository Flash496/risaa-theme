{%- liquid
  assign bg_image_url = 'https://ik.imagekit.io/flashspdstr/risaa/store%20image.jpg'
  if section.settings.background_image != blank
    assign bg_image_url = section.settings.background_image | image_url: width: 2000
  endif
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    margin-top: 0 !important;
    padding-top: 0 !important;
    width: 100% !important;
    max-width: 100% !important;
    padding-left: 0 !important;
    padding-right: 0 !important;
    box-sizing: border-box;
  }

  .risaa-flagship-store-section {
    width: 100%;
    min-height: {{ section.settings.desktop_height }}px;
    background-image: url('{{ bg_image_url }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    position: relative;
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    box-sizing: border-box;
    overflow: visible;
    z-index: 2;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .risaa-flagship-store-container {
    width: 100%;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 6rem;
    box-sizing: border-box;
    display: flex;
    justify-content: flex-start;
    align-items: flex-start;
  }

  .risaa-flagship-card-wrapper {
    width: 100%;
    max-width: 350px;
    margin-bottom: -80px;
    filter: drop-shadow(0 15px 30px rgba(0, 0, 0, 0.08));
  }

  .risaa-flagship-card {
    background-color: #ffffff;
    width: 100%;
    padding: 4rem 2.5rem 6rem 2.5rem;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    min-height: calc({{ section.settings.desktop_height }}px + 80px);
    clip-path: polygon(0 0, 100% 0, 100% 100%, 50% calc(100% - 30px), 0 100%);
  }

  .flagship-eyebrow {
    font-family: var(--font-body);
    font-size: 1.1rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--brand-gold);
    font-weight: 500;
    margin-bottom: 0.5rem;
    display: block;
  }

  .flagship-title {
    font-family: 'Cinzel', Georgia, serif !important;
    font-size: 2.6rem !important;
    color: var(--brand-main) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.15em !important;
    line-height: 1.25 !important;
    font-weight: 400 !important;
    margin: 0 0 0.5rem 0;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(110, 20, 35, 0.1);
  }

  .flagship-group {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .flagship-group-title {
    font-family: 'Cinzel', Georgia, serif !important;
    font-size: 1.3rem !important;
    color: var(--brand-gold) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.15em !important;
    font-weight: 500 !important;
    margin: 0;
  }

  .flagship-text {
    font-family: var(--font-body);
    font-size: 1.35rem;
    color: var(--brand-dark);
    line-height: 1.6;
    margin: 0;
    font-weight: 300;
  }

  .flagship-link {
    font-family: var(--font-body);
    font-size: 1.35rem;
    color: var(--brand-main);
    font-weight: 500;
    text-decoration: none;
    display: inline-block;
    width: fit-content;
    border-bottom: 1px solid var(--brand-main);
    padding-bottom: 2px;
    transition: opacity 0.2s ease, border-color 0.2s ease;
  }

  .flagship-link:hover {
    opacity: 0.7;
    border-color: transparent;
  }

  .flagship-cta {
    margin-top: 1rem;
  }

  .flagship-btn {
    display: inline-block;
    width: 100%;
    text-align: center;
    padding: 15px 30px;
    font-size: 1.3rem !important;
    font-weight: 500;
    background-color: var(--brand-main);
    color: var(--brand-text) !important;
    border: 1px solid var(--brand-main);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-decoration: none;
    transition: var(--transition-quick);
    box-sizing: border-box;
  }

  .flagship-btn:hover {
    background-color: transparent;
    color: var(--brand-main) !important;
  }

  @media screen and (max-width: 989px) {
    .risaa-flagship-store-container {
      padding: 0 4rem;
    }
  }

  @media screen and (max-width: 749px) {
    .risaa-flagship-store-section {
      min-height: {{ section.settings.mobile_height }}px;
      padding-top: 4rem;
      padding-bottom: 4rem;
      justify-content: center;
      align-items: flex-end;
    }

    .risaa-flagship-store-container {
      padding: 0 2rem;
      justify-content: center;
    }

    .risaa-flagship-card-wrapper {
      max-width: 100%;
      margin-bottom: -60px;
    }

    .risaa-flagship-card {
      padding: 3rem 2.5rem 5rem 2.5rem;
      gap: 2rem;
      min-height: calc({{ section.settings.mobile_height }}px + 60px);
      clip-path: polygon(0 0, 100% 0, 100% 100%, 50% calc(100% - 25px), 0 100%);
    }

    .flagship-title {
      font-size: 2.2rem !important;
    }
  }
{%- endstyle -%}

<section class="risaa-flagship-store-section" id="RisaaFlagshipSection-{{ section.id }}">
  <div class="risaa-flagship-store-container">
    <div class="risaa-flagship-card-wrapper" data-anim="roll-down">
      <div class="risaa-flagship-card">
        <div>
          {%- if section.settings.eyebrow != blank -%}
          <span class="flagship-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
        <h2 class="flagship-title">{{ section.settings.heading }}</h2>
      </div>

      <div class="flagship-group">
        {%- if section.settings.timings_eyebrow != blank -%}
          <h3 class="flagship-group-title">{{ section.settings.timings_eyebrow }}</h3>
        {%- endif -%}
        {%- if section.settings.timings != blank -%}
          <p class="flagship-text">{{ section.settings.timings }}</p>
        {%- endif -%}
        {%- if section.settings.phone != blank -%}
          <p class="flagship-text">
            <a href="tel:{{ section.settings.phone | replace: ' ', '' | replace: '-', '' }}" class="flagship-link">
              {{- section.settings.phone -}}
            </a>
          </p>
        {%- endif -%}
      </div>

      <div class="flagship-group">
        {%- if section.settings.address_eyebrow != blank -%}
          <h3 class="flagship-group-title">{{ section.settings.address_eyebrow }}</h3>
        {%- endif -%}
        <div class="flagship-text">
          {%- if section.settings.address_line_1 != blank -%}
            <div>{{ section.settings.address_line_1 }}</div>
          {%- endif -%}
          {%- if section.settings.address_line_2 != blank -%}
            <div>{{ section.settings.address_line_2 }}</div>
          {%- endif -%}
          {%- if section.settings.address_line_3 != blank -%}
            <div>{{ section.settings.address_line_3 }}</div>
          {%- endif -%}
        </div>
        {%- if section.settings.email != blank -%}
          <p class="flagship-text">
            <a href="mailto:{{ section.settings.email }}" class="flagship-link">
              {{- section.settings.email -}}
            </a>
          </p>
        {%- endif -%}
      </div>

      {%- liquid
        assign button_link = section.settings.button_link
        if button_link == blank
          assign button_link = 'https://maps.app.goo.gl/GijLheNTVLk7mghM9'
        endif
      -%}
      {%- if section.settings.button_label != blank -%}
        <div class="flagship-cta">
          <a
            href="{{ button_link }}"
            class="flagship-btn"
            target="_blank"
            rel="noopener"
          >
            {{- section.settings.button_label -}}
          </a>
        </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Risaa Flagship Store",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Visit Our Store"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Studio Heading",
      "default": "RiSaa - The Design Studio"
    },
    {
      "type": "header",
      "content": "Timings & Contact"
    },
    {
      "type": "text",
      "id": "timings_eyebrow",
      "label": "Timings Eyebrow",
      "default": "Mon – Sun"
    },
    {
      "type": "text",
      "id": "timings",
      "label": "Timings Text",
      "default": "11:00 AM – 7:30 PM"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "+91 9501032126"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email Address",
      "default": "hello@risaa.com"
    },
    {
      "type": "header",
      "content": "Address Details"
    },
    {
      "type": "text",
      "id": "address_eyebrow",
      "label": "Address Eyebrow",
      "default": "Reach Us"
    },
    {
      "type": "text",
      "id": "address_line_1",
      "label": "Address Line 1",
      "default": "117-B, Jyoti Colony, Part B"
    },
    {
      "type": "text",
      "id": "address_line_2",
      "label": "Address Line 2",
      "default": "Model Town Extension"
    },
    {
      "type": "text",
      "id": "address_line_3",
      "label": "Address Line 3",
      "default": "Ludhiana, Punjab 141002"
    },
    {
      "type": "header",
      "content": "Call To Action"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Get directions"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Directions URL"
    },
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Desktop Height",
      "default": 550
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 300,
      "max": 600,
      "step": 50,
      "unit": "px",
      "label": "Mobile Height",
      "default": 400
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Risaa Flagship Store"
    }
  ]
}
{% endschema %}
