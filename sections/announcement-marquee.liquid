{%- style -%}
  .announcement-bar {
    background-color: #EDE0D4;
    color: var(--brand-main);
    padding: 10px 0;
    position: relative;
    width: 100%;
    z-index: 1000;
    text-align: center;
    border-bottom: 1px solid rgba(110, 20, 35, 0.1);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .announcement-bar__wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0 20px;
    position: relative;
  }

  .announcement-bar__btn {
    background: none;
    border: none;
    color: var(--brand-main);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0 15px;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.7;
    transition: opacity 0.2s;
  }
  
  .announcement-bar__btn:hover {
    opacity: 1;
  }

  .announcement-bar__btn svg {
    width: 12px;
    height: 12px;
    fill: currentColor;
  }

  .announcement-bar__carousel {
    position: relative;
    height: auto;
    min-height: 20px; /* Adjust based on font size */
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .announcement-bar__item {
    position: absolute;
    width: 100%;
    font-family: var(--font-body);
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    text-transform: none;
    font-weight: 600;
    opacity: 0;
    transition: opacity 0.8s ease-in-out;
    pointer-events: none;
  }

  .announcement-bar__item.active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  @media screen and (max-width: 749px) {
    .announcement-bar {
      padding: 8px 0;
    }
    .announcement-bar__carousel {
      height: auto;
      min-height: 28px;
    }
    .announcement-bar__item {
      font-size: 1.1rem;
      line-height: 1.3;
      padding: 0 10px;
    }
    .announcement-bar__btn {
      padding: 0 5px;
    }
  }
{%- endstyle -%}

<div class="announcement-bar" role="region" aria-label="Announcement">
  <div class="announcement-bar__wrapper">
    {%- if section.blocks.size > 1 -%}
      <button class="announcement-bar__btn announcement-bar__btn--prev" aria-label="Previous announcement">
        <span class="svg-wrapper" style="transform: rotate(90deg); display: flex;">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
    {%- endif -%}

    <div class="announcement-bar__carousel" id="AnnouncementCarousel-{{ section.id }}">
      {%- for block in section.blocks -%}
        <div class="announcement-bar__item {% if forloop.first %}active{% endif %}" {{ block.shopify_attributes }}>
          {{ block.settings.text }}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.blocks.size > 1 -%}
      <button class="announcement-bar__btn announcement-bar__btn--next" aria-label="Next announcement">
        <span class="svg-wrapper" style="transform: rotate(-90deg); display: flex;">
          {{- 'icon-caret.svg' | inline_asset_content -}}
        </span>
      </button>
    {%- endif -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const carousel = document.getElementById('AnnouncementCarousel-{{ section.id }}');
    if (!carousel) return;
    
    const items = carousel.querySelectorAll('.announcement-bar__item');
    if (items.length <= 1) return; // No need to slide if only 1 item

    let currentIndex = 0;
    const totalItems = items.length;
    let autoPlayInterval;

    function showSlide(index) {
      items[currentIndex].classList.remove('active');
      items[currentIndex].style.position = 'absolute';
      
      currentIndex = (index + totalItems) % totalItems;
      
      items[currentIndex].classList.add('active');
      items[currentIndex].style.position = 'relative';
    }

    function nextSlide() {
      showSlide(currentIndex + 1);
    }

    function prevSlide() {
      showSlide(currentIndex - 1);
    }

    function startAutoPlay() {
      stopAutoPlay();
      autoPlayInterval = setInterval(nextSlide, 4000);
    }

    function stopAutoPlay() {
      if (autoPlayInterval) {
        clearInterval(autoPlayInterval);
      }
    }

    // Event listeners for buttons
    // Since we have multiple elements inside the section, we scope the query to this section
    const prevBtn = carousel.parentElement.querySelector('.announcement-bar__btn--prev');
    const nextBtn = carousel.parentElement.querySelector('.announcement-bar__btn--next');

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        prevSlide();
        startAutoPlay(); // Reset timer on manual click
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        nextSlide();
        startAutoPlay(); // Reset timer on manual click
      });
    }

    // Start auto-play initially
    startAutoPlay();
  });
</script>

{% schema %}
{
  "name": "Announcement Carousel",
  "max_blocks": 5,
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Free pan-India shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Carousel",
      "blocks": [
        {
          "type": "announcement",
          "settings": {
            "text": "Sale alerts & discounts"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "Free pan-India shipping"
          }
        },
        {
          "type": "announcement",
          "settings": {
            "text": "24 hr dispatch on selected items"
          }
        }
      ]
    }
  ]
}
{% endschema %}
