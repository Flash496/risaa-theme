{%- style -%}
  .risaa-usps {
    background-color: var(--brand-text);
    padding: 5rem 0;
    border-top: 1px solid rgba(110, 20, 35, 0.08);
    border-bottom: 1px solid rgba(110, 20, 35, 0.08);
    position: relative;
  }

  .risaa-usps__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3rem;
  }

  .risaa-usps__item {
    text-align: center;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .risaa-usps__icon-wrapper {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    color: var(--brand-gold);
  }

  .risaa-usps__icon-wrapper svg {
    width: 32px;
    height: 32px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .risaa-usps__title {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    color: var(--brand-main);
    letter-spacing: 0.15em;
    margin: 0 0 0.8rem;
    text-transform: uppercase;
    font-weight: 500;
  }

  .risaa-usps__text {
    font-family: var(--font-body);
    font-size: 1.2rem;
    color: var(--brand-dark);
    line-height: 1.5;
    margin: 0;
    font-weight: 300;
    opacity: 0.85;
    max-width: 240px;
  }

  @media screen and (max-width: 989px) {
    .risaa-usps__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }
  }

  @media screen and (max-width: 749px) {
    .risaa-usps {
      padding: 3.5rem 0;
    }
    .risaa-usps__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .risaa-usps__item {
      padding: 1rem;
    }
  }
{%- endstyle -%}

<section class="risaa-usps" id="risaa-usps-{{ section.id }}">
  <div class="page-width">
    <div class="risaa-usps__grid">
      {%- for block in section.blocks -%}
        <div class="risaa-usps__item" {{ block.shopify_attributes }}>
          <div class="risaa-usps__icon-wrapper">
            {%- case block.settings.icon -%}
              {%- when 'measure' -%}
                <!-- Ruler / Tape / Fit Measure Icon -->
                <svg viewBox="0 0 24 24">
                  <path d="M4 5h16a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1z"/>
                  <path d="M7 5v4M11 5v7M15 5v4M19 5v5"/>
                </svg>
              {%- when 'shipping' -%}
                <!-- Globe / Delivery Icon -->
                <svg viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
              {%- when 'luxury' -%}
                <!-- Gem / Diamond / Accessible Luxury Icon -->
                <svg viewBox="0 0 24 24">
                  <path d="M6 3h12l4 6-10 12L2 9z"/>
                  <path d="M11 3 8 9l4 12M13 3l3 6-4 12"/>
                  <path d="M2 9h20"/>
                </svg>
              {%- when 'craft' -%}
                <!-- Needle & Thread / Sparkle Icon -->
                <svg viewBox="0 0 24 24">
                  <path d="M12 3a9 9 0 0 0-9 9c0 3 2.5 5 2.5 5S6 21 12 21s6.5-4 6.5-4 2.5-2 2.5-5a9 9 0 0 0-9-9z"/>
                  <path d="M12 8v8M8 12h8"/>
                </svg>
            {%- endcase -%}
          </div>
          <h3 class="risaa-usps__title">{{ block.settings.title }}</h3>
          <p class="risaa-usps__text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Risaa USPs",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "usp",
      "name": "USP",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "measure", "label": "Custom Fit (Ruler)" },
            { "value": "shipping", "label": "Worldwide Shipping (Globe)" },
            { "value": "luxury", "label": "Accessible Luxury (Gem)" },
            { "value": "craft", "label": "Artisanal Craft (Needle/Sparkle)" }
          ],
          "default": "measure"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Custom Tailoring"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Perfect, made-to-measure fit designed precisely for you."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Risaa USPs",
      "blocks": [
        { "type": "usp", "settings": { "icon": "measure", "title": "Perfect Tailored Fit", "text": "Each ensemble is crafted to your unique measurements for a flawless drape." } },
        { "type": "usp", "settings": { "icon": "shipping", "title": "Worldwide Shipping", "text": "Delivering beautiful customized ethnic wear to your doorstep globally." } },
        { "type": "usp", "settings": { "icon": "luxury", "title": "Accessible Luxury", "text": "Premium quality couture without the traditional luxury retail markups." } },
        { "type": "usp", "settings": { "icon": "craft", "title": "Artisanal Heritage", "text": "Handcrafted details and exquisite embroideries from our master artisans." } }
      ]
    }
  ]
}
{% endschema %}
